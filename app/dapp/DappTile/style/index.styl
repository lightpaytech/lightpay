// VAULT — Dapp Tile (left sidebar icon tiles)

.lpAppTile
  display flex
  justify-content center
  align-items center
  flex-direction column
  color rgba(186, 230, 253, 0.7)
  margin 6px 0px
  cursor pointer
  transition 0.22s cubic-bezier(0.4, 0, 0.2, 1) all
  -webkit-user-select none

  // ─── Icon container ───────────────────────────────────────────────────────

  .lpAppIcon
    height 58px
    width 58px
    background rgb(6, 9, 22)
    border 1px solid rgba(14, 165, 233, 0.18)
    border-radius 18px
    display flex
    justify-content center
    align-items center
    flex-direction column
    cursor pointer
    transition 0.22s cubic-bezier(0.4, 0, 0.2, 1) all
    position relative
    overflow hidden

    img
      width 100%
      height 100%
      object-fit cover
      border-radius 17px

    svg
      color rgba(186, 230, 253, 0.7)
      transition 0.18s cubic-bezier(0.4, 0, 0.2, 1) color

    // Border glow ring on hover (no box-shadow)
    &::after
      content ''
      position absolute
      inset 0
      border-radius 18px

  .lpAppIcon:hover
    background rgb(10, 14, 35)
    border-color rgba(14, 165, 233, 0.4)

    svg
      color rgb(14, 165, 233)

    &::after
      border 1px solid rgba(14, 165, 233, 0.15)

  // ─── Active / selected tile ───────────────────────────────────────────────

  .lpAppIcon.dappIconActive
    background rgba(14, 165, 233, 0.1)
    border-color rgba(14, 165, 233, 0.4)

    svg
      color rgb(14, 165, 233)

  // ─── Status indicator dot ─────────────────────────────────────────────────

  .dappStatusDot
    position absolute
    bottom 4px
    right 4px
    width 8px
    height 8px
    border-radius 50%
    border 1.5px solid rgb(3, 5, 15)
    background rgba(100, 116, 139, 0.6)

  .dappStatusDot.dappStatusConnected
    background rgb(14, 165, 233)

  // ─── Loading overlay ──────────────────────────────────────────────────────

  .dappIconLoading
    position absolute
    inset 0
    border-radius 18px
    display flex
    align-items center
    justify-content center
    background rgba(3, 5, 15, 0.7)

    .dappIconSpinner
      width 22px
      height 22px
      border-radius 50%
      border-top 2px solid rgba(14, 165, 233, 0.9)
      border-right 2px solid rgba(14, 165, 233, 0.2)
      border-bottom 2px solid rgba(14, 165, 233, 0.08)
      border-left 2px solid rgba(14, 165, 233, 0.08)
      animation vaultTileSpin 0.7s infinite linear

  @keyframes vaultTileSpin
    0%
      transform rotate(0deg)
    100%
      transform rotate(360deg)

  // ─── Dapp label ───────────────────────────────────────────────────────────

  .lpAppName
    font-size 10px
    text-transform uppercase
    font-weight 400
    letter-spacing 0.05em
    color rgba(186, 230, 253, 0.7)
    margin-top 5px
    text-align center
    max-width 64px
    overflow hidden
    text-overflow ellipsis
    white-space nowrap
    transition 0.18s cubic-bezier(0.4, 0, 0.2, 1) color

.lpAppTile:hover .lpAppName
  color rgb(224, 242, 254)
