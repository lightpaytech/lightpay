// LightPay VAULT — Theme Chooser (unique onboarding screen)

.themeChooserSlide
  padding 32px 24px

.themeChooserGrid
  display grid
  grid-template-columns 1fr 1fr
  gap 14px
  width 100%
  margin-top 8px

.themeChooserOption
  border 2px solid rgba(14, 165, 233, 0.18)
  border-radius 16px
  padding 16px
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  position relative
  display flex
  flex-direction column
  gap 12px
  align-items center

.themeChooserOption:hover
  border-color rgba(14, 165, 233, 0.4)
  background rgba(14, 165, 233, 0.04)

// Dark theme option is the default — pre-selected electric blue state
.themeChooserOptionActive
  border-color rgba(14, 165, 233, 0.6)
  background rgba(14, 165, 233, 0.08)

.themeChooserPreview
  width 100%
  height 90px
  border-radius 10px
  padding 10px
  display flex
  flex-direction column
  gap 6px
  overflow hidden

.themeChooserPreviewDark
  background rgb(3, 5, 15)
  border 1px solid rgba(14, 165, 233, 0.2)

.themeChooserPreviewLight
  background #f0f6ff
  border 1px solid rgba(0,0,0,0.08)

.themeChooserPreviewBar
  height 6px
  border-radius 3px
  width 60%
  background rgba(14, 165, 233, 0.5)

.themeChooserPreviewDark .themeChooserPreviewCard
  height 12px
  border-radius 4px
  background rgba(14, 165, 233, 0.12)

.themeChooserPreviewLight .themeChooserPreviewCard
  height 12px
  border-radius 4px
  background rgba(0,0,0,0.07)

.themeChooserPreviewCardShort
  width 70% !important

.themeChooserOptionLabel
  font-size 13px
  font-weight 500
  color rgb(224, 242, 254)
  letter-spacing 0.02em

.themeChooserCheck
  position absolute
  top 10px
  right 10px
  width 22px
  height 22px
  border-radius 50%
  background rgb(14, 165, 233)
  border 1px solid rgba(14, 165, 233, 0.5)
  display flex
  align-items center
  justify-content center
  color rgb(3, 5, 15)
