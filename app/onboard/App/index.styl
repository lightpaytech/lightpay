// LightPay VAULT — Onboarding
@import '../../../resources/base'

html, body
  margin 0
  border 0
  font-family 'MainFont'
  font-weight 300
  -webkit-app-region drag
  overflow hidden
  color var(--outerspace)
  background var(--ghostA)

div
  user-select none
  cursor default

::-webkit-scrollbar
  display none

.light
  --ghostA rgb(248, 250, 255)
  --ghostB rgb(240, 245, 255)
  --ghostC rgb(224, 235, 252)
  --good rgb(14, 165, 233)
  --goodUp rgb(56, 189, 248)
  --good01 rgba(14, 165, 233, 0.1)
  --good02 rgba(14, 165, 233, 0.2)
  --good04 rgba(14, 165, 233, 0.4)
  --bad rgb(220, 38, 38)
  --overlayA rgba(14, 165, 233, 0.04)
  --overlayB rgba(14, 165, 233, 0.06)

.dark
  --ghostA rgb(248, 250, 255)
  --ghostB rgb(240, 245, 255)
  --ghostC rgb(224, 235, 252)
  --good rgb(14, 165, 233)
  --goodUp rgb(56, 189, 248)
  --good01 rgba(14, 165, 233, 0.1)
  --good02 rgba(14, 165, 233, 0.2)
  --good04 rgba(14, 165, 233, 0.4)
  --bad rgb(244, 63, 94)
  --overlayA rgba(14, 165, 233, 0.03)
  --overlayB rgba(14, 165, 233, 0.04)

// ─── Main onboard container ──────────────────────────────────
.onboard
  position fixed
  inset 0
  display flex
  flex-direction column
  overflow hidden

// ─── Slide wrapper ───────────────────────────────────────────
.onboardSlide
  flex 1
  display flex
  flex-direction column
  align-items center
  justify-content center
  padding 32px 28px
  text-align center
  gap 20px

// ─── Slide logo / icon area ──────────────────────────────────
.onboardIcon
  width 80px
  height 80px
  border-radius 24px
  background rgba(255, 255, 255, 0.08)
  border 1px solid rgba(14, 165, 233, 0.30)
  display flex
  align-items center
  justify-content center
  margin-bottom 8px

.onboardIcon img
  width 52px
  height 52px
  object-fit contain

// ─── Checkmark icon (Outro) ──────────────────────────────────
.onboardCheckmark
  width 72px
  height 72px
  border-radius 50%
  background rgba(255, 255, 255, 0.08)
  border 1.5px solid rgba(14, 165, 233, 0.45)
  display flex
  align-items center
  justify-content center
  margin-bottom 12px
  animation vaultFadeIn 0.45s cubic-bezier(0.4, 0, 0.2, 1) both

.onboardCheckmark svg
  width 36px
  height 36px
  stroke var(--good)
  fill none
  stroke-width 2.5
  stroke-linecap round
  stroke-linejoin round

// ─── Slide title ─────────────────────────────────────────────
.onboardTitle
  font-size 26px
  font-weight 500
  color rgb(15, 23, 42)
  line-height 1.25
  letter-spacing -0.01em

.onboardTitleHighlight
  color var(--good)
  display inline-block

// ─── Slide subtitle ──────────────────────────────────────────
.onboardSubtitle
  font-size 15px
  font-weight 300
  color rgba(15, 23, 42, 0.7)
  line-height 1.65
  max-width 320px

// ─── Feature list ────────────────────────────────────────────
.onboardFeatureList
  width 100%
  display flex
  flex-direction column
  gap 8px
  text-align left

.dark
  .onboardFeatureItem
    background rgb(240, 245, 255)
  .onboardFeatureItem:hover
    background rgb(224, 235, 252)

.light
  .onboardFeatureItem
    background rgb(240, 245, 255)
  .onboardFeatureItem:hover
    background rgb(224, 235, 252)

.onboardFeatureItem
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 12px
  padding 12px 16px
  display flex
  align-items center
  gap 12px
  transition var(--standardFast)

.onboardFeatureItem:hover
  border-color rgba(14, 165, 233, 0.40)

.onboardFeatureDot
  width 8px
  height 8px
  border-radius 50%
  background var(--good)
  flex-shrink 0

.onboardFeatureText
  font-size 13px
  color rgba(15, 23, 42, 0.7)
  line-height 1.5

// ─── Progress dots ───────────────────────────────────────────
.onboardProgress
  display flex
  gap 8px
  margin-bottom 8px

.onboardProgressDot
  width 8px
  height 8px
  border-radius 50%
  background rgba(14, 165, 233, 0.2)
  transition 0.25s cubic-bezier(0.4, 0, 0.2, 1) all

.onboardProgressDotActive
  background rgb(14, 165, 233)
  width 24px
  border-radius 4px

// ─── Navigation area ─────────────────────────────────────────
.onboardNav
  padding 16px 28px 24px
  display flex
  gap 10px
  -webkit-app-region no-drag

.onboardNext
  flex 1
  height 50px
  background rgb(14, 165, 233)
  border 1px solid rgba(14, 165, 233, 0.40)
  border-radius 14px
  color white
  font-family 'MainFont'
  font-size 15px
  font-weight 500
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  letter-spacing 0.02em

.onboardNext:hover
  background rgb(56, 189, 248)
  border-color rgba(14, 165, 233, 0.50)

.onboardBack
  width 50px
  height 50px
  border-radius 14px
  border 1px solid rgba(14, 165, 233, 0.18)
  background transparent
  color rgba(15, 23, 42, 0.7)
  display flex
  align-items center
  justify-content center
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

.onboardBack:hover
  border-color rgba(14, 165, 233, 0.40)
  color rgb(14, 165, 233)
  background rgba(255, 255, 255, 0.06)

// ─── Window controls (traffic lights) ───────────────────────
.onboardWindowControls
  position absolute
  top 12px
  left 16px
  display flex
  gap 6px
  -webkit-app-region no-drag

.onboardWindowDot
  width 12px
  height 12px
  border-radius 50%
  cursor pointer

.onboardWindowClose
  background rgba(255, 96, 92, 0.8)
.onboardWindowMin
  background rgba(255, 189, 46, 0.8)
.onboardWindowMax
  background rgba(39, 201, 63, 0.8)

@import './Slides/ThemeChooser/index'

.themeChooserPreviewCard
  height 12px
  border-radius 4px

.themeChooserPreviewDark .themeChooserPreviewCard
  background rgba(14, 165, 233, 0.12)

.themeChooserPreviewLight .themeChooserPreviewCard
  background rgba(0,0,0,0.07)
