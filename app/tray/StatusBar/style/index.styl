// ─── Electric Blue Design: Badge ──────────────────────────────────────────────
// Floating pill badges — electric blue dark theme
// Transition: 0.28s cubic-bezier(0.4,0,0.2,1)

// ─── Badge wrap (full-screen overlay carrier) ─────────────────────────────────

.statusWrap
  position absolute
  right 0px
  bottom 0px
  left 0px
  top 0px
  z-index 1000000001
  background rgba(3, 5, 15, 0.75)
  display flex
  justify-content center
  align-items center

// ─── Badge modal card ─────────────────────────────────────────────────────────

.statusIndicator
  width calc(100% - 20px)
  transform translateY(700px)
  border-radius 16px
  background rgb(6, 9, 22)
  border 1px solid rgba(14, 165, 233, 0.2)
  z-index 1
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all
  font-size 15px
  font-weight 300
  padding-bottom 120px
  padding-top 70px
  height 196px
  color rgb(224, 242, 254)

  .badgeMessage, .badgeInput
    position relative
    z-index 10

  .badgeMessage
    height 120px
    display flex
    justify-content center
    align-items center
    text-align center
    padding 0px 40px 0px 40px
    color rgb(224, 242, 254)
    font-size 15px
    font-weight 300

  .badgeInput
    width 100%
    display flex
    justify-content center
    margin-bottom 5px

    .badgeInputButton
      width 400px
      display flex
      justify-content center
      align-items center
      cursor pointer
      transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

      .statusInputInner
        height 40px
        width calc(80% - 2px)
        display flex
        justify-content center
        align-items center
        border-radius 10px
        text-transform uppercase
        font-size 13px
        font-weight 400
        letter-spacing 1px
        margin-left 1px
        cursor pointer
        background rgb(10, 14, 35)
        border 1px solid rgba(14, 165, 233, 0.2)
        transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

      .statusInputInner:hover
        background rgb(6, 9, 22)
        border-color rgba(14, 165, 233, 0.4)

      .statusInputSmall
        font-size 11px
        height 28px
        width calc(60% - 2px)

// ─── Pill statusIndicator strip ────────────────────────────────────────────────

.statusStrip
  position fixed
  top 12px
  right 12px
  z-index 99999999
  display flex
  align-items center
  gap 8px

.statusChip
  background rgb(10, 14, 35)
  border 1px solid rgba(14, 165, 233, 0.2)
  border-radius 20px
  padding 5px 12px
  font-size 12px
  font-weight 400
  color rgb(224, 242, 254)
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

.statusChipGood
  border-color rgba(14, 165, 233, 0.5)
  color rgb(14, 165, 233)

.statusChipBad
  border-color rgba(244, 63, 94, 0.5)
  color var(--bad)
