// VAULT — Transaction History

.historyWrap
  padding 14px

.historyEmpty
  padding 24px 14px
  text-align center
  display flex
  flex-direction column
  align-items center
  gap 10px

.historyEmptyIcon
  width 48px
  height 48px
  border-radius 16px
  background rgba(14, 165, 233, 0.07)
  border 1px solid rgba(14, 165, 233, 0.18)
  display flex
  align-items center
  justify-content center
  color rgba(14, 165, 233, 0.5)

.historyEmptyText
  font-size 13px
  color var(--outerspace06)

.historyEmptySubtext
  font-size 11px
  color var(--outerspace04)

.historyItem
  background rgb(10, 14, 35)
  border-bottom 1px solid rgba(14, 165, 233, 0.08)
  border-radius 12px
  padding 12px 14px
  margin-bottom 6px
  display flex
  align-items center
  gap 10px
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

.historyItem:hover
  border-color rgba(14, 165, 233, 0.4)
  background rgba(14, 165, 233, 0.06)

.historyItemIcon
  width 34px
  height 34px
  border-radius 50%
  display flex
  align-items center
  justify-content center
  flex-shrink 0

.historyItemIconSend
  background rgba(255, 75, 100, 0.1)
  color var(--bad)

.historyItemIconReceive
  background rgba(14, 165, 233, 0.1)
  color rgb(14, 165, 233)

.historyItemIconContract
  background rgba(14, 165, 233, 0.1)
  color rgb(14, 165, 233)

.historyItemInfo
  flex 1
  min-width 0

.historyItemType
  font-size 13px
  font-weight 400
  color var(--outerspace)

.historyItemTime
  font-size 11px
  color var(--outerspace04)
  margin-top 2px

.historyItemValue
  font-family 'CodeFont'
  font-size 12px
  font-weight 300
  text-align right

.historyItemValueSend
  color var(--bad)

.historyItemValueReceive
  color rgb(14, 165, 233)
