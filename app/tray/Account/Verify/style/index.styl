// VAULT — Address Verify Screen

.deviceVerify
  padding 20px
  display flex
  flex-direction column
  gap 16px
  align-items center
  text-align center

.deviceVerifyTitle
  font-size 16px
  font-weight 500
  color var(--outerspace)

.deviceVerifyAddress
  font-family 'CodeFont'
  font-size 11px
  color var(--outerspace07)
  background rgb(240, 245, 255)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 10px
  padding 10px 14px
  letter-spacing 0.06em
  width 100%
  word-break break-all
  text-align left

.deviceVerifyStatus
  width 60px
  height 60px
  border-radius 50%
  display flex
  align-items center
  justify-content center

.deviceVerifyStatusOk
  background rgba(14, 165, 233, 0.1)
  border 2px solid rgba(14, 165, 233, 0.40)
  color rgb(14, 165, 233)

.deviceVerifyStatusFail
  background rgba(255, 75, 100, 0.1)
  border 2px solid rgba(255, 75, 100, 0.35)
  color rgb(255, 75, 100)

.deviceVerifyMsg
  font-size 13px
  color var(--outerspace07)
  line-height 1.55
