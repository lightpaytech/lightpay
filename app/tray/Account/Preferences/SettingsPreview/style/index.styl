// VAULT — Account Preferences Preview

.prefPreview
  padding 10px 14px
  display flex
  flex-direction column
  gap 4px

.prefPreviewItem
  display flex
  align-items center
  justify-content space-between
  padding 6px 0
  border-bottom 1px solid rgba(14, 165, 233, 0.06)

.prefPreviewItem:last-child
  border-bottom none

.prefPreviewLabel
  font-size 12px
  color var(--outerspace07)

.prefPreviewValue
  font-size 12px
  font-family 'CodeFont'
  color var(--outerspace05)

.prefPreviewToggleOn
  color rgb(14, 165, 233)
  font-size 11px

.prefPreviewToggleOff
  color var(--outerspace04)
  font-size 11px
