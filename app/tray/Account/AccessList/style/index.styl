// VAULT design — Permissions module

// ── Module header ─────────────────────────────────────────────────────────────
.permissionsModuleHeader
  font-size 11px
  letter-spacing 0.1em
  text-transform uppercase
  color var(--outerspace05)
  padding 14px 14px 8px
  font-weight 400

// ── Module section ────────────────────────────────────────────────────────────
.moduleMainPermissions
  border-radius 12px
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  overflow hidden
  margin-bottom 8px

// ── Clear button ──────────────────────────────────────────────────────────────
.clearPermsBtn
  padding 6px

// ── Dapp row ──────────────────────────────────────────────────────────────────
// favicon 20px | dapp name (flex grow) | connection time right
.devicePerm
  position relative
  justify-content space-between
  padding 12px 14px
  font-size 13px
  font-weight 300
  color var(--outerspace07)
  transform translateZ(0)
  z-index 2000
  width 100%
  display flex
  align-items center
  border-bottom 1px solid rgba(14, 165, 233, 0.08)
  box-sizing border-box
  transition background 0.12s ease-out

  &:last-child
    border-bottom none

  &:hover
    background rgba(255, 255, 255, 0.05)
    cursor pointer

  .signerPermissionControls
    display flex
    position relative
    align-items center
    justify-content space-between
    transform translateZ(0)
    z-index 40
    width 100%

  .signerPermissionDetails
    display flex
    position relative
    justify-content space-between
    align-items center
    transform translateZ(0)
    font-size 13px
    padding 10px 0px 0px 1px
    z-index 20
    font-weight 300
    color var(--outerspace07)

// ── Favicon ───────────────────────────────────────────────────────────────────
.signerPermissionFavicon
  width 20px
  height 20px
  border-radius 4px
  margin-right 10px
  flex-shrink 0
  overflow hidden
  background var(--ghostA)

  img
    width 100%
    height 100%
    object-fit cover

// ── Origin / dapp name ────────────────────────────────────────────────────────
.signerPermissionOrigin
  background transparent
  width 250px
  direction rtl
  text-overflow ellipsis
  overflow hidden
  text-align left
  white-space nowrap
  font-size 13px
  font-weight 300
  color var(--outerspace07)
  margin-top 4px
  flex 1

// ── Connection time ───────────────────────────────────────────────────────────
.signerPermissionTime
  font-family 'CodeFont'
  font-size 11px
  font-weight 200
  color var(--outerspace05)
  margin-left auto
  padding-left 8px
  white-space nowrap

// ── Connected indicator — emerald dot ─────────────────────────────────────────
.devicePermDotOn
  background var(--good)
  width 7px
  height 7px
  border-radius 50%
  flex-shrink 0
  margin-right 8px

// ── Disconnected — gray dot ───────────────────────────────────────────────────
.devicePermDotOff
  background var(--outerspace05)
  width 7px
  height 7px
  border-radius 50%
  flex-shrink 0
  margin-right 8px

// ── Revoke button ─────────────────────────────────────────────────────────────
.devicePermRevoke
  border 1px solid rgba(244, 63, 94, 0.3)
  border-radius 8px
  color var(--bad)
  font-size 11px
  font-weight 400
  padding 4px 10px
  cursor pointer
  transition all 0.12s ease-out
  background transparent
  white-space nowrap
  flex-shrink 0

.devicePermRevoke:hover
  background rgba(244, 63, 94, 0.08)
  border-color rgba(244, 63, 94, 0.5)

// ── Permission toggle (full size) ─────────────────────────────────────────────
.devicePermToggle
  position relative
  background rgb(224, 235, 252)
  height 24px
  width 44px
  border-radius 12px
  transition var(--standard)
  margin-top 4px
  cursor pointer
  border 1px solid rgba(14, 165, 233, 0.22)
  box-sizing border-box
  padding 0

  .signerPermissionToggleSwitch
    position absolute
    top 50%
    left 2px
    width 18px
    height 18px
    border-radius 50%
    transition var(--standard)
    background rgb(255, 255, 255)
    box-shadow 0 1px 3px rgba(15, 23, 42, 0.20), 0 0 0 1px rgba(15, 23, 42, 0.05)
    transform translateY(-50%)
    pointer-events none

.signerPermissionToggleOn
  background rgb(14, 165, 233)
  border-color rgb(14, 165, 233)

  .signerPermissionToggleSwitch
    left calc(100% - 20px)
    box-shadow 0 1px 4px rgba(15, 23, 42, 0.28), 0 0 0 1px rgba(15, 23, 42, 0.05)

.devicePermToggle:hover
  border-color rgba(14, 165, 233, 0.50)

.signerPermissionToggleOn:hover
  background rgb(2, 132, 199)
  border-color rgb(2, 132, 199)

// ── Permission toggle (small) ─────────────────────────────────────────────────
.devicePermToggleSmall
  position relative
  background rgb(224, 235, 252)
  height 18px
  width 32px
  border-radius 9px
  transition var(--standard)
  margin-top 2px
  margin-right 4px
  cursor pointer
  border 1px solid rgba(14, 165, 233, 0.22)
  box-sizing border-box

  .signerPermissionToggleSwitch
    position absolute
    top 50%
    left 2px
    width 12px
    height 12px
    border-radius 50%
    transition var(--standard)
    background rgb(255, 255, 255)
    box-shadow 0 1px 2px rgba(15, 23, 42, 0.20)
    transform translateY(-50%)
    pointer-events none

.signerPermissionToggleSmallOn
  background rgb(14, 165, 233)
  border-color rgb(14, 165, 233)

  .signerPermissionToggleSwitch
    left calc(100% - 14px)

.devicePermToggleSmall:hover
  border-color rgba(14, 165, 233, 0.45)

.signerPermissionToggleSmallOn:hover
  background rgb(2, 132, 199)
