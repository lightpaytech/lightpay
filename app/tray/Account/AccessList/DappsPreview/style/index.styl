// VAULT — Connected Dapps Preview

.devicePermPreview
  padding 10px 14px
  display flex
  gap 6px
  flex-wrap wrap

.devicePermPreviewItem
  width 28px
  height 28px
  border-radius 8px
  overflow hidden
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  display flex
  align-items center
  justify-content center
  cursor pointer
0.15s all

  img
    width 100%
    height 100%
    object-fit cover

.devicePermPreviewItem:hover
  border-color rgba(14, 165, 233, 0.4)

.devicePermPreviewCount
  width 28px
  height 28px
  border-radius 8px
  background rgba(14, 165, 233, 0.08)
  border 1px solid rgba(14, 165, 233, 0.18)
  display flex
  align-items center
  justify-content center
  font-size 11px
  font-weight 500
  color var(--good)
  cursor pointer
