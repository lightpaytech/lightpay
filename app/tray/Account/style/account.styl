@keyframes arrowSlide
  0%
    opacity 0
    transform translateY(5px)
  20%
    opacity 1
  40%
    opacity 0
    transform translateY(-15px)
  100%
    opacity 0

@keyframes arrowSlideSingle
  0%
    opacity 0
    transform translateY(3px)
  50%
    opacity 1
  100%
    opacity 0
    transform translateY(-3px)

@keyframes headShake
  0%
    transform translateX(0)
  6.5%
    transform translateX(-6px) rotateY(-9deg)
  18.5%
    transform translateX(5px) rotateY(7deg)
  31.5%
    transform translateX(-3px) rotateY(-5deg)
  43.5%
    transform translateX(2px) rotateY(3deg)
  50%
    transform translateX(0)

.headShake
  animation-duration 1s
  animation-fill-mode both
  animation-timing-function ease-in-out
  animation-name headShake
  transform translateZ(0)

.standardFade-enter
  opacity 0

.standardFade-enter.standardFade-enter-active
  opacity 1
  transition var(--standard)

.standardFade-leave
  opacity 1

.standardFade-leave.standardFade-leave-active
  opacity 0
  transition var(--standard)

.footerModule
  position absolute
  bottom 0px
  left 0px
  right 0px
  min-height 40px
  z-index 99999999
  transition var(--standard)

  .footerWrap
    width 100%
    display flow-root

.signer
  position relative
  z-index 3001
  transition var(--standard)
  will-change transform
  transform translate3d(0, 0, 0)
  pointer-events auto
  box-sizing border-box
  z-index 10000000

  .signerContainer
    position relative
    z-index 3002
    padding 0px 0px 5px 0px

// ─── Account controller strip ────────────────────────────────────────────────

.walletHeader
  padding 14px
  background var(--ghostB)
  border-bottom 1px solid rgba(14, 165, 233, 0.18)
  box-sizing border-box

.walletHeaderTop
  height 56px
  display flex
  align-items center

.walletAvatar
  width 36px
  height 36px
  border-radius 50%
  border 2px solid rgba(14, 165, 233, 0.40)
  overflow hidden
  flex-shrink 0

.walletAccountName
  font-size 15px
  font-weight 400
  color var(--outerspace)
  letter-spacing 0.01em

.walletAccountAddr
  font-family 'CodeFont'
  font-size 11px
  color var(--outerspace06)
  letter-spacing 0.08em

// ─── Main account panel ───────────────────────────────────────────────────────

.walletMain
  position absolute
  top 138px
  right 14px
  bottom 40px
  left 14px
  z-index 3
  border-radius 0 0 16px 16px
  transition var(--standard)
  overflow hidden
  background var(--ghostB)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-top none

  .walletModulesExpand
    background var(--ghostA)
    z-index 2001
    margin-bottom 30px
    height 100%

    .moduleExpanded
      z-index 20000

      .walletModuleInner
        position relative

    .walletModule
      position relative !important

  .walletMainScroll
    position absolute
    top 0
    right 0
    bottom 0
    left 0
    overflow-y auto
    overflow-x hidden
    transform translate3d(0, 0, 0)
    border-radius 0 0 16px 16px
    scrollbar-width none

    &::-webkit-scrollbar
      display none

  .walletMainSlide
    position relative
    width 100%
    transform translate3d(0, 0, 0)
    transition var(--standardSlow)
    transition-delay 0.32s
    padding-bottom 90px
    pointer-events none
    z-index 999

.walletModule
  position absolute
  top 0
  left 2px
  right 2px
  transform translate3d(0, 0, 0)
  transition var(--standardFast)
  pointer-events auto
  padding-bottom 7px

.moduleExpanded
  min-height 100%
  .walletModuleInner
    background none
    border-radius none

.actionsPreview:hover
  .requestsPreviewArrow
    transform translateX(0px)

.actionsPreview
  height 52px
  position relative
  font-size 11px
  text-transform uppercase
  letter-spacing 0.08em
  font-family 'MainFont'
  font-weight 500
  box-sizing border-box
  border-radius 16px
  cursor pointer
  overflow hidden
  background var(--ghostAZ)

  *
    pointer-events none

  .requestsPreviewOverlay
    position absolute
    top 0
    right 0
    bottom 0
    left 0
    z-index 200
    pointer-events none
    transition var(--standardFast)
    background linear-gradient(90deg, var(--overlayA), var(--overlayB))
    border-radius 16px

  .requestPreviewContent
    position absolute
    top 0
    right 0
    bottom 0
    left 0
    display flex
    align-items center
    justify-content space-between
    cursor pointer
    z-index 200
    padding 16px 0px 16px 20px
    box-sizing border-box
    overflow hidden
    border-radius 16px

    .requestPreviewContentTitle
      display flex
      align-items center

    .requestPreviewContentArrow
      display flex
      align-items center
      padding-right 20px
      transition var(--standard)

      div
        max-width 13px

  .requestsPreviewArrow
    position absolute
    top 0
    right 0
    bottom 0
    left 0px
    transform translateX(-440px)
    transition var(--standard)

    .actionsPreviewArrow
      position absolute
      background var(--ghostA)
      left 0px
      margin -157px
      width 367px
      height 367px
      transform rotate(45deg)
      margin-left 0px
      border-radius 16px
      pointer-events none
      z-index 100
      filter blur(8px)

  span
    margin-right 8px

  .requestsBadgeOverlay
    position absolute
    top 0
    right 0
    bottom 0
    left 0
    background linear-gradient(-35deg, var(--overlayA) 0%, var(--overlayB) 100%)
    z-index 999
    pointer-events none

.walletModuleInner
  position absolute
  top 0
  left 0px
  right 0px
  bottom 7px
  transform translate3d(0, 0, 0)
  padding 0px 6px
  border-radius 16px

  .walletModuleCard
    position relative
    border-radius 16px
    background var(--ghostAZ)
    border 1px solid rgba(14, 165, 233, 0.18)

  .sectionTitle:before
    content ''
    position absolute
    bottom -2px
    right 16px
    left 16px
    height 1px
    background var(--ghostA)

  .moduleHeaderBlank
    height 6px

  .sectionTitle
    position relative
    font-size 11px
    text-transform uppercase
    letter-spacing 0.08em
    padding 16px 90px 10px 20px
    height 42px
    font-family 'MainFont'
    font-weight 500
    box-sizing border-box
    display flex
    align-items center
    color var(--outerspace06)
    margin-bottom 10px

    span
      margin-right 8px

    .moduleHeaderClose
      background var(--bad)
      color var(--moonOver)
      width 20px
      height 20px
      border-radius 10px
      position absolute
      right 11px
      top 9px
      bottom 0
      display flex
      justify-content center
      align-items center
      cursor pointer
      *
        pointer-events none

    .moduleHeaderLoading
      position absolute
      left 6px
      top 1px
      bottom 0
      display flex
      justify-content center
      align-items center

    .moduleHeaderLoadingLoader
      border-radius 50%
      width 12px
      height 12px
      margin 12px auto
      font-size 10px
      position relative
      text-indent -9999em
      border-top 3px solid var(--ghostA)
      border-right 3px solid var(--ghostA)
      border-bottom 3px solid var(--ghostA)
      border-left 3px solid var(--good)
      transform translateZ(0)
      animation load 0.5s infinite linear
      will-change transform

  .sectionTitle:before
    background none

  .moduleHeaderBorderless
    border-bottom none

  .moduleComingSoon
    padding 14px 0px 20px 0px
    display flex
    justify-content center
    color rgb(15, 23, 42)
    font-weight 300
    font-size 24px

  .sectionContent
    padding 14px

  .sectionFooter
    padding 14px

  .moduleMainSettings
    font-size 11px
    text-transform uppercase
    letter-spacing 0.08em
    font-weight 400

  .sectionFooterBtn
    position absolute
    bottom 0px
    width 100%
    cursor pointer
    text-align center
    font-size 12px
    text-transform uppercase
    border-top 1px solid rgba(14, 165, 233, 0.18)
    box-sizing border-box
    font-weight 300
    letter-spacing 1px
    padding 12px
    height 42px
    text-align center
    box-sizing border-box
    background var(--ghostB)
    z-index 400000
    transition var(--standardFast)

  .sectionFooterBtn:hover
    background rgba(255, 255, 255, 0.06)
    color var(--good)

.signerVerifyText
  font-size 15px
  text-align center
  display flex
  justify-content center
  align-items center
  height 70px
  padding 0px 30px

.sectionRow
  height 40px
  margin-bottom 6px
  display flex
  align-items center

  input
    z-index 200
    user-select auto
    background rgb(255, 255, 255)
    outline none
    border 1px solid rgba(14, 165, 233, 0.30)
    margin-left 8px
    height 100%
    color var(--outerspace)
    border-radius 8px
    padding 0px 12px
    font-size 14px
    transition var(--standardFast)

  input:focus
    border-color rgba(14, 165, 233, 0.40)
    outline none

.sectionBtn
  width 100%
  height 40px
  background var(--ghostAZ)
  border-radius 10px
  border 1px solid rgba(14, 165, 233, 0.18)
  color var(--outerspace)
  display flex
  justify-content center
  align-items center
  font-weight 400
  font-size 13px
  box-sizing border-box
  text-transform uppercase
  transition var(--standardFast)

  svg
    position relative

  span
    padding-left 4px

  *
    pointer-events none

.sectionBtn.signerVerifyInProgress
  background var(--ghostC)
  color var(--outerspace04)

.sectionBtn:hover:not(.signerVerifyInProgress)
  cursor pointer
  background rgba(255, 255, 255, 0.06)
  border-color rgba(14, 165, 233, 0.40)
  color var(--good)

.sectionBtnDanger
  color var(--bad)

.sectionBtnPrimary
  color var(--good)

.sectionBtnLocked
  color rgb(15, 23, 42)

.sectionBtnLocked:hover
  background var(--ghostB)

