.signersSlide
  position absolute
  top 0
  right 0
  bottom 0
  left 0
  z-index 6000
  pointer-events none

.panelHeader
  position relative
  height 64px
  z-index 20000000000
  transition var(--standardFast)
  box-sizing border-box
  margin 4px

  .panelHeaderTitle
    position absolute
    left 0
    top 0
    bottom 0
    font-size 20px
    padding 18px

  .walletAddChainBtn
    position absolute
    right 12px
    top 16px
    bottom 0
    cursor pointer
    height 32px
    width 106px
    border-radius 10px
    background var(--ghostB)
    border 1px solid rgba(14, 165, 233, 0.18)
    display flex
    justify-content center
    align-items center
    font-size 11px
    font-weight 300
    overflow hidden
    background-position 0 100%
    text-transform uppercase
    letter-spacing 1px
    transition var(--standardFast)
    cursor pointer

    .panelHeaderAddChainInner
      pointer-events none
      margin-left 4px
      margin-top -1px

  .walletAddChainBtn:hover
    color var(--good)
    border-color rgba(14, 165, 233, 0.4)
    background rgba(14, 165, 233, 0.06)

  .panelHeaderUpdate
    position absolute
    right 12px
    top 16px
    bottom 0
    cursor pointer
    height 32px
    width 66px
    border-radius 16px
    background var(--ghostX)
    display flex
    justify-content center
    align-items center
    font-family 'CodeFont'
    font-size 26px
    font-weight 300
    overflow hidden
    background-position 0 100%

    .panelHeaderUpdateInner
      position absolute
      top 2px
      right 2px
      bottom 2px
      left 2px
      background var(--ghostX)
      border-radius 14px

    .panelHeaderUpdateToggle
      position absolute
      height 28px
      width 55px
      border-radius 14px
      left 0px
      background var(--ghostD)
      z-index 10
      transition var(--standardFast)
      cursor pointer
      display flex
      justify-content center
      align-items center
      color var(--outerspace05)

      *
        pointer-events none

      svg
        position relative
        top 0px
        left 0px

    .panelHeaderUpdateToggle:hover
      color var(--good)

    .panelHeaderUpdateToggleOn
      color var(--good)
      transform translateX(7px)

  .panelHeaderUpdateOn
    background var(--good)

.networkMonitorSwitch
  position absolute
  top 9px
  right 9px
  display flex
  background var(--ghostA)
  padding 2px 2px 1px 2px
  border-radius 16px

  .networkSwitchBtn
    padding 2px 6px
    border-radius 10px
    background var(--ghostA)
    border 1px solid rgba(14, 165, 233, 0.18)
    border-bottom 2px solid var(--ghostA)
    cursor pointer
    *
      pointer-events none

  .networkSwitchBtn:first-child
    margin-right 3px
    border-top-right-radius 8px
    border-bottom-right-radius 8px

  .networkSwitchBtn:last-child
    border-top-left-radius 8px
    border-bottom-left-radius 8px

  .networkSwitchBtn:hover
    background var(--ghostB)
    transform translateY(-1px)
    border-bottom 2px solid var(--ghostA)
    border 1px solid rgba(14, 165, 233, 0.4)
    position relative
    z-index 300000

  .networkSwitchBtn:active
    background var(--ghostB)
    transform translateY(0px)
    border 1px solid rgba(14, 165, 233, 0.18)

@import './account.styl'
