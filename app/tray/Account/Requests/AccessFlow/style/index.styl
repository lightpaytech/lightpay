// VAULT — Provider Access Request

.accessFlowWrap
  padding 16px

.accessFlowOrigin
  display flex
  align-items center
  gap 12px
  margin-bottom 16px

.accessFlowOriginIcon
  width 44px
  height 44px
  border-radius 14px
  overflow hidden
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  flex-shrink 0
  display flex
  align-items center
  justify-content center

  img
    width 100%
    height 100%
    object-fit contain

.accessFlowOriginName
  font-size 15px
  font-weight 500
  color var(--outerspace)

.accessFlowOriginUrl
  font-size 11px
  font-family 'CodeFont'
  color var(--outerspace05)
  margin-top 2px

.accessFlowRequest
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 12px
  padding 12px 14px
  font-size 13px
  color var(--outerspace07)
  line-height 1.6
  margin-bottom 14px

.accessFlowNote
  font-size 11px
  color var(--outerspace04)
  text-align center
  line-height 1.5
