// VAULT — ENS Actions

.ensFlowWrap
  padding 14px
  display flex
  flex-direction column
  gap 10px

.ensFlowName
  font-size 18px
  font-weight 500
  color var(--good)
  text-align center
  font-family 'CodeFont'
  letter-spacing 0.02em

.ensFlowAction
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 12px
  padding 12px 14px
  display flex
  flex-direction column
  gap 4px

.ensFlowActionType
  font-size 10px
  font-weight 500
  letter-spacing 0.08em
  text-transform uppercase
  color var(--outerspace04)

.ensFlowActionDetail
  font-size 13px
  color var(--outerspace07)

.ensFlowDuration
  font-family 'CodeFont'
  font-size 12px
  color var(--good)
