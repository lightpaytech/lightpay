// VAULT — EIP-712 Typed Data Signing

.typedSignFlowWrap
  padding 14px

.typedSignFlowDomain
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 12px
  padding 10px 14px
  margin-bottom 8px

.typedSignFlowDomainLabel
  font-size 10px
  font-weight 500
  letter-spacing 0.08em
  text-transform uppercase
  color var(--outerspace04)
  margin-bottom 6px

.typedSignFlowDomainName
  font-size 14px
  font-weight 500
  color var(--outerspace)

.typedSignFlowDomainChain
  font-family 'CodeFont'
  font-size 11px
  color var(--outerspace05)
  margin-top 2px

.typedSignFlowMessage
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 12px
  padding 12px 14px
  max-height 180px
  overflow-y auto
  margin-bottom 8px

.typedSignFlowField
  display flex
  flex-direction column
  gap 2px
  padding 6px 0
  border-bottom 1px solid rgba(14, 165, 233, 0.18)

.typedSignFlowField:last-child
  border-bottom none

.typedSignFlowFieldKey
  font-size 10px
  font-weight 500
  letter-spacing 0.06em
  text-transform uppercase
  color var(--outerspace04)

.typedSignFlowFieldValue
  font-family 'CodeFont'
  font-size 12px
  color var(--outerspace08)
  word-break break-all
