  width 36px
  height 36px
  border-radius 50%
  border 3px solid rgba(14, 165, 233, 0.18)
  border-top-color var(--good)
  animation spinnerRing 0.8s linear infinite

.requestContainerEmpty
  display flex
  flex-direction column
  align-items center
  justify-content center
  padding 32px 20px
  gap 12px
  text-align center
  height 100%

.noRequests
  font-size 13px
  color var(--outerspace05)

.requestSign
  padding 10px 14px

.requestDecline
  padding 0 14px 10px

.requestGroupMain
  padding 8px 14px

.requestGroupButton
  display flex
  align-items center
  gap 8px
  padding 10px 14px
  cursor pointer
  border-bottom 1px solid rgba(14, 165, 233, 0.18)
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) background

.requestGroupButton:hover
  background rgba(0, 212, 255, 0.04)

.requestGroupButtonLabel
  font-size 13px
  color var(--outerspace07)
  flex 1

.requestItemTitleSubText
  font-size 11px
  color var(--outerspace04)
  margin-top 2px

// Signal value display (personal_sign)
.signValue
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 12px
  padding 12px 14px
  max-height 160px
  overflow-y auto
  margin 10px 14px

.signValueInner
  font-family 'CodeFont'
  font-size 12px
  color var(--outerspace08)
  line-height 1.7
  word-break break-word
  white-space pre-wrap

.signValueMore
  font-size 11px
  color var(--outerspace04)
  text-align center
  margin-top 8px
  padding-top 8px
  border-top 1px solid rgba(14, 165, 233, 0.18)

.unknownType
  padding 14px
  font-size 13px
  color var(--outerspace05)
  text-align center

.actionDeclineBtn
  height 48px
  border-radius 14px
  border 1px solid rgba(255, 75, 100, 0.4)
  background transparent
  color var(--bad)
  font-size 15px
  font-weight 400
  display flex
  align-items center
  justify-content center
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

.actionDeclineBtn:hover
  background rgba(255, 75, 100, 0.07)
  border-color rgba(255, 75, 100, 0.6)

.actionSignBtn
  flex 1
  height 48px
  border-radius 14px
  background rgb(14, 165, 233)
  color white
  font-size 15px
  font-weight 500
  display flex
  align-items center
  justify-content center
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

.actionSignBtn:hover
  background rgb(56, 189, 248)
  transform translateY(-1px)

.actionGroupLabel
  font-size 11px
  color var(--outerspace04)
  letter-spacing 0.06em
  text-transform uppercase
  font-weight 500
  padding 10px 14px 4px
