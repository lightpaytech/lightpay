// ─── TxFee — VAULT design ────────────────────────────────────────────────────

// Fee bar — clickable pill-style container
._flowGasBar
  font-size 17px
  font-weight 400
  display flex
  justify-content center
  align-items center
  border-radius 12px
  -webkit-app-region no-drag
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)
  pointer-events auto
  transform translate3d(0, 0, 0)
  font-family 'MainFont'
  padding 0px
  background var(--ghostA)
  border 1px solid rgba(14, 165, 233, 0.18)
  margin-top 5px
  cursor pointer
  flex-grow 1

  *
    pointer-events none

  svg
    position relative
    top 0
    padding 0px 3px 0px 4px

._flowGasBar:hover
  background var(--ghostB)
  border-color rgba(14, 165, 233, 0.4)

// Fee gwei display area
._flowGasGwei
  cursor pointer
  transform translateY(0px)
  display flex
  justify-content center
  align-items center
  padding 20px
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)

  *
    pointer-events none

  ._flowGasGweiValue
    font-family 'CodeFont'
    font-weight 400
    font-size 23px
    color var(--outerspace)
    display flex
    align-items center
    justify-content center
    position relative
    top -1px

  ._flowGasGweiLabel
    display flex
    align-items center
    justify-content center
    font-family 'MainFont'
    padding-left 4px
    position relative
    top 0px
    font-weight 500
    font-size 11px
    text-transform uppercase
    letter-spacing 0.08em
    color var(--outerspace05)

._flowGasGwei:hover
  background var(--ghostB)

._flowGasGwei:active
  transform translateY(0px)

// Section header label
._flowGasLabel
  font-size 11px
  text-transform uppercase
  letter-spacing 0.08em
  color var(--outerspace05)
  font-family 'MainFont'
  font-weight 500
  padding 12px 14px 6px 14px

// Fee tier pills — horizontal row
._flowGasTiers
  display flex
  flex-direction row
  gap 6px
  padding 0px 10px 10px 10px

._flowGasPill
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 8px
  padding 6px 12px
  font-size 12px
  font-family 'MainFont'
  font-weight 400
  color var(--outerspace07)
  cursor pointer
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)
  flex 1
  text-align center
  text-transform uppercase
  letter-spacing 0.04em

._flowGasPill:hover
  background rgba(14, 165, 233, 0.06)
  border-color rgba(14, 165, 233, 0.4)
  color var(--good)

// Selected tier pill — electric blue
._flowGasPillActive
  background rgba(14, 165, 233, 0.12)
  border-color rgba(14, 165, 233, 0.4)
  color var(--good)
  font-weight 500

// Fast / ASAP pills — stronger electric intensity
._flowGasPillFast._flowGasPillActive,
._flowGasPillAsap._flowGasPillActive
  background rgba(14, 165, 233, 0.18)
  border-color rgba(14, 165, 233, 0.6)

// USD fee tag value
._flowGasUsdTag
  font-size 13px
  font-weight 300
  color var(--outerspace06)

// Main fee value display
._flowGasValue
  position relative
  display flex
  align-items center
  justify-content center
  font-weight 400
  font-family 'CodeFont'
  font-size 18px
  margin-left 10px
  color var(--outerspace)

._flowGasDefault
  opacity 1
  display flex
  align-items center
  justify-content center
  font-size 14px
  font-weight 400

  span
    padding 4px

  .displayValueFiat, .displayValueMain
    padding 1px

  ._txFeeValueCurrency
    color var(--good)
    font-size 10px
    font-weight 600
    font-family 'MainFont'

._flowGasWarn
  color var(--bad)

._flowGasHover
  position absolute
  opacity 0
  top 0
  left 0
  bottom 0
  right 0
  display flex
  align-items center
  justify-content center

._flowGasDefault:hover
  opacity 0

// ETH fee amount
._flowGasEth
  padding-right 6px
  opacity 1
  font-family 'CodeFont'

._flowGasEthValue
  padding-right 0px
  font-size 18px
  font-family 'CodeFont'
  color var(--outerspace)

// USD equivalent row
._flowGasUsd
  font-weight 300
  position relative
  font-size 13px
  color var(--outerspace06)

._flowGasUsdSymbol
  font-size 11px
  color var(--outerspace05)

._flowGasUsdDesc
  position relative
  font-size 11px
  font-family 'MainFont'
  padding-left 2px
  color var(--outerspace05)

// L1 fee indicator (for L2 chains)
._flowGasL1
  font-size 11px
  color var(--outerspace05)
  font-family 'MainFont'
  padding 0px 14px 8px 14px
  text-align center
  letter-spacing 0.04em

._flowGasEq
  font-size 15px
  padding 0px 8px 0px 0px
  display none

// Custom fee input
._flowGasCustomInput
  font-family 'CodeFont'
  background rgba(14, 165, 233, 0.05)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 8px
  color var(--outerspace)
  text-align center
  font-size 18px
  padding 6px 12px
  outline 0
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)

._flowGasCustomInput:focus
  background rgba(14, 165, 233, 0.08)
  border-color rgba(14, 165, 233, 0.4)
  transform scale(1.02)

@keyframes wavey
  0%
    -webkit-transform rotate(0deg)
    transform rotate(0deg)
  100%
    -webkit-transform rotate(360deg)
    transform rotate(360deg)

