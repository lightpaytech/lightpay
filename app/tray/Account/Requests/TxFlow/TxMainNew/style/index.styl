// VAULT — Transaction Main Overview

.flowOverview
  padding 14px
  display flex
  flex-direction column
  gap 8px

.flowOverviewHeader
  display flex
  align-items center
  gap 10px
  padding-bottom 10px
  border-bottom 1px solid rgba(14, 165, 233, 0.18)

.flowOverviewOrigin
  flex 1

.flowOverviewOriginName
  font-size 12px
  color var(--outerspace06)
  letter-spacing 0.03em

.flowOverviewAction
  font-size 11px
  font-weight 500
  padding 3px 8px
  border-radius 6px
  background rgba(14, 165, 233, 0.1)
  color var(--good)
  border 1px solid rgba(14, 165, 233, 0.40)
  text-transform uppercase
  letter-spacing 0.04em

.flowOverviewSection
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 12px
  padding 10px 14px

.flowOverviewSectionLabel
  font-size 10px
  font-weight 500
  letter-spacing 0.08em
  text-transform uppercase
  color var(--outerspace04)
  margin-bottom 6px

.flowOverviewSectionValue
  font-family 'CodeFont'
  font-size 13px
  color var(--outerspace08)
