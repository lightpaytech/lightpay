// ─── ViewData — VAULT design ─────────────────────────────────────────────────

// Decoded contract card
.decodedDataContract
  padding 32px 11px 11px 11px
  position relative
  border-radius 10px
  background var(--ghostA)
  border 1px solid rgba(14, 165, 233, 0.18)

.dataUnverified
  position absolute
  color var(--bad)
  top 9px
  right 15px
  font-size 11px
  font-weight 500
  font-family 'MainFont'
  text-transform uppercase
  letter-spacing 0.06em

.dataSource
  position absolute
  top 9px
  left 15px
  font-size 11px
  font-weight 500
  font-family 'MainFont'
  text-transform uppercase
  letter-spacing 0.06em
  color var(--outerspace05)

.decodedDataContractTarget
  position relative
  height 70px
  padding 0px
  box-sizing border-box
  display flex
  flex-direction column
  align-items center
  justify-content center

  .decodedDataSync
    position absolute
    svg
      transform rotate(90deg)

  .decodedDataSyncLeft
    left 14px
    top 28px
    width 8px
    overflow hidden
    transform rotate(-10deg)
    svg
      transform rotate(90deg) scaleX(-1)

  .decodedDataSyncRight
    right 14px
    top 28px
    width 8px
    overflow hidden
    transform rotate(190deg)
    svg
      transform rotate(90deg)

  .decodedDataContractName
    text-align center
    font-size 17px
    font-family 'MainFont'
    font-weight 400
    color var(--outerspace)

  .decodedDataContractMethod
    text-align center
    font-family 'MainFont'
    font-weight 300
    font-size 15px
    color var(--good)

.decodedDataContractArgHeader
  font-size 11px
  text-transform uppercase
  letter-spacing 0.08em
  font-weight 500
  color var(--outerspace05)
  text-align center
  height 30px
  display flex
  align-items center
  justify-content center
  background var(--ghostB)
  border-radius 8px

.decodedDataContractArg
  position relative
  text-align center
  padding 10px 10px 25px 10px
  font-size 17px

.decodedDataSubtitle
  position absolute
  left 0
  bottom 0
  right 0
  height 30px
  font-size 12px
  font-weight 400
  font-family 'MainFont'
  display flex
  align-items center
  justify-content center
  color var(--outerspace05)

// Raw hex data scroll box
.overflowBox
  width 100%
  height auto
  overflow-x scroll
  overflow-y hidden
  word-wrap normal
  margin-bottom -15px

  div
    user-select all

// Raw data block — monospace code style
.rawDataHeader
  font-family 'MainFont'
  text-align center
  font-size 15px
  font-weight 500
  letter-spacing 0.04em
  color var(--outerspace)
  margin-top 20px
  margin-bottom 5px

.txDataOverlayRaw
  padding 0px 13px 40px 20px

.txDataOverlayRawTitle
  padding-bottom 20px
  text-align center
  font-size 13px
  font-weight 500
  font-family 'MainFont'
  text-transform uppercase
  letter-spacing 0.08em
  color var(--outerspace05)

// Raw hex value — CodeFont block
.txDataOverlayRawData
  font-size 11px
  font-family 'CodeFont'
  background var(--ghostX)
  border-radius 10px
  padding 12px
  color var(--outerspace07)
  word-break break-all
  white-space pre-wrap
  position relative
  cursor pointer
  max-width 100%

  *
    pointer-events none

.txDataOverlayRawData:hover
  background var(--ghostA)

// Copied confirmation overlay
.txModuleDataBodyCopied
  position absolute
  top -5px
  left -5px
  right -5px
  bottom -5px
  display flex
  justify-content center
  align-items center
  font-size 15px
  letter-spacing 0px
  border-radius 12px
  background rgba(14, 165, 233, 0.08)
  border 1px solid rgba(14, 165, 233, 0.4)
  color var(--good)

  svg
    margin -3px 0px 0px 10px
