// ─── TransactionRequest new.styl — VAULT design ──────────────────────────────

// ─── _flowBtnAction — base interactive button ─────────────────────────────────────

._flowBtnAction
  background var(--ghostB)
  border-radius 14px
  border 1px solid rgba(14, 165, 233, 0.18)
  transform translateY(0px)
  cursor pointer
  position relative
  overflow hidden
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)

  *
    pointer-events none

._flowBtnAction:hover
  color var(--goodOver)
  border-color rgba(14, 165, 233, 0.40)
  transform translateY(-1px)
  animation 5s shake ease-in-out infinite alternate

._flowBtnAction:hover::after
  content ''
  position absolute
  inset 0
  background var(--good)
  z-index 3
  opacity 0.08

._flowBtnBad:hover
  color var(--badOver)

._flowBtnBad:hover::after
  content ''
  position absolute
  inset 0
  color var(--badOver)
  background var(--bad)
  z-index 3
  opacity 0.08

._flowBtnAction:active
  transform translateY(0px)

// ─── shake keyframe ───────────────────────────────────────────────────────────

@keyframes shake
  0%
    transform translate3d(0px, 0px, 0) rotate(-0.4deg) scale(1)
  25%
    transform translate3d(-0.7px, -1px, 0) rotate(0.4deg) scale(1.01)
  50%
    transform translate3d(0.7px, 1px, 0) rotate(-0.4deg) scale(1.02)
  75%
    transform translate3d(-0.7px, 0.3px, 0) rotate(0.2deg) scale(1.01)
  100%
    transform translate3d(0.7px, 0.7px, 0) rotate(-0.4deg) scale(1)

@keyframes shake-little
  2%
    transform: translate(0px, 0px) rotate(0.5deg)
  4%
    transform: translate(0px, 1px) rotate(0.5deg)
