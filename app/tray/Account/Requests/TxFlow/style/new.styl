// ─── txViewData overlay ───────────────────────────────────────────────────────

.txViewData
  margin 64px 8px
  background var(--ghostA)
  padding 32px 6px 64px 6px
  border-radius 20px
  border 1px solid rgba(14, 165, 233, 0.18)
  border-bottom 2px solid rgba(14, 165, 233, 0.18)

  .txViewDataHeader
    padding 0px 0px
    margin-bottom 32px
    font-family 'AccentFont'
    text-transform uppercase
    font-size 18px
    text-align center
    font-weight 400
    letter-spacing 6px
    margin-left 4px
    opacity 1
    color var(--outerspace)

// ─── _flowModule — top module bar ───────────────────────────────────────────────

._flowModule
  position absolute
  top 130px
  left 10px
  right 10px
  height 30px
  z-index 100000

  ._flowModuleInner
    position absolute
    top 0
    right 0
    bottom 0
    left 0
    background var(--ghostC)
    border-radius 8px
    border 1px solid rgba(14, 165, 233, 0.18)
    display flex
    flex-direction row
    align-items stretch
    font-weight 300

    ._flowModuleSlice
      display flex
      justify-content center
      align-items center
      text-transform uppercase
      font-size 11px
      letter-spacing 0.06em
      padding 0px 6px
      font-family 'CodeFont'
      color var(--outerspace05)

// ─── _flowBody ──────────────────────────────────────────────────────────────────

._flowBody
  width 100%
  margin 0px 6px
  padding-top 22px

// ─── txDescriptionSummaryStandalone ──────────────────────────────────────────

.txDescriptionSummaryStandalone
  display flex
  justify-content center
  align-items center
  flex-direction column
  padding 18px 6px 20px 6px
  font-size 15px
  font-weight 500
  border-top 1px solid rgba(14, 165, 233, 0.18)
  margin 12px 12px 0px 12px
  font-family 'MainFont'
  text-transform uppercase
  letter-spacing 0.06em
  color var(--outerspace)

  div, span
    margin 0px 2px

// ─── _flowDescription ───────────────────────────────────────────────────────────

._flowDescription
  width 100%
  font-family 'MainFont'
  font-size 16px
  font-weight 400
  cursor pointer
  padding 12px

  *
    pointer-events none

  ._flowDesc
    display flex
    justify-content center
    align-items center
    flex-direction column

    ._flowDescMain
      padding 12px
      text-align center

    ._flowDescTag
      font-size 11px
      font-weight 500
      text-transform uppercase
      letter-spacing 0.08em
      text-align center
      white-space nowrap
      overflow hidden
      text-overflow ellipsis
      width 300px
      color var(--outerspace05)

    ._flowEnsHeadline
      font-size 26px
      font-weight 500
      color var(--outerspace)

    ._flowEnsMidline
      font-size 12px
      color var(--outerspace06)

  ._flowDescAlt
    font-size 10px
    width 100%
    border-top 1px solid rgba(14, 165, 233, 0.18)
    padding 10px 20px
    text-transform uppercase
    letter-spacing 0.06em
    color var(--outerspace04)

@import '../AdjustFee/style'
