// ─── TxAction — VAULT design ─────────────────────────────────────────────────

// Action title — readable, medium weight
._flowTitle
  font-size 15px
  font-weight 400
  font-family 'MainFont'
  color var(--outerspace)
  margin-bottom 6px

// Action type statusIndicator — colored pill per type
._flowBadge
  display inline-flex
  align-items center
  border-radius 8px
  padding 3px 10px
  font-size 11px
  font-weight 500
  font-family 'MainFont'
  text-transform uppercase
  letter-spacing 0.06em

// Transfer — electric blue
._flowBadgeTransfer
  background rgba(14, 165, 233, 0.1)
  color var(--good)
  border 1px solid rgba(14, 165, 233, 0.4)

// Approve — amber warning
._flowBadgeApprove
  background rgba(251, 191, 36, 0.08)
  color rgb(251, 191, 36)
  border 1px solid rgb(251, 191, 36)

// Swap — sky blue family
._flowBadgeSwap
  background rgba(56, 189, 248, 0.1)
  color rgba(56, 189, 248, 0.9)
  border 1px solid rgba(56, 189, 248, 0.25)

// Mint — sky blue family
._flowBadgeMint
  background rgba(56, 189, 248, 0.1)
  color rgba(56, 189, 248, 0.9)
  border 1px solid rgba(56, 189, 248, 0.25)

// Generic unknown action
._flowBadgeUnknown
  background var(--ghostC)
  color var(--outerspace05)
  border 1px solid rgba(14, 165, 233, 0.18)

// Action container row
._flowRow
  display flex
  align-items center
  gap 8px
  padding 10px 14px

// Action button — base style (reused in approval footer)
._flowBtn
  background var(--ghostA)
  box-sizing border-box
  height 60px
  margin 1px
  flex 1
  cursor pointer
  display flex
  justify-content center
  align-items center
  padding-top 3px
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)
  font-family 'MainFont'
  transform translateY(0px)
  text-transform uppercase
  letter-spacing 0.04em
  flex-grow 1
  border-radius 10px
  font-size 13px
  font-weight 400
  border 1px solid rgba(14, 165, 233, 0.18)

._flowBtn:hover
  background var(--ghostB)
  transform translateY(-1px)
  border-color rgba(14, 165, 233, 0.4)

._flowBtn:active
  background var(--ghostA)
  transform translateY(1px)

._flowBtnPrimary
  color var(--good)

._flowBtnDanger
  color var(--bad)
