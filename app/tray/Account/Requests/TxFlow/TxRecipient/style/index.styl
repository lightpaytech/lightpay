// ─── TxRecipient — VAULT design ──────────────────────────────────────────────

// Contract statusIndicator — electric blue tint
._flowToContract
  margin-left 10px
  display inline-flex
  align-items center
  background rgba(56, 189, 248, 0.1)
  border 1px solid rgba(56, 189, 248, 0.3)
  border-radius 6px
  padding 2px 7px
  font-size 10px
  font-weight 500
  font-family 'MainFont'
  text-transform uppercase
  letter-spacing 0.06em
  color rgba(56, 189, 248, 0.9)
  position relative
  top 0px

// Recipient main row — monospace address
._flowTo
  font-size 12px
  font-weight 400
  font-family 'CodeFont'
  letter-spacing 0.06em
  color var(--outerspace08)

// ENS name display — larger, readable
._flowToEns
  font-size 15px
  font-weight 400
  font-family 'MainFont'
  color var(--outerspace)
  margin-bottom 2px

// Recipient avatar
._flowToAvatar
  width 32px
  height 32px
  border-radius 50%
  border 2px solid rgba(14, 165, 233, 0.4)
  overflow hidden
  flex-shrink 0

// Full address overlay — shown on hover
._flowToFull
  position absolute
  top 0
  left 0
  bottom 0
  right 0
  display flex
  justify-content center
  align-items center
  z-index 40000
  border-radius 8px
  background rgba(14, 165, 233, 0.06)
  border 1px solid rgba(14, 165, 233, 0.4)
  opacity 0
  transition all 0.18s cubic-bezier(0.4, 0, 0.2, 1)

  ._flowToCode
    position relative
    top 1.5px
    left 1px
    font-size 12px
    font-family 'CodeFont'
    letter-spacing 0.06em
    color var(--outerspace08)

._flowToFull:hover
  opacity 1
  transform translateX(0px) scale(1)
  cursor pointer
