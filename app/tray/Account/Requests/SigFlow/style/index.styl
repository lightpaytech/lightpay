// VAULT — Signature Request

.sigFlowWrap
  padding 14px

.sigFlowMessage
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 14px
  padding 14px
  font-family 'CodeFont'
  font-size 12px
  font-weight 300
  color var(--outerspace08)
  line-height 1.6
  letter-spacing 0.03em
  word-break break-all
  margin-bottom 10px
  max-height 160px
  overflow-y auto

.sigFlowMessageDecoded
  font-family 'MainFont'
  font-size 13px
  letter-spacing 0
  color var(--outerspace)

.sigFlowOrigin
  font-size 11px
  color var(--outerspace05)
  letter-spacing 0.04em
  text-transform uppercase
  font-weight 500
  margin-bottom 8px

.sigFlowWarning
  background rgba(251, 191, 36, 0.08)
  border 1px solid rgb(251, 191, 36)
  border-radius 10px
  padding 10px 14px
  font-size 11px
  color var(--warning)
  line-height 1.55
  margin-bottom 10px
