// LightPay VAULT — Portfolio Chart (unique feature)

.portfolioChart
  margin 0 0 10px 0
  background var(--ghostB)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 16px
  overflow hidden
  padding 14px 14px 0

.portfolioChartHeader
  display flex
  align-items center
  justify-content space-between
  margin-bottom 4px

.portfolioChartLabel
  font-size 11px
  font-weight 500
  letter-spacing 0.1em
  text-transform uppercase
  color var(--outerspace05)

.portfolioChartChange
  font-size 11px
  font-weight 500
  font-family 'CodeFont'
  letter-spacing 0.02em

.portfolioChartValue
  font-size 22px
  font-weight 600
  font-family 'CodeFont'
  color var(--outerspace)
  letter-spacing -0.02em
  margin-bottom 10px

.portfolioChartSvgWrap
  margin 0 -14px
  height 72px
  position relative
  overflow hidden
