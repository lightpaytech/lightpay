// VAULT — Balances Preview (collapsed)

.assetsPreview
  padding 10px 14px
  display flex
  flex-direction column
  gap 6px

.assetsPreviewTotal
  font-size 22px
  font-weight 600
  font-family 'CodeFont'
  color var(--outerspace)
  letter-spacing -0.02em

.assetsPreviewChange
  font-family 'CodeFont'
  font-size 11px

.assetsPreviewChangeUp
  color var(--good)

.assetsPreviewChangeDown
  color var(--bad)

.assetsPreviewTokens
  display flex
  gap 4px
  flex-wrap wrap
  margin-top 4px

.assetsPreviewToken
  display flex
  align-items center
  gap 4px
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 20px
  padding 3px 8px 3px 4px

.assetsPreviewTokenIcon
  width 16px
  height 16px
  border-radius 50%
  overflow hidden
  background var(--ghostD)

  img
    width 100%
    height 100%
    object-fit cover

.assetsPreviewTokenSymbol
  font-family 'CodeFont'
  font-size 10px
  color var(--outerspace06)
  letter-spacing 0.04em
