// VAULT — Balances Expanded View

.assetsExpanded
  padding 0

.assetsExpandedTotal
  padding 16px 14px 12px
  border-bottom 1px solid rgba(14, 165, 233, 0.18)

.assetsExpandedTotalLabel
  font-size 10px
  font-weight 500
  letter-spacing 0.1em
  text-transform uppercase
  color var(--outerspace04)
  margin-bottom 4px

.assetsExpandedTotalValue
  font-size 28px
  font-weight 600
  font-family 'CodeFont'
  color var(--outerspace)
  letter-spacing -0.02em

.assetsExpandedTotalChange
  font-family 'CodeFont'
  font-size 12px
  margin-top 2px

.assetsExpandedTotalChangeUp
  color var(--good)

.assetsExpandedTotalChangeDown
  color var(--bad)

.assetsExpandedList
  display flex
  flex-direction column

.assetsExpandedEmpty
  padding 24px 14px
  text-align center
  font-size 13px
  color var(--outerspace05)
