// VAULT design — Balances module

.assetsBlock
  box-sizing border-box
  overflow auto

// ── Module header ────────────────────────────────────────────────────────────
.assetsHeader
  font-size 11px
  letter-spacing 0.1em
  text-transform uppercase
  color var(--outerspace05)
  padding 14px 14px 8px
  font-weight 400

// ── Module section wrapper ───────────────────────────────────────────────────
.assetBalancesWrap
  margin 0px 6px 6px 6px
  padding 2px 3px 1px 3px
  box-sizing border-box
  overflow auto
  background var(--ghostC)
  border-radius 12px
  border 1px solid rgba(14, 165, 233, 0.18)
  overflow hidden
  min-height 76px
  position relative
  z-index 999
  margin-bottom 8px

  .assetBalance:first-child
    border-top-right-radius 11px
    border-top-left-radius 11px

  .assetBalance:last-child
    border-bottom-right-radius 11px
    border-bottom-left-radius 11px
    border-bottom none

  .assetBalance:first-child:last-child
    border-radius 11px

.signerBalancesExpanded
  width 100%

// ── Warning ──────────────────────────────────────────────────────────────────
.signerBalanceWarning
  position relative
  border-top 1px solid rgba(14, 165, 233, 0.18)
  font-weight 400
  padding 10px 0px
  cursor pointer

.signerBalanceWarningTitle
  position relative
  height 24px
  width 100%
  z-index 200000
  font-size 11px
  letter-spacing 0.1em
  display flex
  justify-content center
  align-items center
  color var(--outerspace05)
  text-transform uppercase
  pointer-events none

.signerBalanceWarningTitle:hover
  color var(--outerspace07)

.signerBalanceWarningMessage
  position relative
  width 100%
  text-align center
  padding 20px
  box-sizing border-box
  font-size 13px
  font-weight 300
  color var(--outerspace07)

// ── Total balance display ────────────────────────────────────────────────────
.signerBalanceTotal
  position relative
  height 52px
  width 100%
  z-index 200000
  font-size 26px
  font-weight 500
  color var(--outerspace)
  text-align center
  margin-bottom 6px

  .signerBalanceButtons
    display flex
    justify-content left
    align-items center
    height 100%

    .moduleItemButton
      background var(--ghostA)
      border 1px solid rgba(14, 165, 233, 0.18)
      border-radius 10px
      cursor pointer
      transition all 0.15s ease-out
      *
        pointer-events none

    .moduleItemButton:hover
      background rgba(14, 165, 233, 0.1)
      transform translateY(-1px)

    .moduleItemButton:active
      background rgba(14, 165, 233, 0.06)
      transform translateY(0px)

  .signerBalanceButton
    height 40px
    margin-left 13px
    background var(--ghostA)
    border 1px solid rgba(14, 165, 233, 0.18)
    border-radius 20px
    box-sizing border-box
    cursor pointer
    z-index 4000
    display flex
    justify-content center
    align-items center
    font-size 11px
    font-weight 400
    letter-spacing 0.1em
    text-transform uppercase
    padding 1px 20px 0px 21px
    transition all 0.15s ease-out
    *
      pointer-events none
      margin-left 2px

  .signerBalanceButton:hover
    background rgba(14, 165, 233, 0.1)
    color var(--good)
    border-color rgba(14, 165, 233, 0.4)

  .signerBalanceTotalText
    position absolute
    left 16px
    right 23px
    bottom 0px
    top 0px
    display flex
    justify-content flex-end
    align-items center

    .signerBalanceTotalLabel
      margin-right 6px
      margin-top 1px
      text-transform uppercase
      font-size 10px
      letter-spacing 0.1em
      font-weight 400
      color var(--outerspace05)

    .assetTotalValue
      font-size 26px
      font-weight 500
      font-family 'CodeFont'
      letter-spacing -1px
      text-align center
      display flex
      align-items center
      color var(--outerspace)

// ── Loading states ───────────────────────────────────────────────────────────
.signerBalancesLoading
  position absolute
  top 46px
  left 9px
  right 9px
  bottom 78px
  z-index 200
  border-radius 10px
  display flex
  justify-content center
  align-items center
  background var(--ghostA)

  .loader, .loader:after
    border-radius 100%
    width 22px
    height 22px

  .loader
    font-size 7px
    position relative
    text-indent -9999em
    border-top 3px solid rgba(14, 165, 233, 0.18)
    border-right 3px solid rgba(14, 165, 233, 0.18)
    border-bottom 3px solid rgba(14, 165, 233, 0.18)
    border-left 3px solid var(--good)
    transform translateZ(0)
    animation load8 0.6s infinite linear !important
    will-change transform

// ── Balance row ──────────────────────────────────────────────────────────────
.assetBalance
  position relative
  opacity 1
  height 70px
  width 100%
  transition 0.1s ease-out all
  font-family 'MainFont'
  overflow hidden
  padding 12px 14px
  border-bottom 1px solid rgba(14, 165, 233, 0.18)
  display flex
  align-items center
  box-sizing border-box

  &:hover
    background rgba(14, 165, 233, 0.06)
    cursor pointer

  @keyframes sheenLoad
    0%
      transform rotateZ(360deg) translateX(-100%)
    100%
      transform rotateZ(360deg) translateX(100%)

  .signerBalanceLoading
    position absolute
    top 0
    bottom 0
    left 0
    transform rotateZ(360deg) translateX(-100%)
    will-change transform
    width 400%
    background linear-gradient(90deg, var(--ghostB0) 25%, var(--ghostB) 48%, var(--ghostB) 52%, var(--ghostB0) 75%)
    animation sheenLoad 5s infinite linear
    transition var(--standardFast)

  .signerBalanceInner
    position relative
    height 100%
    transition all linear 0.8s

  // Token icon — left
  .assetTokenIcon
    position absolute
    left 12px
    top 50%
    transform translateY(-50%)
    width 28px
    height 28px
    border-radius 50%
    border 1px solid rgba(14, 165, 233, 0.18)
    overflow hidden
    z-index 1
    flex-shrink 0

    img:before
      content attr(alt)
      top 0
      bottom 0
      left 0
      right 0
      border-radius 50%
      position absolute
      background var(--outerspace)
      color var(--ghostA)
      display flex
      justify-content center
      align-items center
      font-size 11px
      font-weight 300
      letter-spacing -0.5px
      margin-left -0.5px

    img
      height 28px
      width 28px
      border-radius 50%
      position absolute
      overflow hidden
      object-fit cover

  .signerBalanceChainIcon
    position absolute
    left 28px
    top calc(50% - 4px)
    height 14px
    width 14px
    background var(--outerspace)
    border-radius 50%
    overflow hidden
    z-index 2
    color black

  // Token name — center
  .assetTokenName
    position absolute
    left 54px
    top 50%
    transform translateY(-60%)
    right 140px
    font-size 13px
    display flex
    align-items center
    font-weight 300
    color var(--outerspace07)
    white-space nowrap
    z-index 2
    overflow hidden

  .signerBalanceChain
    position absolute
    left 54px
    top calc(50% + 6px)
    font-size 10px
    display flex
    align-items center
    font-weight 400
    white-space nowrap
    z-index 2
    text-transform uppercase
    letter-spacing 0.1em
    height 12px
    padding 0px 0px 0px 2px
    border-radius 8px
    color var(--outerspace05)

  // Value — right (CodeFont)
  .assetTokenValue
    position absolute
    right 10px
    top 50%
    transform translateY(-60%)
    font-size 13px
    text-align right
    display flex
    align-items center
    font-family 'CodeFont'
    font-weight 200
    color var(--outerspace09)

    .displayValueSymbol
      font-family 'MainFont'
      font-weight 600
      font-size 0.65em
      line-height 13px
      position relative
      letter-spacing 0.5px
      margin-top -0.12em
      margin-right 0.36em

  .signerBalanceEquivalent
    position absolute
    right 10px
    bottom 10px
    font-size 12px
    color var(--outerspace05)
    display flex
    align-items center
    font-family 'CodeFont'

  // Price row
  .signerBalancePrice
    position absolute
    right 12px
    bottom 8px
    left 54px
    font-size 12px
    font-weight 200
    color var(--outerspace07)
    display flex
    align-items center
    justify-content space-between
    font-family 'CodeFont'

  .signerBalanceOk
    display flex
    align-items center
    justify-content center

  .signerBalanceCurrentValue
    display flex
    align-items center

  .signerBalanceCurrentPrice
    display flex
    align-items center
    margin-left -2px

  .signerBalanceCurrentPriceChange
    display flex
    align-items center
    margin-left 4px

  .signerBalanceCurrentPriceChangeUp
    color var(--good)

  .signerBalanceCurrentPriceChangeDown
    color var(--bad)

// ── Slider / shadow helpers ───────────────────────────────────────────────────
.signerBalanceSliderDisplay
  position absolute
  top 0
  left 0
  right 0
one

.signerBalanceSliderShadow
  position relative
  opacity 0

// ── Empty / loading placeholders ─────────────────────────────────────────────
.signerBalanceNoTokens
  height 48px
  display flex
  justify-content center
  align-items center
  color var(--outerspace05)
  text-transform uppercase
  font-size 11px
  letter-spacing 0.1em
  border-bottom 1px solid rgba(14, 165, 233, 0.18)

// ── "Add token" button ───────────────────────────────────────────────────────
.signerBalanceAddToken
  display flex
  justify-content center
  align-items center
  padding 12px 14px
  border 1px dashed rgba(14, 165, 233, 0.25)
  border-radius 10px
  font-size 13px
  font-weight 300
  color var(--outerspace05)
  cursor pointer
  transition all 0.15s ease-out
  margin 8px 6px

.signerBalanceAddToken:hover
  border-color rgba(14, 165, 233, 0.5)
  background rgba(14, 165, 233, 0.06)
  color var(--good)

// ── Module loading spinner ───────────────────────────────────────────────────
.moduleLoading
  height 40px
  display flex
  justify-content center
  align-items center
  padding 20px
  border-bottom 1px solid rgba(14, 165, 233, 0.18)
  margin 0px 16px

.moduleLoadingLoader
  border-radius 50%
  width 30px
  height 30px
  margin 30px auto
  font-size 10px
  position relative
  text-indent -9999em
  border-top 3px solid rgba(14, 165, 233, 0.18)
  border-right 3px solid rgba(14, 165, 233, 0.18)
  border-bottom 3px solid rgba(14, 165, 233, 0.18)
  border-left 3px solid var(--good)
  transform translateZ(0)
  animation load 0.5s infinite linear
  will-change transform

@keyframes load
  0%
    -webkit-transform rotate(0deg)
    transform rotate(0deg)

  100%
    -webkit-transform rotate(360deg)
    transform rotate(360deg)

// ─── Asset module sub-classes ────────────────────────────────────────────────

.assetTotalValue
  font-size 26px
  font-weight 600
  font-family 'CodeFont'
  color var(--outerspace)
  letter-spacing -0.02em

.assetTokenName
  font-size 13px
  font-weight 400
  color var(--outerspace)

.assetTokenValue
  font-family 'CodeFont'
  font-size 12px
  font-weight 300
  color var(--outerspace08)

.sectionTitle
  padding 10px 14px 8px
  font-size 11px
  font-weight 500
  letter-spacing 0.1em
  text-transform uppercase
  color var(--outerspace05)
  display flex
  align-items center
  gap 6px

.sectionContent
  padding 0

.moduleComingSoon
  padding 20px 14px
  font-size 13px
  color var(--outerspace04)
  text-align center

.removeButton
  width 24px
  height 24px
  border-radius 6px
  display flex
  align-items center
  justify-content center
  color var(--outerspace04)
  cursor pointer
0.15s all

.removeButton:hover
  background rgba(244, 63, 94, 0.08)
  color var(--bad)
