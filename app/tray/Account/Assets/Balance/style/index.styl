// VAULT — Single Balance Row

.assetRow
  padding 11px 14px
  display flex
  align-items center
  gap 10px
  border-bottom 1px solid rgba(14, 165, 233, 0.18)
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) background
  cursor pointer

.assetRow:last-child
  border-bottom none

.assetRow:hover
  background rgba(14, 165, 233, 0.06)

.assetRowIcon
  width 30px
  height 30px
  border-radius 50%
  overflow hidden
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  flex-shrink 0
  display flex
  align-items center
  justify-content center

  img
    width 100%
    height 100%
    object-fit cover

.assetRowInfo
  flex 1
  min-width 0

.assetRowName
  font-size 13px
  font-weight 400
  color var(--outerspace)
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.assetRowSymbol
  font-family 'CodeFont'
  font-size 10px
  color var(--outerspace04)
  letter-spacing 0.06em

.assetRowValue
  text-align right

.assetRowAmount
  font-family 'CodeFont'
  font-size 12px
  font-weight 300
  color var(--outerspace08)

.assetRowUsd
  font-size 11px
  color var(--outerspace05)
