// VAULT — Empty/Default Account State

.walletEmptyState
  display flex
  flex-direction column
  align-items center
  justify-content center
  padding 32px 20px
  gap 16px
  text-align center
  height 100%

.walletEmptyStateIcon
  width 64px
  height 64px
  border-radius 20px
  background linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.04))
  border 1px solid rgba(14, 165, 233, 0.40)
  display flex
  align-items center
  justify-content center
  color rgba(14, 165, 233, 0.7)

.walletEmptyStateTitle
  font-size 18px
  font-weight 500
  color var(--outerspace)

.walletEmptyStateSubtitle
  font-size 13px
  color var(--outerspace06)
  line-height 1.6
  max-width 260px
