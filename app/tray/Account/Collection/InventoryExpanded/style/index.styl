// VAULT — NFT Expanded View

.collectExpanded
  padding 0

.collectExpandedGrid
  display grid
  grid-template-columns repeat(3, 1fr)
  gap 8px
  padding 14px

.collectExpandedItem
  border-radius 12px
  overflow hidden
  background rgb(6, 9, 22)
  border 1px solid rgba(14, 165, 233, 0.18)
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

.collectExpandedItem:hover
  border-color rgba(14, 165, 233, 0.4)

.collectExpandedItemImg
  aspect-ratio 1
  overflow hidden

  img
    width 100%
    height 100%
    object-fit cover

.collectExpandedItemName
  padding 6px 8px
  font-size 10px
  color var(--outerspace06)
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
