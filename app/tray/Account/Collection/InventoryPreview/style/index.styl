// VAULT — NFT Inventory Preview

.collectPreview
  padding 10px 14px
  display flex
  gap 6px
  flex-wrap wrap

.collectPreviewNft
  width 44px
  height 44px
  border-radius 10px
  overflow hidden
  background rgb(6, 9, 22)
  border 1px solid rgba(14, 165, 233, 0.18)
  cursor pointer
  transition 0.15s all
  flex-shrink 0

  img
    width 100%
    height 100%
    object-fit cover

.collectPreviewNft:hover
  border-color rgba(14, 165, 233, 0.4)

.collectPreviewCount
  width 44px
  height 44px
  border-radius 10px
  background rgba(14, 165, 233, 0.07)
  border 1px solid rgba(14, 165, 233, 0.18)
  display flex
  align-items center
  justify-content center
  font-size 12px
  font-weight 500
  color rgb(14, 165, 233)
  cursor pointer

.collectPreviewEmpty
  padding 16px 14px
  font-size 12px
  color var(--outerspace04)
  text-align center
