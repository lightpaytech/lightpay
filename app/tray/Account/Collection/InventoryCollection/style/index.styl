// VAULT — NFT Collection Row

.collectGroupItem
  padding 0 14px 14px

.collectGroupHeader
  padding 10px 14px 8px
  display flex
  align-items center
  gap 8px
  cursor pointer

.collectGroupName
  flex 1
  font-size 13px
  font-weight 400
  color var(--outerspace07)

.collectGroupCount
  font-family 'CodeFont'
  font-size 11px
  color var(--outerspace05)
  background rgba(255, 255, 255, 0.07)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 20px
  padding 2px 8px

.collectGroupGrid
  display grid
  grid-template-columns repeat(3, 1fr)
  gap 6px

.collectGroupNft
  aspect-ratio 1
  border-radius 10px
  overflow hidden
  background rgb(240, 245, 255)
  border 1px solid rgba(14, 165, 233, 0.18)
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

  img
    width 100%
    height 100%
    object-fit cover

.collectGroupNft:hover
  border-color rgba(14, 165, 233, 0.40)
  transform scale(1.02)
