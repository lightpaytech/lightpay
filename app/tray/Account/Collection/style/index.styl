// VAULT design — Inventory (NFT) module

// ── Scroll container ──────────────────────────────────────────────────────────
.walletViewScroll
  position absolute
  top 0
  bottom 0
  left 0
  right 0
  padding-top 30px
  padding-bottom 60px
  overflow-y scroll
  overflow-x hidden
  border-radius 26px

// ── Module header ─────────────────────────────────────────────────────────────
.inventoryModuleHeader
  font-size 11px
  letter-spacing 0.1em
  text-transform uppercase
  color var(--outerspace05)
  padding 14px 14px 8px
  font-weight 400

// ── Module wrapper ────────────────────────────────────────────────────────────
.dark
  .collectWrapper
    background rgb(240, 245, 255)

.light
  .collectWrapper
    background rgb(240, 245, 255)

.collectWrapper
  border 1px solid rgba(14, 165, 233, 0.18)
  margin 0px 6px 8px 6px
  padding 0px 3px 1px 3px
  border-radius 12px
  overflow hidden

  .collectGroup:first-child
    border-top-left-radius 11px
    border-top-right-radius 11px

  .collectGroup:last-child
    border-bottom-left-radius 11px
    border-bottom-right-radius 11px

  .collectGroup:first-child:last-child
    border-radius 11px

// ── Collection row ────────────────────────────────────────────────────────────
.collectGroup
  position relative
  border-radius 8px
  z-index 300
  width 100%
  transition background 0.12s ease-out

  .collectTop
    position relative
    display flex
    justify-content space-between
    align-items center
    padding 12px 14px
    font-size 13px
    cursor pointer
    font-weight 300
    color var(--outerspace07)

    *
      pointer-events none

  .inventoryCollectionLine
    position absolute
    top 0
    left 14px
    right 14px
    bottom -1px
    border-bottom 1px solid rgba(14, 165, 233, 0.08)
    pointer-events none

  .inventoryCollectionName
    display flex
    justify-content center
    align-items center
    font-size 13px
    font-weight 300
    color var(--outerspace07)

  .collectCount
    width 40px
    height 22px
    background var(--ghostA)
    border 1px solid rgba(14, 165, 233, 0.18)
    display flex
    justify-content center
    align-items center
    border-radius 10px
    font-family 'CodeFont'
    font-weight 200
    font-size 13px
    color var(--outerspace09)
    margin-bottom -2px

.collectGroup:hover
  background rgba(255, 255, 255, 0.06)

.collectGroup:last-child
  .inventoryCollectionLine
    border-bottom none

// ── Empty state ───────────────────────────────────────────────────────────────
.inventoryNotFound
  font-size 11px
  text-transform uppercase
  font-weight 400
  letter-spacing 0.1em
  padding-left 1px
  display flex
  justify-content center
  align-items center
  transition var(--standard)
  color var(--outerspace05)
  margin-top 3px
  height 48px
  border-radius 12px
  box-sizing border-box

// ── NFT expanded preview ──────────────────────────────────────────────────────
.dark
  .inventoryPreviewTitle
    background rgb(240, 245, 255)

.light
  .inventoryPreviewTitle
    background rgb(240, 245, 255)

.inventoryPreviewTitle
  border 1px solid rgba(14, 165, 233, 0.18)
  position absolute
  top 267px
  left 3px
  right 3px
  height 30px
  z-index 4
  display flex
  justify-content center
  align-items center
  font-weight 400
  font-size 11px
  letter-spacing 0.1em
  border-radius 8px
  text-transform uppercase
  padding-bottom 2px

.inventoryPreview
  position absolute
  top 33px
  left 3px
  right 3px
  height 130px
  padding 50px
  z-index 3
  display flex
  justify-content center
  align-items center
  flex-direction column
  border-radius 12px
  border-top-left-radius 12px
  border-top-right-radius 12px

  .inventoryPreviewCollection
    background-repeat no-repeat
    background-size cover
    background-position center
    position absolute
    left 50%
    height 100px
    width 100px
    margin-left -56px
    z-index 2
    border-radius 50%
    border 4px solid rgb(240, 245, 255)

  .inventoryPreviewMedia
    position absolute
    top 12px
    left 12px
    right 12px
    bottom 12px
    z-index 4
    opacity 1
    overflow hidden
    border-radius 10px

    img
      width 100%
      height 100%
      object-fit contain

    img:before
      content attr(alt)
      top 0
      bottom 0
      left 0
      right 0
      width 100%
      height 100%
      overflow hidden
      color rgb(15, 23, 42)
      display flex
      justify-content center
      align-items center
      font-size 11px
      font-weight 300
      letter-spacing -0.5px
      margin-left -0.5px

.dark
  .inventoryPreview
    .inventoryPreviewMedia
      img:before
        background rgb(248, 250, 255)

.light
  .inventoryPreview
    .inventoryPreviewMedia
      img:before
        background rgb(248, 250, 255)

// ── Expanded collection items container ───────────────────────────────────────
.moduleExpanded
  .inventoryCollectionItems
    position relative

.inventoryDisplay
  position absolute
  top 0
  right 0
  bottom 0
  left 0

  .inventoryCollectionImage
    height 42px
    width 42px
    border-radius 12px
    border 1px solid rgba(14, 165, 233, 0.18)
    background var(--ghostA)
    overflow hidden

    img
      height 42px
      width 42px
      object-fit cover

  .inventoryCollectionItems
    position absolute
    top 290px
    bottom 0
    left 0
    right 0
    padding 14px 4px 4px 4px
    display flex
    flex-wrap wrap
    gap 10px
    align-content flex-start
    overflow-y scroll
    border-bottom-left-radius 12px
    border-bottom-right-radius 12px

    // ── NFT thumbnail ────────────────────────────────────────────────────────
    .collectItem
      width 94px
      height 94px
      border-radius 12px
      border 1px solid rgba(14, 165, 233, 0.18)
      padding 4px
      box-sizing border-box
      cursor pointer
      overflow hidden
      transition all 0.12s ease-out
      *
        pointer-events none

    .inventoryItemImage
      object-fit cover
      left 0px
      top 0px
      z-index 1
      width 94px
      height 94px

      img
        width 90px
        height 90px
        border-radius 10px
        transition 0.12s ease-out
        overflow hidden

      img:before
        content attr(alt)
        top 0
        bottom 0
        left 0
        right 0
        border-radius 10px
        width 80px
        height 82px
        overflow hidden
        color rgb(15, 23, 42)
        display flex
        justify-content center
        align-items center
        font-size 11px
        font-weight 300
        letter-spacing -0.5px
        padding 4px
        text-align center

    .collectItem:hover
      border-color rgba(14, 165, 233, 0.40)
      background rgba(255, 255, 255, 0.06)
      img
        transform scale(1.06)

.dark
  .inventoryDisplay
    .inventoryCollectionItems
      .collectItem
        background rgb(240, 245, 255)
      .inventoryItemImage
        img:before
          background rgb(248, 250, 255)

.light
  .inventoryDisplay
    .inventoryCollectionItems
      .collectItem
        background rgb(240, 245, 255)
      .inventoryItemImage
        img:before
          background rgb(248, 250, 255)

// ─── Collection sub-classes (inventory items) ────────────────────────────────

.collectCount
  font-family 'CodeFont'
  font-size 11px
  color var(--outerspace05)
  background rgba(255, 255, 255, 0.07)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 20px
  padding 2px 8px

.dark
  .collectItem
    background rgb(240, 245, 255)

.light
  .collectItem
    background rgb(240, 245, 255)

.collectItem
  border-radius 10px
  overflow hidden
  border 1px solid rgba(14, 165, 233, 0.18)
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

.collectItem:hover
  border-color rgba(14, 165, 233, 0.40)
  transform scale(1.02)

.collectTop
  padding 10px 14px 8px
  display flex
  align-items center
  justify-content space-between

.inventoryCollectionLine
  height 1px
  background rgba(255, 255, 255, 0.08)
  margin 4px 0

.inventoryCollectionName
  font-size 13px
  font-weight 400
  color var(--outerspace07)

.inventoryCollectionItems
  display grid
  grid-template-columns repeat(3, 1fr)
  gap 6px
  padding 0 14px 14px

.inventoryItemImage
  width 100%
  aspect-ratio 1
  object-fit cover

.inventoryPreviewCollection
  padding 8px 14px
  font-size 11px
  color var(--outerspace05)

.dark
  .inventoryPreviewMedia
    background rgb(224, 235, 252)

.light
  .inventoryPreviewMedia
    background rgb(224, 235, 252)

.inventoryPreviewMedia
  border-radius 8px
  overflow hidden
  border 1px solid rgba(14, 165, 233, 0.18)
