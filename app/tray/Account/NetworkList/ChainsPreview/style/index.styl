// VAULT — Chains/Networks Preview

.networkListPreview
  padding 10px 14px
  display flex
  gap 6px
  flex-wrap wrap

.networkListPreviewChip
  display flex
  align-items center
  gap 5px
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 20px
  padding 4px 10px 4px 6px
  cursor pointer
  transition 0.15s all

.networkListPreviewChip:hover
  border-color rgba(14, 165, 233, 0.4)
  background rgba(14, 165, 233, 0.06)

.networkListPreviewDot
  width 8px
  height 8px
  border-radius 50%
  flex-shrink 0

.networkListPreviewName
  font-size 11px
  font-weight 400
  color var(--outerspace07)
