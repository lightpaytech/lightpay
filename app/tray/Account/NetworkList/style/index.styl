// VAULT design — Chains module

// ── Module header ────────────────────────────────────────────────────────────
.networksHeader
  font-size 11px
  letter-spacing 0.1em
  text-transform uppercase
  color var(--outerspace05)
  padding 14px 14px 8px
  font-weight 400

// ── Module section ───────────────────────────────────────────────────────────
.networksSection
  border-radius 12px
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  overflow hidden
  margin-bottom 8px

// ── Chain list wrapper ───────────────────────────────────────────────────────
.networkList
  border-radius 12px
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.18)
  overflow hidden
  margin 0px 6px 8px 6px

// ── Chain row ────────────────────────────────────────────────────────────────
.networkRow
  padding 12px 14px
  border-bottom 1px solid rgba(14, 165, 233, 0.18)
  display flex
  align-items center
  position relative
  transition background 0.12s ease-out
  cursor pointer
  box-sizing border-box

.networkRow:last-child
  border-bottom none

.networkRow:hover
  background rgba(255, 255, 255, 0.06)
  cursor pointer

// ── Active chain ─────────────────────────────────────────────────────────────
.networkRowActive
  border-left 3px solid var(--good)
  background rgba(255, 255, 255, 0.06)

// ── Network color left bar (4px wide) ────────────────────────────────────────
.networkColorBar
  width 4px
  border-radius 0 8px 8px 0
  position absolute
  left 0
  top 8px
  bottom 8px
  background var(--accent0)

// ── RPC status dot ───────────────────────────────────────────────────────────
.networkRpcDot
  width 7px
  height 7px
  border-radius 50%
  flex-shrink 0
  margin-right 10px

.networkRpcGood
  background var(--good)

.networkRpcBad
  background var(--bad)

.networkRpcNeutral
  background var(--outerspace05)

// ── Connection dot (generic) ─────────────────────────────────────────────────
.connectionDotGood
  background var(--good)
  width 7px
  height 7px
  border-radius 50%
  flex-shrink 0

.connectionDotBad
  background var(--bad)
  width 7px
  height 7px
  border-radius 50%
  flex-shrink 0

// ── Chain icon / logo ────────────────────────────────────────────────────────
.networkIcon
  width 28px
  height 28px
  border-radius 50%
  border 1px solid rgba(14, 165, 233, 0.18)
  overflow hidden
  margin-right 12px
  flex-shrink 0
  background var(--ghostA)

  img
    width 100%
    height 100%
    object-fit cover

// ── Chain name ───────────────────────────────────────────────────────────────
.networkName
  font-size 14px
  font-weight 400
  color var(--outerspace07)
  flex 1
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

// ── Chain meta / RPC label ───────────────────────────────────────────────────
.networkRpcLabel
  font-family 'CodeFont'
  font-size 11px
  font-weight 200
  color var(--outerspace05)
  margin-left auto
  padding-left 8px
  white-space nowrap

// ── Chain ID statusIndicator ───────────────────────────────────────────────────────────
.networkIdBadge
  font-family 'CodeFont'
  font-size 11px
  font-weight 200
  color var(--outerspace05)
  background var(--ghostA)
  border-radius 6px
  padding 2px 6px
  margin-left 8px
  white-space nowrap

// ── Accent color variants for chain bars ─────────────────────────────────────
.chainColorBar0
  background var(--accent0)
.chainColorBar1
  background var(--accent1)
.chainColorBar2
  background var(--accent2)
.chainColorBar3
  background var(--accent3)
.chainColorBar4
  background var(--accent4)
.chainColorBar5
  background var(--accent5)

// ── RPC glow variants matching accent colors ──────────────────────────────────
.chainRpcDot0
  background var(--accent0)
.chainRpcDot1
  background var(--accent1)
.chainRpcDot2
  background var(--accent2)
.chainRpcDot3
  background var(--accent3)
.chainRpcDot4
  background var(--accent4)
.chainRpcDot5
  background var(--accent5)

// ── Empty state ───────────────────────────────────────────────────────────────
.networksNotFound
  height 48px
  display flex
  justify-content center
  align-items center
  color var(--outerspace05)
  text-transform uppercase
  font-size 11px
  letter-spacing 0.1em
