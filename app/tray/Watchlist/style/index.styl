// LightPay VAULT — Watchlist Module (unique feature)

.watchlistModule
  margin 0 0 10px 0
  background rgb(6,9,22)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 16px
  overflow hidden

.watchlistHeader
  padding 14px 14px 10px
  display flex
  align-items center
  justify-content space-between
  border-bottom 1px solid rgba(14,165,233,0.18)

.watchlistTitle
  font-size 11px
  font-weight 500
  letter-spacing 0.1em
  text-transform uppercase
  color rgba(186,230,253,0.7)

.watchlistAddBtn
  width 28px
  height 28px
  border-radius 8px
  border 1px solid rgba(14,165,233,0.18)
  background transparent
  display flex
  align-items center
  justify-content center
  cursor pointer
  color rgba(186,230,253,0.7)
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)

.watchlistAddBtn:hover
  border-color rgba(14,165,233,0.4)
  color rgb(14,165,233)
  background rgba(14,165,233,0.06)

.watchlistInputRow
  padding 12px 14px
  display flex
  flex-wrap wrap
  gap 8px
  border-bottom 1px solid rgba(14,165,233,0.18)

.watchlistInput
  flex 1
  min-width 0
  background rgb(10,14,35)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 10px
  padding 9px 12px
  font-family 'CodeFont'
  font-size 11px
  font-weight 400
  color rgb(224,242,254)
  outline none
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)
  -webkit-app-region no-drag

.watchlistInput:focus
  border-color rgba(14,165,233,0.4)

.watchlistInput::placeholder
  color rgba(186,230,253,0.2)

.watchlistInputSubmit
  padding 9px 14px
  background rgb(14,165,233)
  border-radius 10px
  font-size 12px
  font-weight 500
  color rgb(3,5,15)
  cursor pointer
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)
  white-space nowrap

.watchlistInputSubmit:hover
  background rgb(56,189,248)

.watchlistInputError
  width 100%
  font-size 11px
  color rgb(239,68,68)
  padding 0 2px

.watchlistEmpty
  padding 24px 14px
  text-align center
  display flex
  flex-direction column
  align-items center
  gap 8px

.watchlistEmptyIcon
  width 44px
  height 44px
  border-radius 14px
  background rgba(14,165,233,0.08)
  border 1px solid rgba(14,165,233,0.18)
  display flex
  align-items center
  justify-content center
  color rgba(14,165,233,0.6)

.watchlistEmptyText
  font-size 13px
  font-weight 400
  color rgba(186,230,253,0.7)

.watchlistEmptySubtext
  font-size 11px
  color rgba(186,230,253,0.4)
  line-height 1.5

.watchlistItems
  display flex
  flex-direction column

.watchlistItem
  padding 12px 14px
  display flex
  align-items center
  justify-content space-between
  border-bottom 1px solid rgba(14,165,233,0.07)
  transition background 0.2s cubic-bezier(0.4, 0, 0.2, 1)

.watchlistItem:last-child
  border-bottom none

.watchlistItem:hover
  background rgba(14,165,233,0.04)

.watchlistItemLeft
  display flex
  flex-direction column
  gap 3px

.watchlistItemAddr
  font-family 'CodeFont'
  font-size 12px
  font-weight 400
  color rgba(186,230,253,0.7)
  letter-spacing 0.04em

.watchlistItemBalance
  font-family 'CodeFont'
  font-size 11px
  font-weight 300
  color rgb(14,165,233)

.watchlistItemRemove
  width 24px
  height 24px
  border-radius 6px
  display flex
  align-items center
  justify-content center
  color rgba(186,230,253,0.3)
  cursor pointer
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)

.watchlistItemRemove:hover
  background rgba(239,68,68,0.08)
  color rgb(239,68,68)
  border-radius 6px
