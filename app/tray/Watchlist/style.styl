// LightPay — Watchlist (tray)

.watchlist
  padding 12px 0

.watchlistHeader
  display flex
  align-items baseline
  justify-content space-between
  padding 0 16px 10px

.watchlistTitle
  font-size 12px
  font-weight 600
  color rgb(14,165,233)
  text-transform uppercase
  letter-spacing 0.06em

.watchlistSubtitle
  font-size 10px
  color rgba(186,230,253,0.3)

.watchlistSearch
  padding 0 8px
  margin-bottom 8px
  position relative

.watchlistSearchInput
  width 100%
  box-sizing border-box
  background rgb(10,14,35)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 6px
  padding 7px 12px
  font-size 12px
  color rgba(186,230,253,0.7)
  transition all 0.15s ease
  &:focus
    outline none
    border-color rgba(14,165,233,0.4)
    background rgb(10,14,35)

.watchlistDropdown
  position absolute
  top calc(100% + 4px)
  left 8px
  right 8px
  background rgb(6,9,22)
  border 1px solid rgba(14,165,233,0.25)
  border-radius 6px
  z-index 100
  overflow hidden

.watchlistDropdownItem
  display flex
  align-items center
  gap 8px
  width 100%
  padding 8px 12px
  background none
  border none
  cursor pointer
  text-align left
  transition background 0.1s ease
  &:hover
    background rgba(14,165,233,0.04)

.watchlistDropdownSymbol
  font-size 12px
  font-weight 600
  color rgba(186,230,253,0.7)
  min-width 40px

.watchlistDropdownName
  font-size 11px
  color rgba(186,230,253,0.4)

.watchlistRows
  padding 0 8px

.watchlistRow
  display grid
  grid-template-columns 40px 1fr auto auto 20px
  align-items center
  gap 8px
  padding 7px 8px
  border-radius 5px
  transition background 0.1s ease
  &:hover
    background rgba(14,165,233,0.04)

.watchlistTokenSymbol
  font-size 12px
  font-weight 700
  color rgb(224,242,254)

.watchlistTokenName
  font-size 11px
  color rgba(186,230,253,0.4)
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.watchlistPrice
  font-size 12px
  color rgba(186,230,253,0.7)
  font-variant-numeric tabular-nums
  text-align right

.watchlistChange
  font-size 11px
  font-variant-numeric tabular-nums
  text-align right
  min-width 52px

.watchlistChangePositive
  color rgb(34,197,94)

.watchlistChangeNegative
  color rgb(239,68,68)

.watchlistRemove
  background none
  border none
  cursor pointer
  color rgba(186,230,253,0.2)
  font-size 10px
  padding 2px 3px
  border-radius 2px
  transition color 0.1s ease
  &:hover
    color rgba(239,68,68,0.7)

.watchlistEmpty
  padding 14px 8px
  font-size 11px
  color rgba(186,230,253,0.3)
  text-align center
