// LightPay — Watchlist (tray)

.watchlist
  padding 12px 0

.watchlistHeader
  display flex
  align-items baseline
  justify-content space-between
  padding 0 16px 10px

.watchlistTitle
  font-size 12px
  font-weight 600
  color rgb(14,165,233)
  text-transform uppercase
  letter-spacing 0.06em

.watchlistSubtitle
  font-size 10px
  color rgba(15, 23, 42, 0.55)

.watchlistSearch
  padding 0 8px
  margin-bottom 8px
  position relative

.watchlistSearchInput
  background rgb(255, 255, 255)
  width 100%
  box-sizing border-box
  border 1px solid rgba(14, 165, 233, 0.30)
  border-radius 8px
  padding 11px 14px
  font-size 14px
  color rgba(15, 23, 42, 0.7)
  transition all 0.15s ease
  &:focus
    outline none
    border-color rgba(14, 165, 233, 0.40)

.watchlistDropdown
  position absolute
  top calc(100% + 4px)
  left 8px
  right 8px
  border 1px solid rgba(14, 165, 233, 0.25)
  border-radius 6px
  z-index 100
  overflow hidden

.dark
  .watchlistSearchInput
    background rgb(224, 235, 252)
    &:focus
      background rgb(224, 235, 252)
  .watchlistDropdown
    background rgb(240, 245, 255)

.light
  .watchlistSearchInput
    background rgb(224,235,252)
    &:focus
      background rgb(224,235,252)
  .watchlistDropdown
    background rgb(240,245,255)

.watchlistDropdownItem
  display flex
  align-items center
  gap 8px
  width 100%
  padding 8px 12px
  background none
  border none
  cursor pointer
  text-align left
  transition background 0.1s ease
  &:hover
    background rgba(255, 255, 255, 0.04)

.watchlistDropdownSymbol
  font-size 12px
  font-weight 600
  color rgba(15, 23, 42, 0.7)
  min-width 40px

.watchlistDropdownName
  font-size 11px
  color rgba(15, 23, 42, 0.6)

.watchlistRows
  padding 0 8px

.watchlistRow
  display grid
  grid-template-columns 40px 1fr auto auto 20px
  align-items center
  gap 8px
  padding 7px 8px
  border-radius 5px
  transition background 0.1s ease
  &:hover
    background rgba(255, 255, 255, 0.04)

.watchlistTokenSymbol
  font-size 12px
  font-weight 700
  color rgb(15, 23, 42)

.watchlistTokenName
  font-size 11px
  color rgba(15, 23, 42, 0.4)
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.watchlistPrice
  font-size 12px
  color rgba(15, 23, 42, 0.7)
  font-variant-numeric tabular-nums
  text-align right

.watchlistChange
  font-size 11px
  font-variant-numeric tabular-nums
  text-align right
  min-width 52px

.watchlistChangePositive
  color rgb(34,197,94)

.watchlistChangeNegative
  color rgb(239,68,68)

.watchlistRemove
  background none
  border none
  cursor pointer
  color rgba(15, 23, 42, 0.5)
  font-size 10px
  padding 2px 3px
  border-radius 2px
  transition color 0.1s ease
  &:hover
    color rgba(239,68,68,0.7)

.watchlistInput::placeholder
  color rgba(15, 23, 42, 0.55)

.watchlistEmpty
  padding 14px 8px
  font-size 11px
  color rgba(15, 23, 42, 0.3)
  text-align center
