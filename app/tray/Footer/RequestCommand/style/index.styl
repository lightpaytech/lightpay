// ─── RequestCommand index.styl — Electric Blue design ────────────────────────
// Footer approve/reject area — most critical user action surface

// Container wrapping approve + reject
.actionCommand
  border-top 1px solid rgba(14, 165, 233, 0.12)
  padding 12px 14px
  display flex
  gap 10px
  align-items center

.dark
  .actionCommand
    background rgb(240, 245, 255)

.light
  .actionCommand
    background rgb(240, 245, 255)

@import '../TxApproval/style'
