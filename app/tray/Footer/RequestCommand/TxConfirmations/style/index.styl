// Electric Blue — Transaction Confirmations

.flowConfirmations
  display flex
  align-items center
  gap 6px
  padding 6px 0

.flowConfirmationsDots
  display flex
  gap 4px

.flowConfirmationsDot
  width 8px
  height 8px
  border-radius 50%
  background rgba(14, 165, 233, 0.15)
  transition 0.3s cubic-bezier(0.4, 0, 0.2, 1) all

.flowConfirmationsDotFilled
  background rgb(14, 165, 233)

.flowConfirmationsText
  font-family 'CodeFont'
  font-size 11px
  color rgba(186, 230, 253, 0.7)
