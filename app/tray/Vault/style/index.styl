// LightPay Electric Blue — VaultPanel container

.vaultPanel
  position absolute
  inset 0
  display flex
  flex-direction column
  overflow hidden
  background rgb(6, 9, 22)

.vaultPanelHeader
  flex-shrink 0
  z-index 100

.vaultPanelBody
  flex 1
  overflow hidden
  position relative

.vaultPanelFooter
  flex-shrink 0
  z-index 100
