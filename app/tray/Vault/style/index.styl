// LightPay Electric Blue — VaultPanel container

.dark
  .vaultPanel
    background rgb(240, 245, 255)

.light
  .vaultPanel
    background rgb(240, 245, 255)

.vaultPanel
  position absolute
  inset 0
  display flex
  flex-direction column
  overflow hidden

.vaultPanelHeader
  flex-shrink 0
  z-index 100

.vaultPanelBody
  flex 1
  overflow hidden
  position relative

.vaultPanelFooter
  flex-shrink 0
  z-index 100
