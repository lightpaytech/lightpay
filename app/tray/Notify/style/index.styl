  padding 10px 14px
  font-size 12px
  color rgb(14, 165, 233)
  text-align center
  margin-top 8px

.alertSection
  font-size 13px
  color rgba(186, 230, 253, 0.7)
  line-height 1.6
  margin-bottom 6px

.alertActions
  display flex
  gap 8px
  margin-top 4px

.alertActionBtn
  flex 1
  height 44px
  border-radius 12px
  display flex
  align-items center
  justify-content center
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
