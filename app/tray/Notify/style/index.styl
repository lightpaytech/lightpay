  text-align center
  margin-bottom 16px

.alertBodyLine
  font-size 13px
  color rgba(186, 230, 253, 0.7)
  line-height 1.65
  margin-bottom 8px

.alertBodyLineUrl
  font-family 'CodeFont'
  font-size 11px
  color rgb(14, 165, 233)
