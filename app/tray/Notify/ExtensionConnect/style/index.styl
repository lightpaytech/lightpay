// Electric Blue — Extension Connect Notification

.extConnectWrap
  padding 14px

.extConnectTitle
  font-size 14px
  font-weight 500
  color rgb(15, 23, 42)
  margin-bottom 8px

.extConnectId
  font-family 'CodeFont'
  font-size 11px
  color rgba(15, 23, 42, 0.7)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 8px
  padding 6px 10px
  letter-spacing 0.06em
  word-break break-all
  margin-bottom 12px

.dark
  .extConnectId
    background rgb(248, 250, 255)

.light
  .extConnectId
    background rgb(248, 250, 255)

.extConnectActions
  display flex
  gap 8px

.extConnectAllow
  flex 1
  height 38px
  background rgb(14, 165, 233)
  border 1px solid rgba(14, 165, 233, 0.40)
  border-radius 10px
  display flex
  align-items center
  justify-content center
  color white
  font-size 13px
  font-weight 500
  cursor pointer
  transition 0.2s cubic-bezier(0.4,0,0.2,1) all

.extConnectAllow:hover
  background rgb(56, 189, 248)
  border-color rgba(14, 165, 233, 0.50)

.extConnectDeny
  height 38px
  padding 0 14px
  border-radius 10px
  border 1px solid rgba(244,63,94,0.25)
  background transparent
  color var(--bad)
  font-size 13px
  cursor pointer
  display flex
  align-items center
  justify-content center
  transition 0.2s cubic-bezier(0.4,0,0.2,1) all

.extConnectDeny:hover
  background rgba(244,63,94,0.06)
  border-color rgba(244,63,94,0.5)
