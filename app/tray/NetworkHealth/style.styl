// LightPay — Network Health Bar

@keyframes networkPulse
  0%, 100%
    opacity 1
  50%
    opacity 0.4

.networkHealthBar
  border-top 1px solid rgba(14, 165, 233, 0.10)

.dark
  .networkHealthBar
    background rgb(240, 245, 255)

.light
  .networkHealthBar
    background rgb(240,245,255)

.networkHealthSummary
  display flex
  align-items center
  padding 6px 16px
  cursor pointer
  gap 8px
  transition background 0.15s ease
  &:hover
    background rgba(255, 255, 255, 0.04)

.networkHealthIndicator
  display flex
  align-items center
  gap 6px
  flex 1

.networkHealthPulse
  width 8px
  height 8px
  border-radius 50%
  flex-shrink 0

.networkHealthPulseGood
  background rgb(34,197,94)
  animation networkPulse 2s infinite

.networkHealthPulseWarn
  background rgb(251,191,36)

.networkHealthPulseOff
  background rgb(239,68,68)

.networkHealthLabel
  font-size 11px
  color rgba(15, 23, 42, 0.65)
  font-weight 500

.networkHealthCount
  font-size 11px
  color rgba(15, 23, 42, 0.6)

.networkHealthChevron
  font-size 9px
  color rgba(15, 23, 42, 0.5)

.networkHealthDetail
  padding 6px 16px 10px
  border-top 1px solid rgba(14, 165, 233, 0.10)

.networkHealthRow
  display flex
  align-items center
  gap 8px
  padding 4px 8px
  border-radius 4px
  transition background 0.15s ease
  &:hover
    background rgba(255, 255, 255, 0.04)

.healthDot
  width 7px
  height 7px
  border-radius 50%
  flex-shrink 0

.healthDotGood
  background rgb(34,197,94)

.healthDotWarn
  background rgb(251,191,36)

.healthDotOff
  background rgb(239,68,68)

.networkHealthName
  flex 1
  font-size 11px
  color rgba(15, 23, 42, 0.6)

.networkHealthLatency
  font-size 10px
  color rgba(15, 23, 42, 0.5)

.networkHealthEmpty
  font-size 11px
  color rgba(15, 23, 42, 0.6)
  padding 4px 0
