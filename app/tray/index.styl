// LightPay VAULT — Tray Panel
@import '../../resources/base'

html, body
  margin 0
  border 0
  font-family 'MainFont'
  font-weight 300
  -webkit-app-region no-drag
  overflow hidden
  color rgb(7, 89, 133)
  background-color rgb(248, 250, 255)

div
  user-select none
  cursor default

::-webkit-scrollbar
  width 0
  background transparent

// Main tray panel
#panel
  margin 0
  overflow hidden
  position relative

  .session
    position fixed
    top 0
    right 15px
    height 40px
    font-weight 400
    border-bottom-left-radius 8px
    display flex
    justify-content center
    align-items center
    user-select none
    cursor default
    font-size 13px

// ─── VAULT visual overrides for dark mode ─────
