// LightPay VAULT — Tray Panel
@import '../../resources/base'

html, body
  margin 0
  border 0
  font-family 'MainFont'
  font-weight 300
  -webkit-app-region no-drag
  overflow hidden
  color rgb(224, 242, 254)
  background-color rgb(3, 5, 15)

div
  user-select none
  cursor default

::-webkit-scrollbar
  width 0
  background transparent

// Main tray panel
#panel
  margin 0
  overflow hidden
  position relative

  .session
    position fixed
    top 0
    right 15px
    height 40px
    font-weight 400
    border-bottom-left-radius 8px
    display flex
    justify-content center
    align-items center
    user-select none
    cursor default
    font-size 13px

// ─── VAULT visual overrides for dark mode ─────
.dark
  --ghostX rgba(1, 3, 9, 1)
  --ghostX04 rgba(1, 3, 9, 0.4)
  --ghostX09 rgba(1, 3, 9, 0.9)
  --ghostY rgba(3, 5, 15, 1)
  --ghostZ rgba(4, 7, 18, 1)
  --ghostZ0 rgba(4, 7, 18, 0)
  --ghostZ05 rgba(4, 7, 18, 0.5)
  --ghostZ08 rgba(4, 7, 18, 0.8)
  --ghostAZ rgba(6, 9, 22, 1)
