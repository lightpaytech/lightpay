// VAULT card animations
@keyframes vaultSlideIn
  0%
    opacity 0
    transform translateY(8px) scale(0.98)
  60%
    opacity 1
    transform translateY(-1px) scale(1.002)
  100%
    opacity 1
    transform translateY(0) scale(1)

@keyframes vaultFadeUp
  0%
    opacity 0
    transform translateY(6px)
  100%
    opacity 1
    transform translateY(0)

@keyframes arrowSlide
  0%
    opacity 0
    transform translateY(4px)
  20%
    opacity 1
  40%
    opacity 0
    transform translateY(-12px)
  100%
    opacity 0

@keyframes arrowSlideSingle
  0%
    opacity 0
    transform translateY(3px)
  50%
    opacity 1
  100%
    opacity 0
    transform translateY(-3px)

@keyframes headShake
  0%
    transform translateX(0)
  6.5%
    transform translateX(-5px) rotateY(-8deg)
  18.5%
    transform translateX(4px) rotateY(6deg)
  31.5%
    transform translateX(-2px) rotateY(-4deg)
  43.5%
    transform translateX(2px) rotateY(2deg)
  50%
    transform translateX(0)

.headShake
  animation-duration 0.9s
  animation-fill-mode both
  animation-timing-function ease-in-out
  animation-name headShake
  transform translateZ(0)

.standardFade-enter
  opacity 0

.standardFade-enter.standardFade-enter-active
  opacity 1
  transition var(--standard)

.standardFade-leave
  opacity 1

.standardFade-leave.standardFade-leave-active
  opacity 0
  transition var(--standard)

.footerModule
  position absolute
  bottom 0
  left 0
  right 0
  min-height 44px
  z-index 99999999
  transition var(--standard)

  .footerWrap
    width 100%
    display flow-root

.signer
  position relative
  z-index 3001
  transition var(--standard), 0s linear height
  will-change transform
  transform translate3d(0, 0, 0)
  pointer-events auto
  box-sizing border-box
  z-index 10000000

// ─── Card show / hide ─────────────────────────

.vaultCardShow
  animation vaultSlideIn 360ms cubic-bezier(0.16, 1, 0.3, 1) both
  animation-delay 0s

.vaultCardHide
  opacity 0
  pointer-events none
