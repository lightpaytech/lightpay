// ─── Electric Blue Design: AccountController ──────────────────────────────────
// Primary: rgb(14,165,233) | Card bg: rgb(240,245,255) | Hover: rgb(224,235,252)
// Transition: 0.28s cubic-bezier(0.4,0,0.2,1) | Radius: 16px cards / 10–12px inputs

// ─── Animations ──────────────────────────────────────────────────────────────

@keyframes slideUp
  0%
    opacity 0
  100%
    opacity 1

@keyframes headShake
  0%
    transform translateX(0)
  6.5%
    transform translateX(-6px) rotateY(-9deg)
  18.5%
    transform translateX(5px) rotateY(7deg)
  31.5%
    transform translateX(-3px) rotateY(-5deg)
  43.5%
    transform translateX(2px) rotateY(3deg)
  50%
    transform translateX(0)

@keyframes signerStatusScan
  0%
    left -60%
  100%
    left 110%

.headShake
  animation-duration 1s
  animation-fill-mode both
  animation-timing-function ease-in-out
  animation-name headShake
  transform translateZ(0)

.standardFade-enter
  opacity 0

.standardFade-enter.standardFade-enter-active
  opacity 1
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

.standardFade-leave
  opacity 1

.standardFade-leave.standardFade-leave-active
  opacity 0
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

// ─── Card wrap ───────────────────────────────────────────────────────────────

.signerWrap
  position relative
  width 100%
  padding 0 8px
  box-sizing border-box

.signer
  position relative
  width 100%
  pointer-events auto
  box-sizing border-box
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all
  will-change transform
  transform translate3d(0, 0, 0)
  z-index 10

// ─── Collapsed card (signerTop) — clean flex layout ───────────────────────────

.signerTop
  position relative
  display flex
  align-items center
  gap 12px
  height 72px
  padding 0 14px
  margin 0 0 8px 0
  border-radius 16px
  background rgb(240, 245, 255)
  border 1px solid rgba(14, 165, 233, 0.18)
  cursor pointer
  overflow hidden
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) background, 0.2s cubic-bezier(0.4, 0, 0.2, 1) border-color, 0.2s cubic-bezier(0.4, 0, 0.2, 1) transform, 0.2s cubic-bezier(0.4, 0, 0.2, 1) box-shadow

.signerTop:hover
  background rgb(224, 235, 252)
  border-color rgba(14, 165, 233, 0.40)
  transform translateY(-1px)
  box-shadow 0 4px 12px rgba(14, 165, 233, 0.10)

.signerTopActive
  border-color rgba(14, 165, 233, 0.40)

.signerTopNoHover
  pointer-events none !important
  *
    pointer-events none !important

// ── Status indicator pill (left) ──────────────────────────────────────────────

.accountIndicator
  position relative
  flex-shrink 0
  width 4px
  height 40px
  border-radius 2px
  background rgba(14, 165, 233, 0.18)
  pointer-events none

.accountIndicatorGood
  background rgb(14, 165, 233)

.accountIndicatorLocked
  background var(--bad)

// ── Signer type badge (icon) ──────────────────────────────────────────────────

.deviceType
  position relative
  flex-shrink 0
  width 44px
  height 44px
  border-radius 12px
  background rgba(14, 165, 233, 0.08)
  border 1px solid rgba(14, 165, 233, 0.18)
  display flex
  align-items center
  justify-content center
  color rgb(14, 165, 233)
  pointer-events auto
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

  div, svg
    pointer-events none

.signerTypeHot
  background rgba(251, 146, 60, 0.10)
  border-color rgba(251, 146, 60, 0.30)
  color rgb(251, 146, 60)

.deviceType .signerSelectIconWrap
  position relative
  top auto
  left auto
  right auto
  bottom auto
  width 100%
  height 100%
  display flex
  align-items center
  justify-content center
  padding 0
  transform none

.deviceType .signerImage,
.deviceType .signerText
  display none

// ── Account details (name + truncated address) ────────────────────────────────

.signerDetails
  position relative
  flex 1
  min-width 0
  display flex
  flex-direction column
  justify-content center
  gap 3px
  padding 0
  pointer-events auto

.signerDetailsName
  font-family 'MainFont'
  font-size 15px
  font-weight 500
  color rgb(15, 23, 42)
  letter-spacing 0.01em
  white-space nowrap
  overflow hidden
  text-overflow ellipsis
  pointer-events none

.signerDetailsAddress
  display inline-flex
  align-items center
  width fit-content
  max-width 100%
  font-family 'CodeFont'
  font-size 11px
  font-weight 400
  letter-spacing 0.05em
  color rgba(15, 23, 42, 0.55)
  padding 2px 6px
  margin-left -6px
  border-radius 6px
  cursor pointer
  transition 0.15s cubic-bezier(0.4, 0, 0.2, 1) all

  *
    pointer-events none

.signerDetailsAddress:hover
  background rgba(14, 165, 233, 0.08)
  color rgb(14, 165, 233)

.signerDetailsAddressPart
  font-family 'CodeFont'

.signerDetailsAddressDivide
  display inline-flex
  align-items center
  padding 0 3px
  opacity 0.5

.signerDetailsENSName
  font-family 'CodeFont'
  font-size 13px
  font-weight 500
  letter-spacing -0.02em
  color rgb(14, 165, 233)
  pointer-events auto
  cursor pointer
  width fit-content

// ── Full-address overlay (on hover) ───────────────────────────────────────────

.signerDetailsFullAddress
  position absolute
  inset 0
  display flex
  align-items center
  justify-content center
  padding 0 16px
  cursor pointer
  pointer-events auto
  background rgb(240, 245, 255)
  z-index 5

  *
    pointer-events none

.signerDetailsFullAddressText
  font-family 'CodeFont'
  font-size 12px
  font-weight 400
  letter-spacing 0.05em
  color rgb(15, 23, 42)
  word-break break-all
  text-align center

.signerDetailsFullAddressCopied
  display inline-flex
  align-items center
  gap 8px
  font-family 'MainFont'
  font-size 13px
  font-weight 500
  color rgb(14, 165, 233)

// ── Notification badge (request count) ────────────────────────────────────────

.accountNotificationBadge
  position relative
  flex-shrink 0
  display flex
  align-items center
  justify-content center
  min-width 32px
  height 28px
  padding 0 10px
  border-radius 14px
  background transparent
  border 1px solid rgba(14, 165, 233, 0.18)
  font-family 'CodeFont'
  font-size 12px
  font-weight 500
  color rgba(15, 23, 42, 0.4)
  pointer-events none
  overflow hidden
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

  span
    position relative
    z-index 4

.accountNotificationBadgeReady
  background rgba(14, 165, 233, 0.10)
  border-color rgba(14, 165, 233, 0.30)
  color rgb(15, 23, 42)

.accountNotificationBadgeActive
  background rgb(14, 165, 233)
  border-color rgb(14, 165, 233)

  span
    color white

// ── Chevron / select button (right) ───────────────────────────────────────────

.signerSelect
  position relative
  flex-shrink 0
  width 40px
  height 40px
  border-radius 12px
  background transparent
  border 1px solid rgba(14, 165, 233, 0.18)
  display flex
  align-items center
  justify-content center
  cursor pointer
  padding 0
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

  *
    pointer-events none

.signerSelect:hover
  background rgba(14, 165, 233, 0.08)
  border-color rgba(14, 165, 233, 0.40)

.signerSelectButton
  width 100%
  height 100%
  background transparent
  border none
  border-radius 12px
  display flex
  align-items center
  justify-content center
  padding 0

.signerSelectButton:hover
  background transparent

.signerSelect .signerSelectIconWrap
  position relative
  top auto
  left auto
  right auto
  bottom auto
  width auto
  height auto
  display flex
  align-items center
  justify-content center
  padding 0

.signerSelectIcon
  display flex
  align-items center
  justify-content center
  color rgba(15, 23, 42, 0.5)
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

.signerSelect:hover .signerSelectIcon
  color rgb(14, 165, 233)

// ── Account grabber handle (drag) ─────────────────────────────────────────────

.accountGrabber
  display none

// ─── Expanded / open signer state ─────────────────────────────────────────────

.openSigner
  pointer-events none

  .signerTop
    cursor auto
    margin 0
    border-radius 16px 16px 0 0
    border-bottom 1px solid rgba(14, 165, 233, 0.18)

    .signerSelect
      pointer-events auto !important

      .signerSelectButton
        pointer-events auto !important

  .signerTop:hover
    background rgb(240, 245, 255)
    transform translateY(0)
    box-shadow none

    .signerSelect
      .signerSelectButton
        background transparent

      .signerSelectButton:hover
        background rgba(14, 165, 233, 0.08)

// ─── Status "Not OK" overlay (connecting / locked variants) ──────────────────

.signerStatusNotOk
  position absolute
  inset 0
  display flex
  align-items center
  justify-content center
  flex-direction column
  gap 10px
  padding 0 16px
  background rgb(240, 245, 255)
  z-index 6

.signerStatusNotOkInner
  display flex
  align-items center
  gap 10px
  width 100%

.signerStatusNotOkDot
  width 8px
  height 8px
  border-radius 50%
  background var(--pending)
  flex-shrink 0
  animation vaultPulse 1.4s ease-in-out infinite

.signerStatusNotOkText
  font-size 13px
  font-weight 400
  color rgba(15, 23, 42, 0.4)
  letter-spacing 0.01em
  text-transform capitalize

.signerStatusNotOkLoader
  width 100%
  height 2px
  background rgba(14, 165, 233, 0.15)
  border-radius 1px
  overflow hidden
  position relative

.signerStatusNotOkLoaderBar
  position absolute
  left -60%
  top 0
  bottom 0
  width 60%
  background linear-gradient(90deg, transparent, var(--pending), transparent)
  border-radius 1px
  animation signerStatusScan 1.8s ease-in-out infinite

// ─── Expanded panel: nav bar + middle panel + account list ───────────────────

.walletNavBar
  position absolute
  top 80px
  left 0
  right 0
  height 44px
  border-radius 12px
  background rgb(224, 235, 252)
  border 1px solid rgba(14, 165, 233, 0.18)
  display flex
  align-items center
  justify-content space-between
  overflow hidden
  z-index 5
  animation slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1) both
  animation-delay 0.2s

  .accountMenuLeft, .accountMenuRight
    display flex
    align-items center
    height 100%

  .accountMenuLeft .walletNavItem + .walletNavItem
    border-left 1px solid rgba(14, 165, 233, 0.12)

  .accountMenuRight .walletNavItem + .walletNavItem
    border-left 1px solid rgba(14, 165, 233, 0.12)

  .walletNavItem
    height 44px
    width 44px
    display flex
    align-items center
    justify-content center
    cursor pointer
    color rgba(15, 23, 42, 0.55)
    transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

    div, svg
      pointer-events none

  .walletNavItem:hover
    background rgba(14, 165, 233, 0.08)
    color rgb(14, 165, 233)

.walletSignerMid
  position absolute
  top calc(80px + 52px)
  right 0
  bottom 8px
  left 0
  border-radius 12px
  background rgb(224, 235, 252)
  border 1px solid rgba(14, 165, 233, 0.18)
  overflow hidden
  z-index 5
  animation slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1) both
  animation-delay 0.3s

  > div
    transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

  .signerMidMenu
    background rgba(255, 255, 255, 0.04)
    border-bottom 1px solid rgba(14, 165, 233, 0.12)
    height 50px
    display flex
    flex-direction column
    justify-content center
    align-items center

    .deviceMenuItems
      height 25px
      display flex
      justify-content center
      align-items center
      margin-top 5px

      .deviceMenuItem
        height 30px
        width 40px
        display flex
        justify-content center
        align-items center
        transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

  .walletSignerNode
    display flex
    justify-content center
    align-items center
    font-size 12px
    font-weight 200
    height 40px
    border-top 1px solid rgba(14, 165, 233, 0.15)
    color rgba(15, 23, 42, 0.4)

.signerEvents
  height 200px
  overflow scroll
  background rgba(248, 250, 255, 0.6)
  width 100%

// ─── Account list (when signer expanded to choose accounts) ───────────────────

.walletListWrap
  position absolute
  top 80px
  left 0
  right 0
  background rgb(224, 235, 252)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-top none
  border-bottom-left-radius 16px
  border-bottom-right-radius 16px
  overflow hidden
  z-index 4
  height 0
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) height

  .accountList
    position absolute
    inset 0
    padding 12px 0
    overflow hidden

    .accountListItems
      display flex
      flex-direction column
      gap 4px
      padding 0 12px
      transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all
      pointer-events none
      opacity 0

      .walletListItem
        display flex
        align-items center
        justify-content space-between
        height 44px
        padding 0 12px
        border-radius 10px
        font-family 'CodeFont'
        font-size 12px
        font-weight 400
        color rgba(15, 23, 42, 0.55)
        background transparent
        transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
        cursor pointer

        .accountListItemAddress
          display flex
          align-items center
          gap 4px

          svg
            margin 0 2px

      .walletListItem:hover
        background rgba(14, 165, 233, 0.06)
        color rgb(15, 23, 42)

      .walletListItemActive
        background rgb(240, 245, 255)
        color rgb(15, 23, 42)
        border 1px solid rgba(14, 165, 233, 0.40)

        .accountListItemCheck
          color rgb(14, 165, 233)

    .accountPageToggle
      position absolute
      left 0
      right 0
      bottom 8px
      display flex
      align-items center
      justify-content center
      gap 6px
      font-family 'CodeFont'
      opacity 0
      pointer-events none
      transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

      .walletPageCurrent
        height 27px
        min-width 36px
        padding 0 8px
        display flex
        align-items center
        justify-content center
        font-size 14px
        font-weight 500
        color rgb(14, 165, 233)

      .walletPageBtn
        width 27px
        height 27px
        display flex
        align-items center
        justify-content center
        border-radius 8px
        cursor pointer
        transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

      .walletPageBtn:hover
        background rgba(14, 165, 233, 0.08)

    .settingsMenu
      position absolute
      left 0
      right 0
      bottom 0
      height 50px
      display flex
      flex-direction column
      justify-content center
      align-items center
      transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

.signerInSettings
  .walletListWrap
    height 130px

.signerAccountExpand
  .walletListWrap
    height 425px

    .accountList
      .accountListItems
        opacity 1
        pointer-events auto

      .accountPageToggle
        opacity 1
        pointer-events auto

      .settingsMenu
        opacity 0
        pointer-events none

// ─── Section row / button (settings panel) ────────────────────────────────────

.sectionRow
  height 40px
  margin-bottom 6px
  display flex
  align-items center

  input
    z-index 200
    user-select auto
    background rgb(224, 235, 252)
    outline none
    border 1px solid rgba(14, 165, 233, 0.30)
    margin-left 8px
    height 100%
    color rgb(15, 23, 42)
    border-radius 12px
    padding 0 12px
    font-size 14px
    font-weight 300
    transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

    &:focus
      border-color rgba(14, 165, 233, 0.40)

.sectionBtn
  width 100%
  height 40px
  background rgb(224, 235, 252)
  border-radius 10px
  border 1px solid rgba(14, 165, 233, 0.18)
  color rgb(15, 23, 42)
  display flex
  align-items center
  justify-content center
  font-weight 400
  font-size 13px
  letter-spacing 0.04em
  text-transform uppercase
  box-sizing border-box
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

  span
    padding-left 4px

  *
    pointer-events none

.sectionBtn:hover:not(.signerVerifyInProgress)
  cursor pointer
  background rgb(240, 245, 255)
  border-color rgba(14, 165, 233, 0.40)

.sectionBtn.signerVerifyInProgress
  background rgb(240, 245, 255)
  color rgba(15, 23, 42, 0.4)
  border-color rgba(14, 165, 233, 0.08)

.sectionBtnDanger
  color var(--bad)
  border-color rgba(244, 63, 94, 0.2)

.sectionBtnPrimary
  color rgb(14, 165, 233)
  border-color rgba(14, 165, 233, 0.40)

.sectionBtnLocked
  color rgba(15, 23, 42, 0.4)
  border-color rgba(14, 165, 233, 0.08)

.sectionBtnLocked:hover
  background rgb(224, 235, 252)
  border-color rgba(14, 165, 233, 0.18)

.signerVerifyText
  font-size 15px
  font-weight 400
  text-align center
  display flex
  justify-content center
  align-items center
  height 70px
  padding 0 30px
  color rgb(15, 23, 42)

// ─── Selector scroll / wrapper ───────────────────────────────────────────────

.accountSelectorScroll
  width 100%
  max-height 100%
  overflow-y auto
  -ms-overflow-style none
  scrollbar-width none

.accountSelectorScroll::-webkit-scrollbar
  display none

.accountSelectorScrollWrap
  width 100%
  display flex
  flex-direction column
  gap 0
