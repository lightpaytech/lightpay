@import '../AccountController/style'

// ─── Electric Blue Design: AccountSelector ───────────────────────────────────
// Primary: electric blue rgb(14,165,233) | Backgrounds: dark theme
// Transition: 0.28s cubic-bezier(0.4,0,0.2,1)

.dark
  .walletSelector
    background rgb(240, 245, 255)

.light
  .walletSelector
    background rgb(240, 245, 255)

.walletSelector
  position absolute
  top 80px
  right 8px
  bottom 40px
  left 8px
  border-radius 16px
  z-index 999
  display flex
  flex-direction column
  align-items stretch
  justify-content flex-start
  overflow hidden
  transform translateY(0px)
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all
  border 1px solid rgba(14, 165, 233, 0.18)

  .accountSelectorScroll
    flex 1
    width 100%
    border-radius 14px
    transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all
    overflow-y auto
    overflow-x hidden
    scrollbar-width none

    &::-webkit-scrollbar
      display none

    .accountSelectorScrollWrap
      width 100%
      padding 60px 0 16px 0
      box-sizing border-box
      will-change scroll-position
      z-index 999
      display flex
      flex-direction column
      gap 0

      .noDevices
        width 100%
        display flex
        justify-content center
        align-items center
        flex-direction column
        font-weight 400
        font-size 15px
        position relative
        z-index 100
        padding 24px
        color rgba(15, 23, 42, 0.85)

        .introLogo
          padding-bottom 38px

          svg
            fill rgba(255, 255, 255, 0.6)

        .getStarted
          margin-top 30px
          box-sizing border-box
          border-radius 12px
          padding 20px
          font-size 13px
          margin 20px
          text-align center
          font-weight 300
          color rgba(15, 23, 42, 0.7)
          line-height 24px
          border 1px solid rgba(14, 165, 233, 0.18)

          .getStartedPlus
            display inline-block
            position relative
            top 4px
            border 2px solid rgba(14, 165, 233, 0.60)
            width 43px
            height 22px
            border-radius 11px
            text-align center
            margin 0px 5px 0px 5px
            box-sizing border-box
            color rgba(15, 23, 42, 0.7)

            span
              position relative
              top -3px
              left 2px
              font-size 17px

        .featureBox
          display flex
          justify-content center
          align-items center
          flex-direction column
          margin-top 30px

          .featureBoxText
            font-size 13px
            font-weight 400
            letter-spacing 4px
            color rgba(15, 23, 42, 0.4)

          .featureBoxSubtext
            margin-top 8px
            font-size 12px
            font-family 'CodeFont'
            font-weight 200
            justify-content center
            opacity 0.7

.dark
  .getStarted
    background rgb(224, 235, 252)

.light
  .getStarted
    background rgb(224, 235, 252)

// ─── Horizontal account carousel items ───────────────────────────────────────

.walletSelectorCard
  flex-shrink 0
  width 68px
  display flex
  flex-direction column
  align-items center
  gap 6px
  padding 8px 6px
  border-radius 14px
  border 1px solid rgba(14, 165, 233, 0.15)
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all
  cursor pointer

.walletSelectorCard:hover
  background rgba(255, 255, 255, 0.04)
  border-color rgba(14, 165, 233, 0.20)

.walletSelectorCardActive
  background rgba(255, 255, 255, 0.07)
  border-color rgba(14, 165, 233, 0.40)

.walletSelectorAvatar
  width 40px
  height 40px
  border-radius 50%
  overflow hidden
  border 2px solid rgba(14, 165, 233, 0.25)
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

  img
    width 100%
    height 100%
    object-fit cover

.walletSelectorCardActive .walletSelectorAvatar
  border-color rgba(14, 165, 233, 0.70)

.walletSelectorLabel
  font-size 10px
  font-weight 300
  color rgba(15, 23, 42, 0.4)
  text-align center
  max-width 64px
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
  letter-spacing 0.02em

// ─── Panel filter bar ────────────────────────────────────────────────────────

@keyframes appear
  0%
    filter blur(10px)
    opacity 0

  100%
    filter blur(0px)
    opacity 1

.dark
  .walletSearchMain,
  .walletSearchBar
    background rgb(240, 245, 255)

.light
  .walletSearchMain,
  .walletSearchBar
    background rgb(240, 245, 255)

.walletSearchMain
  position fixed
  top 0px
  left 0px
  right 0px
  height 48px
  z-index 99
  overflow hidden
  animation appear 1s cubic-bezier(0.4, 0, 0.2, 1)
  border-bottom 1px solid rgba(14, 165, 233, 0.18)

.walletSearchBar
  position sticky
  top 0px
  left 0px
  right 0px
  height 48px
  width 100%
  z-index 99
  overflow hidden
  animation appear 1s cubic-bezier(0.4, 0, 0.2, 1)
  border-bottom 1px solid rgba(14, 165, 233, 0.18)

.walletSearchIcon
  position absolute
  top 4px
  left 0
  bottom 0
  width 48px
  display flex
  justify-content center
  align-items center
  color rgba(15, 23, 42, 0.4)

.walletSearchInput
  position absolute
  top 0
  left 30px
  bottom 0
  right 30px

  input, input:hover, input:focus
    width 100%
    height 100%
    border none
    outline none
    text-align center
    background transparent
    color rgb(15, 23, 42)
    font-size 15px
    font-family 'MainFont'
    font-weight 300

.walletSearchClear
  position absolute
  top 8px
  right 3px
  bottom 8px
  width 40px
  display flex
  justify-content center
  align-items center
  color rgba(15, 23, 42, 0.7)
  cursor pointer
  border-radius 20px
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all

  *
    pointer-events none

.walletSearchClear:hover
  background rgba(255, 255, 255, 0.05)
  border 1px solid rgba(14, 165, 233, 0.20)

// ─── Selector open state ──────────────────────────────────────────────────────
// When open, the WalletPanel (.walletMain, z-index 3) renders below the selector.
// The selector spans top:80px→bottom:40px with a solid bg, so leaving it opaque
// would cover the panel entirely. Make it transparent and let only the selected
// signer row (which has its own .signerTop background) remain visible at top.

.walletSelectorOpen
  transform translateY(-14px)
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all
  z-index 999999999
  pointer-events none
  background transparent
  border-color transparent
  overflow visible
  *
    pointer-events none

  // Drop search-bar reservation so the selected signer sits flush at the top
  .accountSelectorScroll
    overflow visible

    .accountSelectorScrollWrap
      padding 0

.dark
  .walletSelector.walletSelectorOpen
    background transparent

.light
  .walletSelector.walletSelectorOpen
    background transparent

// ─── New account button ───────────────────────────────────────────────────────

.addWalletBtn
  display flex
  padding 16px
  color rgba(2, 132, 199, 1)
  font-weight 500
  font-size 13px
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all
  cursor pointer
  border-radius 10px
  border 1px solid rgba(14, 165, 233, 0)

  &:hover
    background rgba(14, 165, 233, 0.08)
    border-color rgba(14, 165, 233, 0.35)

  .newAccountIcon
    padding-right 10px
