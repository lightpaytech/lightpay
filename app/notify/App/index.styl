// LightPay VAULT — Notify Window
@import '../../../resources/base'

html, body
  margin 0
  border 0
  font-family 'MainFont'
  font-weight 300
  -webkit-app-region drag
  overflow hidden
  color var(--outerspace)
  background var(--ghostA)

div
  user-select none
  cursor default

.light
  --ghostA rgb(248, 250, 255)
  --ghostB rgb(240, 245, 255)
  --ghostC rgb(224, 235, 252)
  --good rgb(14, 165, 233)
  --goodUp rgb(56, 189, 248)
  --good01 rgba(14, 165, 233, 0.1)
  --good02 rgba(14, 165, 233, 0.2)
  --good04 rgba(14, 165, 233, 0.4)
  --bad rgb(220, 38, 38)
  --overlayA rgba(14, 165, 233, 0.04)
  --overlayB rgba(14, 165, 233, 0.06)

.dark
  --ghostA rgb(248, 250, 255)
  --ghostB rgb(240, 245, 255)
  --ghostC rgb(224, 235, 252)
  --good rgb(14, 165, 233)
  --goodUp rgb(56, 189, 248)
  --good01 rgba(14, 165, 233, 0.1)
  --good02 rgba(14, 165, 233, 0.2)
  --good04 rgba(14, 165, 233, 0.4)
  --bad rgb(244, 63, 94)
  --overlayA rgba(14, 165, 233, 0.03)
  --overlayB rgba(14, 165, 233, 0.04)

// ─── Notify root ─────────────────────────────────────────────
.notify
  position fixed
  inset 0
  display flex
  flex-direction column
  align-items center
  justify-content center
  padding 20px

// ─── Notification card background (theme-scoped) ─────────────
.dark
  .alertBox
    background rgb(240, 245, 255)

.light
  .alertBox
    background rgb(240, 245, 255)

// ─── Notification card ───────────────────────────────────────
.alertBox
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 20px
  padding 28px
  max-width 480px
  width 100%
  animation vaultSlide 0.32s cubic-bezier(0.4, 0, 0.2, 1) both

// ─── Card header ─────────────────────────────────────────────
.alertTitle
  font-size 20px
  font-weight 500
  color rgb(15, 23, 42)
  margin-bottom 12px
  text-align center
  letter-spacing -0.01em

// ─── Card body ───────────────────────────────────────────────
.alertBody
  font-size 14px
  color rgba(15, 23, 42, 0.7)
  line-height 1.65
  text-align center
  margin-bottom 20px

.alertLink
  color rgb(14, 165, 233)
  text-decoration underline
  cursor pointer
  transition var(--standardFast)

.alertLink:hover
  color rgb(56, 189, 248)

// ─── Action buttons ──────────────────────────────────────────
.notifyActions
  display flex
  gap 10px

.notifyPrimary
  flex 1
  height 46px
  background rgb(14, 165, 233)
  border 1px solid rgba(14, 165, 233, 0.40)
  border-radius 12px
  color white
  font-family 'MainFont'
  font-size 14px
  font-weight 500
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  letter-spacing 0.02em

.notifyPrimary:hover
  background rgb(56, 189, 248)
  border-color rgba(14, 165, 233, 0.50)

.notifySecondary
  height 46px
  padding 0 18px
  border-radius 12px
  border 1px solid rgba(14, 165, 233, 0.18)
  background transparent
  color rgba(15, 23, 42, 0.7)
  font-family 'MainFont'
  font-size 14px
  font-weight 400
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

.notifySecondary:hover
  border-color rgba(14, 165, 233, 0.40)
  color rgb(14, 165, 233)
  background rgba(255, 255, 255, 0.06)
