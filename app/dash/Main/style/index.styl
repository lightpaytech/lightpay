// VAULT — Dashboard Main View

// ─── Spinner ────────────────────────────────────────────────
.loaderWrap
  width 18.5px
  height 18.5px
  margin-left 10px

@keyframes load
  0%
    transform rotate(0deg)
  100%
    transform rotate(360deg)

.loader,
.loader:after
  border-radius 100%
  width 7em
  height 7em

.loader
  font-size 2px
  position relative
  text-indent -9999em
  border-top 2px solid rgba(14, 165, 233, 0.08)
  border-right 2px solid rgba(14, 165, 233, 0.08)
  border-bottom 2px solid rgba(14, 165, 233, 0.08)
  border-left 2px solid var(--good)
  transform translateZ(0)
  animation load 1.1s infinite linear !important

// ─── Feature / feedback request buttons ─────────────────────
.requestFeature
  padding 0px
  display flex
  justify-content center
  align-items center

  .requestFeatureButton
    padding 0px 24px
    border-radius 12px
    height 56px
    font-size 13px
    display flex
    justify-content center
    align-items center
    width 100%
    margin 4px 8px
    font-weight 400
    cursor pointer
    box-sizing border-box
    background var(--ghostB)
    border 1px solid rgba(14, 165, 233, 0.18)
    color var(--outerspace08)
    transition 0.22s cubic-bezier(0.4, 0, 0.2, 1) all
    transform translateY(0px)

    *
      pointer-events none

  .requestFeatureButton:hover
    background var(--ghostC)
    border-color rgba(14, 165, 233, 0.4)
    color var(--good)
    transform translateY(-1px)

  .requestFeatureButton:active
    transform translateY(0px)
    background var(--ghostB)

  .requestFeatureButtonMoon
    color var(--outerspace06)

  .requestFeatureButtonGood
    color var(--good)

// ─── Browser extension snip icons ───────────────────────────
.snipIt
  display flex
  flex-direction column
  justify-content center
  align-items center
  transform translateZ(0)
  padding 0px 10px
  font-size 13px
  font-weight 400
  font-family 'MainFont'
  position relative
  z-index 1
  line-height 22px
  margin-bottom 28px
  margin-top 28px

  @keyframes spin
    0%
      transform rotate(0deg)
    100%
      transform rotate(360deg)

  @keyframes spinReverse
    0%
      transform rotate(0deg)
    100%
      transform rotate(-360deg)

  .snipItBrowserExtensionIcons
    display flex
    justify-content center
    align-items center
    padding 10px
    width 100%

    .extIconSnip
      display flex
      justify-content center
      align-items center
      height 68px
      width 68px
      border-radius 16px
      margin 8px
      cursor pointer
      background var(--ghostB)
      border 1px solid rgba(14, 165, 233, 0.12)
      transition 0.22s cubic-bezier(0.4, 0, 0.2, 1) all
      transform translateY(0px)

      *
        pointer-events none

    .extIconSnip:hover
      transform translateY(-2px)
      background var(--ghostC)
      border-color rgba(14, 165, 233, 0.4)

    .extIconSnip:active
      transform translateY(0px)
      background var(--ghostB)

// ─── Dash modules (navigation tiles) ────────────────────────
.dashModule
  height 112px
  margin 6px
  border-radius 16px
  cursor pointer
  display flex
  justify-content center
  align-items center
  font-size 17px
  font-weight 300
  background var(--ghostB)
  border 1px solid rgba(14, 165, 233, 0.09)
  transition 0.22s cubic-bezier(0.4, 0, 0.2, 1) all
  transform translateY(0px)

  *
    pointer-events none

  .dashModuleIcon
    margin-right 20px
    color var(--good)

.dashModule:hover
  transform translateY(-1px)
  background var(--ghostC)
  border-color rgba(14, 165, 233, 0.4)
  z-index 200
  position relative

.dashModule:active
  transform translateY(0px)
  background var(--ghostB)

// ─── Signer settings slide-in panel ─────────────────────────
.signerSettings
  position absolute
  top 10px
  right 0
  bottom 0
  left 0
  transition var(--standard)
  transform translateZ(0)
  overflow hidden

  .signerSlide
    position absolute
    top 50px
    right 0
    left 0
    bottom 0
    transition var(--standard)
    padding-bottom 50px
    overflow-y scroll
    overflow-x hidden

    .signerSubslider
      width 1000%
      display flex

    .signerSubsliderSlide
      width 10%

    .signerSubsliderSlideMessage
      padding 20px
      display flex
      flex-direction column
      justify-content flex-start
      align-items center
      text-align center

    .renameAccountButtonWrap
      padding 10px
      display flex
      justify-content center
      align-items center
      text-align center

  .signerSettingsTitle
    position relative
    display flex
    align-items flex-end
    justify-content space-between
    height 40px
    font-size 20px
    padding 0px 10px 10px 10px
    font-weight 400
    color var(--outerspace)

  .signerSettingsTitle:before
    content ''
    position absolute
    bottom -2px
    right 10px
    left 10px
    height 1px
    border-radius 1px
    background rgba(14, 165, 233, 0.12)

.signerSettingsHidden
  left 100%
  right -100%

// ─── Signer permission card ──────────────────────────────────
.devicePerm
  position relative
  justify-content space-between
  padding 12px 0px 0px 0px
  font-size 15px
  font-weight 300
  transform translateZ(0)
  z-index 2000
  border-radius 16px
  background var(--ghostB)
  border 1px solid rgba(14, 165, 233, 0.1)

  .signerPermissionControls
    display flex
    position relative
    justify-content space-between
    transform translateZ(0)
    z-index 40

  .signerPermissionDetails
    display flex
    position relative
    justify-content space-between
    transform translateZ(0)
    font-size 13px
    padding 12px 0px 0px 1px
    z-index 20
    font-weight 300
    font-family 'MainFont'
    line-height 18px
    color var(--outerspace07)

  .shortcutCmd
    margin-left 5px
    padding 1px 6px 2px 6px
    font-weight 400
    border-radius 6px
    font-size 11px
    border 1px solid rgba(14, 165, 233, 0.2)
    color var(--outerspace)
    height 28px
    background var(--ghostC)

  .shortcutLoading
    margin-left 5px
    padding 1px 6px 2px 6px
    font-weight 400
    border-radius 6px
    font-size 11px
    border 1px solid rgba(14, 165, 233, 0.12)
    color var(--outerspace05)
    height 28px
    background var(--ghostC)

  .nodeProviderStatus
    display flex
    justify-content center
    align-items center
    height 18px
    border-radius 9px
    font-size 10px
    text-transform uppercase
    letter-spacing 0.06em
    padding-left 8px
    padding-right 8px
    background var(--bad)
    padding-bottom 1px
    font-weight 500
    color #f3f6fd
    transform translateZ(0)

  .nodeProviderConnected
    background var(--good)

  .signerPermissionOrigin
    background transparent
    width 250px
    direction rtl
    text-overflow ellipsis
    overflow hidden
    text-align left
    white-space nowrap
    font-weight 300
    margin-top 2px

  .signerPermissionNoPermissions
    font-weight 300
    text-align center
    width 100%
    font-size 14px
    color var(--outerspace05)

  .signerPermissionSetting
    background transparent
    width 250px
    direction rtl
    text-overflow ellipsis
    overflow hidden
    text-align left
    white-space nowrap
    font-family 'MainFont'
    font-weight 300
    font-size 17px
    position relative
    padding-top 4px

// ─── Local settings panel ────────────────────────────────────
.prefSetting
  background var(--ghostB)
  border-radius 16px
  margin 6px
  padding 20px
  border 1px solid rgba(14, 165, 233, 0.09)

// ─── Add custom token button ─────────────────────────────────
.addCustomAssetBtn
  padding 0px
  margin-bottom 6px
  border-radius 12px
  height 46px
  font-size 13px
  font-weight 400
  letter-spacing 0.04em
  display flex
  justify-content center
  align-items center
  background var(--ghostB)
  border 1px solid rgba(14, 165, 233, 0.12)
  color var(--outerspace07)
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  cursor pointer
  box-sizing border-box

  *
    pointer-events none

.addCustomAssetBtn:hover
  background var(--ghostC)
  border-color rgba(14, 165, 233, 0.4)
  color var(--good)

// ─── VAULT toggle — primary (large) ─────────────────────────
.devicePermToggle
  position relative
  background var(--bad)
  height 20px
  width 40px
  margin-right 6px
  margin-left 12px
  margin-top 4px
  border-radius 10px
  transition 0.24s cubic-bezier(0.4, 0, 0.2, 1) all
  transform translateZ(0)
  cursor pointer
  border 1px solid rgba(0, 0, 0, 0.2)

  .signerPermissionToggleSwitch
    position absolute
    top 2px
    left 2px
    bottom 2px
    width 16px
    border-radius 8px
    transition 0.24s cubic-bezier(0.4, 0, 0.2, 1) all
    background var(--ghostD)
    transform translateZ(0)
    pointer-events none

  .signerPermissionToggleSwitchLocked
    position absolute
    top 0px
    left 0px
    bottom 0px
    right 0px
    border-radius 10px
    display flex
    align-items center
    justify-content center
    cursor pointer

    *
      pointer-events none

    .signerPermissionToggleSwitch
      opacity 1
      transition 0.24s cubic-bezier(0.4, 0, 0.2, 1) all

    svg
      transition 0.24s cubic-bezier(0.4, 0, 0.2, 1) all
      opacity 0
      color var(--ghostD)

  .signerPermissionToggleSwitchLocked:hover
    .signerPermissionToggleSwitch
      opacity 0

    svg
      opacity 1

.signerPermissionToggleOn
  background var(--good)
  border-color rgba(14, 165, 233, 0.4)

  .signerPermissionToggleSwitch
    position absolute
    transform translateX(20px)

.devicePermToggle:hover
  .signerPermissionToggleSwitch
    background var(--ghostC)

// ─── VAULT toggle — small ────────────────────────────────────
.devicePermToggleSmall
  position relative
  background var(--bad)
  height 14px
  width 30px
  border-radius 7px
  transition 0.24s cubic-bezier(0.4, 0, 0.2, 1) all
  transform translateZ(0)
  margin-top 2px
  margin-right 4px
  cursor pointer
  border 1px solid rgba(0, 0, 0, 0.2)

  .signerPermissionToggleSwitch
    position absolute
    top 2px
    left 2px
    bottom 2px
    width 10px
    border-radius 5px
    transition 0.24s cubic-bezier(0.4, 0, 0.2, 1) all
    background var(--ghostD)
    transform translateZ(0)
    pointer-events none

.signerPermissionToggleSmallOn
  background var(--good)
  border-color rgba(14, 165, 233, 0.4)

  .signerPermissionToggleSwitch
    position absolute
    transform translateX(16px)

.devicePermToggleSmall:hover
  .signerPermissionToggleSwitch
    background var(--ghostC)
