// VAULT Dashboard Card System

@keyframes dashCardIn
  0%
    opacity 0
    transform translateX(-8px) scale(0.98)
  55%
    opacity 1
    transform translateX(1px) scale(1.001)
  100%
    opacity 1
    transform translateX(0) scale(1)

@keyframes dashFadeIn
  0%
    opacity 0
  100%
    opacity 1

// ─── Card show/hide ──────────────────────────────────────────
@keyframes vaultCardShow
  0%
    opacity 0
    transform translateX(-10px) scale(0.97)
  50%
    opacity 1
    transform translateX(1px) scale(1.002)
  100%
    opacity 1
    transform translateX(0) scale(1)

.vaultCardShow
  animation vaultCardShow 300ms cubic-bezier(0.4, 0, 0.2, 1) both
  animation-delay 0s

.vaultCardHide
  opacity 0
  pointer-events none

// ─── VAULT dashCard ──────────────────────────────────────────
.dashCard
  background rgb(6, 9, 22)
  border 1px solid rgba(14, 165, 233, 0.15)
  border-radius 16px
  overflow hidden
  transition 0.28s cubic-bezier(0.4, 0, 0.2, 1) all
  margin-bottom 10px
  animation dashCardIn 0.36s cubic-bezier(0.4, 0, 0.2, 1) both

.dashCard:hover
  border-color rgba(14, 165, 233, 0.4)
  transform translateY(-1px)

.dashCard:active
  transform translateY(0px)
  border-color rgba(14, 165, 233, 0.15)

.dashCardHeader
  padding 14px 16px
  border-bottom 1px solid rgba(14, 165, 233, 0.07)
  display flex
  align-items center
  justify-content space-between

.dashCardTitle
  font-size 12px
  font-weight 500
  color var(--outerspace06)
  letter-spacing 0.07em
  text-transform uppercase

.dashCardContent
  padding 14px 16px
