// VAULT — Add Token Notification (in dash notify)

.addTokenNotify
  padding 20px
  display flex
  flex-direction column
  gap 16px

.addTokenNotifyIcon
  width 64px
  height 64px
  border-radius 50%
  margin 0 auto
  overflow hidden
  background rgb(10, 14, 35)
  border 2px solid rgba(14, 165, 233, 0.25)
  display flex
  align-items center
  justify-content center

  img
    width 100%
    height 100%
    object-fit cover

.addTokenNotifyName
  font-size 22px
  font-weight 500
  color rgb(224, 242, 254)
  text-align center

.addTokenNotifySymbol
  font-family 'CodeFont'
  font-size 14px
  color rgba(186, 230, 253, 0.7)
  letter-spacing 0.06em
  text-align center

.addTokenNotifyDetails
  background rgb(6, 9, 22)
  border 1px solid rgba(14, 165, 233, 0.08)
  border-radius 14px
  overflow hidden

.addTokenNotifyDetail
  padding 10px 14px
  display flex
  justify-content space-between
  align-items center
  border-bottom 1px solid rgba(14, 165, 233, 0.05)

.addTokenNotifyDetail:last-child
  border-bottom none

.addTokenNotifyDetailLabel
  font-size 12px
  color rgba(186, 230, 253, 0.7)

.addTokenNotifyDetailValue
  font-family 'CodeFont'
  font-size 12px
  color rgb(56, 189, 248)
