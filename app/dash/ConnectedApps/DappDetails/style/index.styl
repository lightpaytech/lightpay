// LightPay VAULT — Connected App Details

.lpAppDetailWrap
  padding 20px
  display flex
  flex-direction column
  gap 16px

.lpAppDetailHeader
  display flex
  align-items center
  gap 14px

.lpAppDetailIcon
  width 52px
  height 52px
  border-radius 16px
  background rgb(10,14,35)
  border 1px solid rgba(14,165,233,0.18)
  overflow hidden
  flex-shrink 0
  display flex
  align-items center
  justify-content center

  img
    width 100%
    height 100%
    object-fit cover

.lpAppDetailName
  font-size 18px
  font-weight 500
  color rgb(224,242,254)

.lpAppDetailUrl
  font-family 'CodeFont'
  font-size 11px
  color rgba(186,230,253,0.4)
  margin-top 2px

.lpAppDetailStats
  display grid
  grid-template-columns 1fr 1fr
  gap 8px

.lpAppDetailStat
  background rgb(6,9,22)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 12px
  padding 12px 14px

.lpAppDetailStatLabel
  font-size 10px
  font-weight 500
  letter-spacing 0.08em
  text-transform uppercase
  color rgba(186,230,253,0.4)
  margin-bottom 4px

.lpAppDetailStatValue
  font-family 'CodeFont'
  font-size 13px
  font-weight 400
  color rgb(224,242,254)

.lpAppDetailRevokeBtn
  height 44px
  border-radius 12px
  border 1px solid rgba(244, 63, 94, 0.25)
  background transparent
  color var(--bad)
  font-size 13px
  font-weight 400
  cursor pointer
  display flex
  align-items center
  justify-content center
  gap 8px
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  margin-top 4px

.lpAppDetailRevokeBtn:hover
  background rgba(244, 63, 94, 0.07)
  border-color rgba(244, 63, 94, 0.5)
