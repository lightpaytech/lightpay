// Electric Blue Command Palette

// Backdrop overlay
.cmdOverlay
  position fixed
  inset 0
  background rgba(248, 250, 255,0.85)
  backdrop-filter blur(8px)
  -webkit-backdrop-filter blur(8px)
  z-index 9000000
  display flex
  justify-content center
  align-items flex-start
  padding-top 80px

// Command box container
.cmdBox
  background rgb(240, 245, 255)
  border 1px solid rgba(14, 165, 233, 0.25)
  border-radius 20px
  width 380px
  max-width calc(100vw - 40px)
  overflow hidden
  display flex
  flex-direction column

// Search input area
.cmdSearch
  display flex
  align-items center
  padding 16px 20px
  border-bottom 1px solid rgba(14, 165, 233, 0.18)
  gap 12px

  .commandSearchIcon
    color rgba(14,165,233,0.6)
    flex-shrink 0
    display flex
    align-items center

  .commandSearchInput
    flex 1
    background transparent
    border none
    outline none
    font-family 'MainFont'
    font-size 16px
    font-weight 300
    color rgb(15, 23, 42)
    -webkit-app-region no-drag

    &::placeholder
      color rgba(15, 23, 42, 0.55)

  .commandSearchClear
    color rgba(14,165,233,0.5)
    cursor pointer
    display flex
    align-items center
    transition all 0.15s ease

    &:hover
      color rgb(15, 23, 42)

// Results list
.cmdResults
  max-height 300px
  overflow-y auto
  overflow-x hidden
  padding 6px

  &::-webkit-scrollbar
    width 4px

  &::-webkit-scrollbar-track
    background transparent

  &::-webkit-scrollbar-thumb
    background rgba(14,165,233,0.2)
    border-radius 2px

// Section label inside results
.cmdSection
  font-size 10px
  font-weight 500
  letter-spacing 1.5px
  text-transform uppercase
  color rgba(15, 23, 42, 0.55)
  padding 10px 12px 4px 12px

// Individual result item
.cmdItem
  padding 10px 16px
  border-radius 10px
  display flex
  align-items center
  gap 12px
  cursor pointer
  transition all 0.15s cubic-bezier(0.4, 0, 0.2, 1)
  margin 1px 0

  *
    pointer-events none

  .commandResultItemIcon
    width 30px
    height 30px
    border-radius 8px
    background rgba(255, 255, 255, 0.08)
    border 1px solid rgba(14, 165, 233, 0.18)
    display flex
    align-items center
    justify-content center
    flex-shrink 0
    color rgba(15, 23, 42, 0.55)

  .commandResultItemLabel
    font-size 14px
    font-weight 400
    color rgb(15, 23, 42)
    flex 1

  .commandResultItemSub
    font-size 11px
    color rgba(15, 23, 42, 0.55)
    font-family 'CodeFont'

  .commandResultItemShortcut
    font-family 'CodeFont'
    font-size 11px
    color rgba(15, 23, 42, 0.55)
    background rgb(224, 235, 252)
    border-radius 5px
    padding 2px 6px

.cmdItem:hover
  background rgba(255, 255, 255, 0.05)

.cmdItemActive
  background rgba(255, 255, 255, 0.08)
  border 1px solid rgba(14, 165, 233, 0.18)

  .commandResultItemIcon
    background rgba(14,165,233,0.12)
    border-color rgba(14, 165, 233, 0.40)
    color rgb(14,165,233)

// Empty state
.cmdEmpty
  padding 32px 20px
  text-align center
  color rgba(15, 23, 42, 0.55)
  font-size 13px

// Footer hint bar
.cmdFooter
  padding 8px 16px
  border-top 1px solid rgba(14, 165, 233, 0.18)
  display flex
  align-items center
  gap 12px
  font-size 11px
  color rgba(15, 23, 42, 0.55)
  font-family 'CodeFont'

  .commandFooterKey
    background rgb(224, 235, 252)
    border-radius 4px
    padding 2px 5px
    font-size 10px

// Legacy nav bar elements — preserved
.cmdPalette
  height 63px
  position absolute
  top 10px
  left 6px
  right 6px
  z-index 3000000

  .commandTitle
    position absolute
    left 73px
    right 70px
    top 1px
    bottom 0
    display flex
    justify-content center
    align-items center
    text-transform uppercase
    letter-spacing 2px
    font-weight 500
    font-size 11px

  .commandItem
    height 38px
    width 48px
    top 8px
    border-radius 16px
    display flex
    justify-content center
    align-items center
    -webkit-app-region no-drag
    pointer-events auto
    transform translate3d(0, 0, 0)
    background rgb(240, 245, 255)
    border 1px solid rgba(14, 165, 233, 0.18)
    position absolute
    cursor pointer

    *
      pointer-events none

  .commandItem:hover
    background rgba(255, 255, 255, 0.05)
    border-color rgba(14, 165, 233, 0.40)

  .commandItemBack
    left 14px

  .commandItemClose
    right 14px

.cmdBack
  padding 20px
  cursor pointer
  position absolute
  top 0
  left 0
  bottom 0
  width 64px

.cmdClose
  padding 20px
  cursor pointer
  position absolute
  top 0
  right 0
  bottom 0
  width 64px
