// LightPay VAULT — Networks Chain Management

// ─── Add / Edit Chain Title ──────────────────────────────────────────────────

.addNetworkTitle
  padding 32px 20px 24px 20px
  font-size 20px
  font-weight 300
  color rgb(15, 23, 42)
  text-align center

// ─── Add Chain Form Wrapper ──────────────────────────────────────────────────

.addNetwork
  font-size 14px
  position relative
  z-index 3
  word-break break-word
  width 100%
  box-sizing border-box
  padding-bottom 24px

// ─── Color Swatch Picker ─────────────────────────────────────────────────────

.networkColorSwatches
  display flex
  margin-top 6px
  margin-bottom 6px
  background rgba(255, 255, 255, 0.04)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 12px
  padding 4px

  .chainColorSwatch
    height 16px
    width calc(100% / 8)
    margin-left 3px
    border-radius 4px
    cursor pointer
    box-sizing border-box
    position relative
    transition transform 0.15s ease

  .chainColorSwatch:hover
    transform translateY(-2px)
    position relative
    z-index 10
    margin-bottom -2px

  .chainColorSwatch:first-child
    border-top-left-radius 10px
    border-bottom-left-radius 10px
    margin-left 0px

  .chainColorSwatch:last-child
    border-top-right-radius 10px
    border-bottom-right-radius 10px

  .chainColorSwatchSelected::before
    content ''
    position absolute
    width 5px
    height 5px
    border-radius 2.5px
    top 50%
    left 50%
    margin-top -2.5px
    margin-left -2.5px
    background rgba(255, 255, 255, 0.85)
    z-index 2

// ─── Input Width Helpers ─────────────────────────────────────────────────────

.networkId
  width calc(50% - 5px)

.networkSymbol
  width calc(50% - 5px)

.networkRpc
  width 100%

// ─── Row Wrappers ─────────────────────────────────────────────────────────────

.networkRow
  width 100%
  display flex
  justify-content space-between
  padding 0px 14px 14px 14px
  box-sizing border-box
  flex-direction column

.networkRowTestnet
  padding 8px 10px 8px 14px
  margin 8px auto 14px auto
  font-size 11px
  font-weight 500
  display flex
  align-items center
  justify-content space-between
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 20px
  text-transform uppercase
  letter-spacing 0.08em
  width 150px
  color rgba(15, 23, 42, 0.7)
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)

.networkRowTestnet:hover
  border-color rgba(14, 165, 233, 0.40)
  color rgb(15, 23, 42)

.networkRowRemove
  padding 8px 0px

// ─── Input Label ─────────────────────────────────────────────────────────────

.networkInputLabel
  font-size 10px
  text-transform uppercase
  font-weight 500
  letter-spacing 0.1em
  padding 10px 0px 4px 4px
  color rgba(15, 23, 42, 0.4)

// ─── Primary / Secondary Section Labels ──────────────────────────────────────

.networkConnectionLabel
  font-size 11px
  letter-spacing 0.06em
  text-transform uppercase
  color rgba(15, 23, 42, 0.4)
  font-weight 500

// ─── Expanded Panel Container ────────────────────────────────────────────────

.networkExpandBody
  padding 12px 14px
  border-top 1px solid rgba(14, 165, 233, 0.18)
  display flex
  flex-direction column
  gap 10px

// ─── VAULT RPC / Explorer / Symbol Input ─────────────────────────────────────

.networkInput
  background rgb(255, 255, 255)
  border 1px solid rgba(14, 165, 233, 0.30)
  border-radius 8px
  outline none
  text-align left
  font-family 'CodeFont'
  font-size 12px
  width 100%
  box-sizing border-box
  padding 10px 12px
  font-weight 400
  color rgb(15, 23, 42)
  margin-top 4px
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)
  letter-spacing 0.02em

.networkInput:focus
  border-color rgba(14, 165, 233, 0.40)
  background rgb(255, 255, 255)
  outline none

.networkInput::placeholder
  color rgba(15, 23, 42, 0.55)

.networkInputDim
  color rgba(15, 23, 42, 0.4)

// Short symbol / chain-id variant
.networkInputShort
  width 100px
  text-align center
  text-transform uppercase

// ─── Connection Status Indicator ─────────────────────────────────────────────

.networkStatus
  display flex
  align-items center
  gap 8px
  padding 4px 0px

.networkStatusDot
  width 8px
  height 8px
  border-radius 50%
  flex-shrink 0

.networkDotGood
  background rgb(34,197,94)

.networkDotBad
  background rgb(239,68,68)

.networkDotPending
  background rgb(251,191,36)

.networkStatusText
  font-size 11px
  text-transform uppercase
  letter-spacing 0.06em
  color rgba(15, 23, 42, 0.7)
  font-weight 400

// ─── Field Display (read-only) ───────────────────────────────────────────────

.networkFieldDisplay
  padding 8px 12px
  margin-top 4px
  background rgba(255, 255, 255, 0.03)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 8px
  font-family 'CodeFont'
  font-size 12px
  color rgba(15, 23, 42, 0.7)
  text-align left
  letter-spacing 0.02em

// ─── Submit / Save Button ────────────────────────────────────────────────────

.addNetworkSubmit
  background rgb(224, 235, 252)
  width 100%
  margin-top 20px
  margin-bottom 16px
  height 44px
  border-radius 10px
  box-sizing border-box
  padding 12px
  text-align center
  display flex
  justify-content center
  align-items center
  gap 8px
  font-size 13px
  text-transform uppercase
  letter-spacing 0.08em
  font-weight 500
  opacity 0.45
  pointer-events none
  border 1px solid transparent
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)

  svg
    flex-shrink 0

.addChainSubmitEnabled
  background rgba(14,165,233,0.12)
  border-color rgba(14, 165, 233, 0.40)
  color rgb(14,165,233)
  opacity 1
  cursor pointer
  pointer-events auto

  *
    pointer-events none

.addChainSubmitEnabled:hover
  background rgba(14,165,233,0.2)
  border-color rgba(14, 165, 233, 0.50)

// ─── Chain Preview (collapsed row) ──────────────────────────────────────────

.networkPreview
  padding 13px 16px
  display flex
  align-items center
  gap 12px
  cursor pointer
  border-bottom 1px solid rgba(14, 165, 233, 0.18)
  transition background 0.2s cubic-bezier(0.4, 0, 0.2, 1)

.networkPreview:hover
  background rgba(255, 255, 255, 0.04)

.networkPreviewColor
  width 10px
  height 10px
  border-radius 50%
  flex-shrink 0

.networkPreviewName
  flex 1
  font-size 14px
  font-weight 400
  color rgb(15, 23, 42)

.networkPreviewStatus
  width 8px
  height 8px
  border-radius 50%
  flex-shrink 0

.networkPreviewStatusGood
  background rgb(34,197,94)

.networkPreviewStatusBad
  background rgb(239,68,68)

.networkPreviewStatusOff
  background rgba(186,230,253,0.2)

// ─── Chain Expanded ──────────────────────────────────────────────────────────

.networkExpanded
  background rgb(224, 235, 252)
  border-top 1px solid rgba(14, 165, 233, 0.18)

.networkExpandedSection
  padding 12px 16px
  border-bottom 1px solid rgba(14, 165, 233, 0.18)

.networkExpandedSection:last-child
  border-bottom none

.networkExpandedLabel
  font-size 10px
  font-weight 500
  letter-spacing 0.08em
  text-transform uppercase
  color rgba(15, 23, 42, 0.4)
  margin-bottom 6px
  display block

.networkExpandedInput
  background rgb(255, 255, 255)
  border 1px solid rgba(14, 165, 233, 0.30)
  border-radius 10px
  padding 9px 12px
  font-family 'CodeFont'
  font-size 11px
  font-weight 400
  color rgb(15, 23, 42)
  width 100%
  outline none
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)
  box-sizing border-box
  -webkit-app-region no-drag

.networkExpandedInput:focus
  border-color rgba(14, 165, 233, 0.40)

.networkExpandedInput::placeholder
  color rgba(15, 23, 42, 0.55)

.networkExpandedInputShort
  width 50%

.networkExpandedActions
  padding 12px 16px
  display flex
  gap 8px

.networkExpandedSave
  flex 1
  height 38px
  background rgb(14,165,233)
  border-radius 10px
  display flex
  align-items center
  justify-content center
  color white
  font-size 13px
  font-weight 500
  cursor pointer
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)

.networkExpandedSave:hover
  background rgb(56,189,248)

.networkExpandedSaveDisabled
  background rgb(224, 235, 252)
  color rgba(15, 23, 42, 0.4)
  cursor not-allowed

.networkExpandedRemove
  height 38px
  padding 0 14px
  border-radius 10px
  border 1px solid rgba(239,68,68,0.25)
  background transparent
  color rgb(239,68,68)
  font-size 13px
  cursor pointer
  display flex
  align-items center
  justify-content center
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)

.networkExpandedRemove:hover
  background rgba(239,68,68,0.07)
  border-color rgba(239,68,68,0.5)

// ─── Connection indicators ───────────────────────────────────────────────────

.networkConnection
  display flex
  align-items center
  gap 8px
  padding 8px 0

.networkConnectionDot
  width 8px
  height 8px
  border-radius 50%
  flex-shrink 0

.networkConnectionDotConnected
  background rgb(34,197,94)

.networkConnectionDotError
  background rgb(239,68,68)

.networkConnectionDotLoading
  background rgba(186,230,253,0.2)
  animation lpBounceIn 1s ease-in-out infinite

.networkConnectionLabel
  font-size 11px
  color rgba(15, 23, 42, 0.7)
  font-family 'CodeFont'

.networkConnectionBadge
  font-size 10px
  font-weight 500
  padding 2px 8px
  border-radius 6px
  text-transform uppercase
  letter-spacing 0.04em

.networkConnectionBadgePrimary
  background rgba(34,197,94,0.1)
  color rgb(34,197,94)
  border 1px solid rgba(34,197,94,0.25)

.networkConnectionBadgeSecondary
  background rgba(14,165,233,0.1)
  color rgb(14,165,233)
  border 1px solid rgba(14, 165, 233, 0.25)

// ─── New Chain form ──────────────────────────────────────────────────────────

.networkNewWrap
  padding 16px
  display flex
  flex-direction column
  gap 10px

.networkNewTitle
  font-size 16px
  font-weight 500
  color rgb(15, 23, 42)
  margin-bottom 4px

.networkNewField
  display flex
  flex-direction column
  gap 5px

.networkNewFieldLabel
  font-size 10px
  font-weight 500
  letter-spacing 0.08em
  text-transform uppercase
  color rgba(15, 23, 42, 0.4)

.networkNewSubmit
  height 44px
  background rgb(14,165,233)
  border-radius 12px
  display flex
  align-items center
  justify-content center
  color white
  font-size 14px
  font-weight 500
  cursor pointer
  transition all 0.2s cubic-bezier(0.4, 0, 0.2, 1)
  margin-top 6px

.networkNewSubmit:hover
  background rgb(56,189,248)
  transform translateY(-1px)

// ─── Chain color picker ──────────────────────────────────────────────────────

.networkColorPicker
  display flex
  flex-wrap wrap
  gap 6px
  padding 4px 0

.networkColorSwatch
  width 24px
  height 24px
  border-radius 50%
  cursor pointer
  border 2px solid transparent
  transition all 0.15s cubic-bezier(0.4, 0, 0.2, 1)
  flex-shrink 0

.networkColorSwatchSelected
  border-color var(--ghostA)
  transform scale(1.15)
