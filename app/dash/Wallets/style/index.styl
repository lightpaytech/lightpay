// LightPay VAULT — Wallets Dashboard Tab

.walletsDash
  padding 14px
  display flex
  flex-direction column
  gap 8px

.walletsDashItem
  background rgb(240, 245, 255)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 14px
  padding 14px
  display flex
  align-items center
  gap 12px
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  cursor pointer

.walletsDashItem:hover
  border-color rgba(14, 165, 233, 0.40)
  background rgba(255, 255, 255, 0.04)

.walletsDashAvatar
  width 36px
  height 36px
  border-radius 50%
  background rgb(224, 235, 252)
  border 1px solid rgba(14, 165, 233, 0.20)
  overflow hidden
  flex-shrink 0

.walletsDashName
  flex 1
  font-size 14px
  font-weight 400
  color rgb(15, 23, 42)

.walletsDashAddr
  font-family 'CodeFont'
  font-size 11px
  color rgba(15, 23, 42, 0.4)
  letter-spacing 0.04em

.walletsDashType
  font-size 10px
  font-weight 500
  padding 3px 8px
  border-radius 20px
  letter-spacing 0.04em

.walletsDashTypeHot
  background rgba(251, 146, 60, 0.1)
  color var(--warning)
  border 1px solid rgba(251, 146, 60, 0.25)

.walletsDashTypeHardware
  background rgba(56, 189, 248, 0.1)
  color var(--accent7)
  border 1px solid rgba(14, 165, 233, 0.25)

.walletsDashTypeWatch
  background rgba(167, 139, 250, 0.1)
  color var(--pending)
  border 1px solid rgba(167, 139, 250, 0.25)
