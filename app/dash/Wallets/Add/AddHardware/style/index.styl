// LightPay VAULT — Add Hardware Signer

.addHardware
  padding 20px
  display flex
  flex-direction column
  gap 16px

.addHardwareTitle
  font-size 18px
  font-weight 500
  color rgb(224,242,254)

.addHardwareDevices
  display grid
  grid-template-columns 1fr 1fr
  gap 10px

.addHardwareDevice
  background rgb(10,14,35)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 14px
  padding 16px
  display flex
  flex-direction column
  align-items center
  gap 10px
  cursor pointer
  text-align center

.addHardwareDevice:hover
  border-color rgba(14,165,233,0.4)
  background rgba(14,165,233,0.04)

.addHardwareDeviceLogo
  width 40px
  height 40px
  border-radius 12px
  background rgba(14,165,233,0.07)
  border 1px solid rgba(14,165,233,0.2)
  display flex
  align-items center
  justify-content center
  overflow hidden
  padding 6px

  img
    width 100%
    height 100%
    object-fit contain
    filter brightness(1.2)

.addHardwareDeviceName
  font-size 13px
  font-weight 400
  color rgb(224,242,254)

.addHardwareStatus
  background rgb(6,9,22)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 12px
  padding 14px
  display flex
  align-items center
  gap 12px

.addHardwareStatusDot
  width 10px
  height 10px
  border-radius 50%
  flex-shrink 0

.addHardwareStatusDotScanning
  background rgb(14,165,233)
  animation lpBounceIn 1.5s ease-in-out infinite

.addHardwareStatusDotFound
  background rgb(56,189,248)

.addHardwareStatusText
  font-size 13px
  color rgba(186,230,253,0.7)

.addHardwareAccounts
  display flex
  flex-direction column
  gap 6px

.addHardwareAccount
  background rgb(10,14,35)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 10px
  padding 10px 14px
  display flex
  align-items center
  gap 10px

.addHardwareAccountActive
  border-color rgba(14,165,233,0.4)
  background rgba(14,165,233,0.04)
  color rgb(14,165,233)

.addHardwareAccountAddr
  font-family 'CodeFont'
  font-size 11px
  color rgba(186,230,253,0.7)
  flex 1
  letter-spacing 0.04em

.addHardwareAccountBal
  font-family 'CodeFont'
  font-size 11px
  color rgba(186,230,253,0.4)
