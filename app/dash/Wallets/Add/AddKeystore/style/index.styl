// LightPay VAULT — Add Keystore

.addKeystore
  padding 20px
  display flex
  flex-direction column
  gap 14px

.addKeystoreTitle
  font-size 18px
  font-weight 500
  color rgb(224,242,254)

.addKeystoreDropzone
  border 2px dashed rgba(14,165,233,0.25)
  border-radius 14px
  padding 32px 20px
  display flex
  flex-direction column
  align-items center
  gap 10px
  cursor pointer

.addKeystoreDropzone:hover
  border-color rgba(14,165,233,0.5)
  background rgba(14,165,233,0.04)

.addKeystoreDropzoneIcon
  width 44px
  height 44px
  border-radius 14px
  background rgba(14,165,233,0.07)
  border 1px solid rgba(14,165,233,0.2)
  display flex
  align-items center
  justify-content center
  color rgb(14,165,233)

.addKeystoreDropzoneText
  font-size 13px
  color rgba(186,230,253,0.7)
  text-align center

.addKeystorePasswordInput
  background rgba(14,165,233,0.04)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 12px
  padding 11px 14px
  font-size 14px
  font-weight 300
  color rgb(224,242,254)
  width 100%
  outline none
  box-sizing border-box
  -webkit-app-region no-drag
  letter-spacing 0.06em

.addKeystorePasswordInput:focus
  border-color rgba(14,165,233,0.4)
