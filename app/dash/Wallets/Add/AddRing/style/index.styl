// LightPay VAULT — Add Private Key (Ring)

.addRing
  padding 20px
  display flex
  flex-direction column
  gap 14px

.addRingTitle
  font-size 18px
  font-weight 500
  color rgb(224,242,254)

.addRingInput
  background rgba(14,165,233,0.04)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 12px
  padding 11px 14px
  font-family 'CodeFont'
  font-size 12px
  font-weight 400
  color rgb(224,242,254)
  width 100%
  outline none
  box-sizing border-box
  -webkit-app-region no-drag
  letter-spacing 0.04em

.addRingInput:focus
  border-color rgba(14,165,233,0.4)

.addRingInput::placeholder
  color rgba(186,230,253,0.4)

.addRingWarning
  background rgba(255, 75, 100, 0.06)
  border 1px solid rgba(255, 75, 100, 0.2)
  border-radius 10px
  padding 10px 14px
  font-size 11px
  color var(--bad)
  line-height 1.55

.addRingKeys
  display flex
  flex-direction column
  gap 6px

.addRingKey
  background rgb(6,9,22)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 10px
  padding 10px 14px
  display flex
  align-items center
  gap 10px

.addRingKeyAddr
  font-family 'CodeFont'
  font-size 11px
  color rgba(186,230,253,0.7)
  flex 1
  letter-spacing 0.04em

.addRingKeyRemove
  width 24px
  height 24px
  border-radius 6px
  display flex
  align-items center
  justify-content center
  color rgba(186,230,253,0.4)
  cursor pointer

.addRingKeyRemove:hover
  background rgba(255, 75, 100, 0.08)
  color var(--bad)
