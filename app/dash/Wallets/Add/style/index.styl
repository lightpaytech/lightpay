// VAULT Add Account Flow

@import '../AddAddress/style'
@import '../AddHardware/style'
@import '../AddKeystore/style'
@import '../AddHardwareLattice/style'

.addWalletItem
  display flex
  justify-content center
  align-items center
  flex-direction column
  transition var(--standardSlowest)
  transition-delay 0.32s
  position absolute
  top 0
  left 0
  bottom 0
  right 0
  overflow hidden

  .addAccountItemWrap
    width 100%
    height 100%
    background rgb(6,9,22)
    border-radius 16px
    z-index 2
    display flex
    justify-content center
    align-items center
    flex-direction column
    position relative

  .addAccountItemClose
    position absolute
    top 18px
    right 12px
    border-radius 10px
    cursor pointer
    background rgb(10,14,35)
    border 1px solid rgba(14,165,233,0.18)
    width 90px
    height 32px
    display flex
    justify-content center
    align-items center
    font-size 11px
    letter-spacing 1px
    font-weight 300
    padding-bottom 1px
    padding-left 1px
    text-transform uppercase
    transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

    *
      pointer-events none

  .addAccountItemClose:hover
    background rgb(15,20,48)
    border-color rgba(14,165,233,0.4)

  .addAccountItemTopType
    position absolute
    top 0
    left 0
    right 0
    display flex
    justify-content center
    align-items center
    font-size 22px
    font-family 'MainFont'
    font-weight 300
    width 100%
    margin 16px 0px

    .addAccountItemIconLedger
      position relative
      top -2px

    .addAccountItemIconTrezor
      position relative
      top -2px

    .addAccountItemTopTitle
      margin-top 0px
      margin-left 0px
      margin-bottom 2px
      text-transform capitalize

    .addAccountItemIcon
      position relative
      height 44px
      width 44px
      display flex
      justify-content center
      align-items center
      color var(--good)
      margin 2px 9px 2px 0px
      border-radius 14px
      background rgba(14,165,233,0.1)
      border 1px solid rgba(14,165,233,0.2)
      transform scale(1)

    .addAccountItemIconHex
      width 45px
      height 45px
      opacity 1
      position absolute
      border-radius 8px
      display none

  .addAccountItemSummary
    display flex
    align-items center
    justify-content center
    z-index 9999
    font-size 13px
    text-align center
    box-sizing border-box
    position absolute
    font-weight 400
    top 80px
    left 50px
    right 50px
    padding 16px
    border 1px solid rgba(14,165,233,0.15)
    border-radius 12px
    background rgba(14,165,233,0.04)

  .addAccountItemTrezorBridgeWarning
    display flex
    align-items center
    justify-content space-between
    flex-direction column
    z-index 9999999
    text-transform uppercase
    letter-spacing 0px
    text-align center
    min-height 22px
    box-sizing border-box
    position absolute
    font-weight 400
    bottom 20px
    left 20px
    right 20px

    .openBridgeUrl
      color var(--good)
      cursor pointer

    .openBridgeUrl:hover
      text-decoration underline
      transform translateY(0)
      transition var(--standardFast)

  .addAccountItemFooter:before
    content ''
    position absolute
    top 0px
    left 8px
    right 8px
    height 4px
    border-radius 2px
    background rgb(6,9,22)

  .addAccountItemFooter
    display flex
    align-items center
    justify-content center
    z-index 9999999
    line-height 22px
    font-size 11px
    text-transform uppercase
    letter-spacing 1px
    text-align justify
    text-align-last center-justify
    min-height 50px
    box-sizing border-box
    position absolute
    bottom 8px
    left 8px
    right 8px
    display none

  .addAccountItemDevices
    position absolute
    top 120px
    left 0px
    bottom 0px
    right 0px
    padding 10px
    font-size 12px
    text-transform uppercase
    letter-spacing 2px
    margin-top 12px
    transition var(--standardSlow)
    overflow hidden
    font-weight 400
    flex-direction column
    overflow-y scroll

    .addAccountItemDevice
      margin-top 10px
      display flex
      justify-content center
      align-items center
      flex-direction column
      padding 0px 7px

    .addAccountItemDevice:hover
      background rgba(14,165,233,0.06)
      border-radius 12px

    .addAccountItemDeviceTitle
      font-weight 300
      text-align center

    .addAccountItemDeviceStatus
      font-size 10px
      display flex
      justify-content center
      align-items center
      text-align center

  .addAccountItemOption
    position absolute
    top 150px
    left 0
    right 0
    bottom 60px
    line-height 22px
    font-size 14px
    text-transform uppercase
    transition var(--standardSlow)
    overflow hidden
    font-weight 400

  .addAccountItemOptionSetup
    position absolute
    top 0px
    right 0
    bottom 0
    left 0
    opacity 0
    pointer-events none
    transition var(--standardSlow)
    transform translateX(0%)

    .addAccountItemOptionSetupLightPays
      display flex
      width 1000%
      height 100%

      .addAccountItemOptionSetupLightPay
        display flex
        align-items center
        flex-direction column
        transition var(--standardSlow)
        width 10%
        overflow-y scroll
        height 100%
        justify-content center
        padding 0px 10px
        box-sizing border-box
        border 1px solid rgba(14,165,233,0.2)

        .addAccountItemOptionSetupLightPay:hover
          border-color rgba(14,165,233,0.5)
          background rgba(14,165,233,0.06)

        .signerAddressAdded
          color var(--good)

        .addAccountItemOptionTitle
          margin-bottom 12px
          text-align center
          font-size 15px
          font-weight 400
          box-sizing border-box

  .addAccountItemOptionError
    height 34px
    padding 0px 20px
    margin-top 12px
    font-size 12px
    color var(--bad)
    text-align center

  .addAccountItemOptionProcessing
    height 34px
    padding 0px 20px
    margin-top 12px
    font-size 12px
    text-align center

  .addWalletSubmitBtn
    height 40px
    border-radius 14px
    padding 0px 40px
    margin-top 12px
    display flex
    text-align center
    justify-content center
    align-items center
    cursor pointer
    background linear-gradient(135deg, rgb(2,132,199), rgb(14,165,233))
    color white
    font-family 'MainFont'
    font-size 14px
    font-weight 500
    letter-spacing 0.02em
    transform translate3d(0, 0, 0)
    transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

  .addWalletSubmitBtn:hover
    transform translateY(-1px)

  .addAccountResolvingEns

    .addWalletSubmitBtn
      margin-top 28px

  .addAccountItemOptionList
    width calc(100% - 0px)
    border-radius 12px
    padding 50px 0px
    height calc(100% - 60px)
    top 20px
    position relative
    overflow hidden
    box-sizing border-box
    overflow-x hidden
    overflow-y scroll

  .fira
    font-family 'CodeFont'
    text-transform none

  .addAccountItemOptionListItem
    text-align center
    padding 16px 8px 16px 8px
    margin 10px
    font-weight 300
    cursor pointer
    border-radius 12px
    background rgb(10,14,35)
    border 1px solid rgba(14,165,233,0.08)
    transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

    *
      cursor pointer

    .actingAccountAddress
      font-family 'CodeFont'
      font-size 20px
      display flex
      justify-content center
      align-items center
      text-transform none

      svg
        padding 2px 3px 0px 3px

    .actingAccountTag
      font-weight 400
      font-size 12px
      text-transform none
      color var(--outerspace08)

  .addAccountItemOptionListItem:hover
    background rgba(14,165,233,0.06)
    border-color rgba(14,165,233,0.2)

  .addAccountItemOptionInput
    width calc(100% - 40px)
    border-radius 12px
    height 50px
    padding 10px
    position relative
    overflow hidden
    background rgba(14,165,233,0.04)
    border 1px solid rgba(14,165,233,0.15)

    textarea
      width calc(100%)
      background transparent
      border none
      outline none
      color var(--outerspace)
      text-align center
      font-size 13px
      line-height 20px
      font-family 'CodeFont'
      padding-bottom 100px
      overflow hidden
      margin 4px 0px 0px 3px

    textarea::selection
      background rgba(5, 25, 35, 1)

  .addAccountItemOptionInput
    width 100%
    border-radius 14px
    padding 0px 0px
    position relative
    overflow hidden
    background rgba(14,165,233,0.04)
    border 1px solid rgba(14,165,233,0.15)
    color var(--outerspace)
    transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

    input
      width 100%
      height 100%
      padding 10px 20px 13px 21px
      background transparent
      border none
      outline none
      color var(--outerspace)
      text-align center
      font-size 22px
      line-height 20px
      font-weight 400
      display flex
      justify-content center
      align-items center
      letter-spacing 1px
      resize none
      transform translate3d(0, 0, 0)
      font-family 'MainFont'

    input::selection
      background var(--bad)

  .addAccountItemOptionInput:focus-within
    border-color rgba(14,165,233,0.4)

  .addAccountItemOptionInput.phrase
    height 122px

    .addAccountItemOptionSubtitle
      position absolute
      bottom 0
      display flex
      justify-content center
      align-items center
      text-align center
      font-size 8px
      width 100%
      font-weight 300
      letter-spacing 1px
      box-sizing border-box

    textarea
      width 100%
      height 100%
      padding 10px 20px
      background transparent
      border none
      outline none
      color var(--outerspace)
      text-align center
      font-size 15px
      line-height 20px
      font-family 'CodeFont'
      display flex
      justify-content center
      align-items center
      overflow-x hidden
      overflow-y scroll
      resize none

    textarea::selection
      background var(--bad)

  .addAccountItemOptionInput.address

    input
      font-size 12px
      padding 10px 10px

  .addAccountItemOptionInputPassword
    height 72px

  .addAccountItemColorBar
    position absolute
    top 0px
    left -40px
    right -40px
    height 4px
    background linear-gradient(90deg, var(--goodShade), var(--good), var(--goodUp))
    border-radius 6px

// Add Account wrap — onboarding shell
.addWalletWrap
  position absolute
  inset 0
  background rgb(3,5,15)
  display flex
  flex-direction column

.addWalletHeader
  padding 20px 20px 0
  text-align center

.addWalletTitle
  font-size 22px
  font-weight 500
  color rgb(224,242,254)
  margin-bottom 6px

.addWalletSubtitle
  font-size 13px
  color rgba(186,230,253,0.7)
  line-height 1.5

// Account type selection grid
.addWalletOptions
  display grid
  grid-template-columns 1fr 1fr
  gap 10px
  padding 20px

.addWalletOption
  background rgb(6,9,22)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 16px
  padding 20px 14px
  display flex
  flex-direction column
  align-items center
  gap 10px
  cursor pointer
  transition 0.25s cubic-bezier(0.4, 0, 0.2, 1) all
  text-align center

.addWalletOption:hover
  background rgba(14,165,233,0.06)
  border-color rgba(14,165,233,0.4)
  transform translateY(-2px)

.addWalletOptionActive
  background rgba(14,165,233,0.1)
  border-color rgba(14,165,233,0.5)

.addWalletOptionIcon
  width 44px
  height 44px
  border-radius 14px
  background rgba(14,165,233,0.1)
  border 1px solid rgba(14,165,233,0.2)
  display flex
  align-items center
  justify-content center
  color var(--good)

.addWalletOptionLabel
  font-size 13px
  font-weight 400
  color rgb(224,242,254)

.addWalletOptionDesc
  font-size 11px
  color rgba(186,230,253,0.4)
  line-height 1.5

// Form inputs
.addWalletInput
  background rgba(14,165,233,0.04)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 12px
  padding 12px 14px
  font-family 'MainFont'
  font-size 14px
  font-weight 300
  color rgb(224,242,254)
  width 100%
  outline none
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  -webkit-app-region no-drag

.addWalletInput:focus
  border-color rgba(14,165,233,0.4)

.addWalletInputCode
  font-family 'CodeFont'
  font-size 12px
  letter-spacing 0.04em

// Password strength indicator
.keyStrength
  height 4px
  border-radius 2px
  background var(--ghostD)
  margin-top 6px
  overflow hidden

.keyStrengthBar
  height 100%
  border-radius 2px
  transition 0.3s cubic-bezier(0.4, 0, 0.2, 1) all

.passwordStrengthWeak
  background var(--bad)
  width 25%

.passwordStrengthOk
  background var(--warning)
  width 50%

.passwordStrengthGood
  background var(--good)
  width 75%

.passwordStrengthStrong
  background linear-gradient(90deg, var(--goodShade), var(--good), var(--goodUp))
  width 100%

// Continue button
.addWalletContinue
  margin 16px 20px
  height 50px
  background linear-gradient(135deg, rgb(2,132,199), rgb(14,165,233))
  border none
  border-radius 14px
  color white
  font-family 'MainFont'
  font-size 15px
  font-weight 500
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  letter-spacing 0.02em

.addWalletContinue:hover
  transform translateY(-1px)

.addWalletContinue:disabled
  background var(--ghostD)
  color rgba(186,230,253,0.4)
  cursor not-allowed
  transform none

.addWalletItemPending
  .addAccountItemOptionIntro
    opacity 0
    pointer-events none
  .addAccountItemOptionSetup
    opacity 1
    pointer-events auto

.addWalletMainActive
  .addAccountMainInner
    .addWalletItem
      opacity 1
      transform translateY(0) scale(1)

.addWalletMainActive
  pointer-events auto
  opacity 1
  transform translateY(0px) scale(1) rotateY(0deg)
  transition-delay 0.00s

@import '../AddPhrase/style'
@import '../AddRing/style'

// ─── Add Wallet flow — global container classes ──────────────────────────────

.addWallets
  position absolute
  inset 0
  background transparent
  display flex
  flex-direction column
  z-index 100

.addWalletsHeader
  padding 14px 16px
  border-bottom 1px solid rgba(14,165,233,0.18)
  display flex
  align-items center
  justify-content space-between

.addWalletsHeaderTitle
  font-size 15px
  font-weight 500
  color rgb(224,242,254)

.addWalletCloseBtn
  width 30px
  height 30px
  border-radius 9px
  border 1px solid rgba(14,165,233,0.18)
  background transparent
  display flex
  align-items center
  justify-content center
  color rgba(186,230,253,0.7)
  cursor pointer
0.15s all

.addWalletCloseBtn:hover
  border-color rgba(244, 63, 94, 0.3)
  color var(--bad)

.addWalletSubmitBtn
  height 46px
  background linear-gradient(135deg, rgb(2,132,199), rgb(14,165,233))
  border-radius 12px
  display flex
  align-items center
  justify-content center
  color white
  font-size 14px
  font-weight 500
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

.addWalletSubmitBtn:hover
  transform translateY(-1px)

.panelBottomMenu
  padding 12px 14px
  border-top 1px solid rgba(14,165,233,0.18)
  display flex
  align-items center
  justify-content center
  gap 10px

.addAccountBreak
  border none
  border-top 1px solid rgba(14,165,233,0.18)
  margin 16px 0

.addAccountFooter
  display flex
  align-items center
  justify-content center
  padding 16px
  color rgba(14,165,233,0.3)

.addAccountMainInner
  flex 1
  overflow-y auto
  padding 16px 20px

.addAccountResolvingEns
  display flex
  align-items center
  gap 8px
  font-size 12px
  color rgba(186,230,253,0.7)
  padding 6px 0

.newAccountText
  font-size 13px
  color rgba(186,230,253,0.7)
  text-align center
  padding 14px 20px

// ─── Add Account Item UI (sub-components) ────────────────────────────────────

.addAccountItemWrap
  flex 1
  display flex
  flex-direction column
  overflow hidden
  background rgb(6,9,22)
  border-radius 16px

.addAccountItemTop
  padding 16px 20px 12px
  border-bottom 1px solid rgba(14,165,233,0.18)

.addAccountItemTopTitle
  font-size 18px
  font-weight 500
  color rgb(224,242,254)
  margin-bottom 4px

.addAccountItemTopType
  font-size 12px
  color rgba(186,230,253,0.7)
  letter-spacing 0.04em

.addAccountItemClose
  position absolute
  top 12px
  right 12px
  width 28px
  height 28px
  border-radius 8px
  border 1px solid rgba(14,165,233,0.18)
  display flex
  align-items center
  justify-content center
  cursor pointer
  color rgba(186,230,253,0.7)
0.15s all

.addAccountItemClose:hover
  border-color rgba(244, 63, 94, 0.3)
  color var(--bad)

.addAccountItemSummary
  background rgb(10,14,35)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 12px
  padding 12px 14px
  margin 12px 0
  font-size 13px
  color rgba(186,230,253,0.7)
  line-height 1.55

.addAccountItemFooter
  padding 12px 20px 20px
  border-top 1px solid rgba(14,165,233,0.18)

.addAccountItemBar
  height 3px
  background var(--ghostD)
  border-radius 2px
  overflow hidden
  margin 10px 0

.addAccountItemOption
  background rgb(10,14,35)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 14px
  padding 16px 12px
  display flex
  flex-direction column
  align-items center
  gap 10px
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  text-align center

.addAccountItemOption:hover
  border-color rgba(14,165,233,0.4)
  background rgba(14,165,233,0.06)
  transform translateY(-2px)

.addAccountItemOptionTitle
  font-size 12px
  font-weight 500
  color rgb(224,242,254)

.addAccountItemHot
  border-color rgba(251, 146, 60, 0.2)

.addAccountItemHardware
  border-color rgba(56, 189, 248, 0.2)

.addAccountItemDevice
  width 36px
  height 36px
  border-radius 11px
  background rgba(14,165,233,0.08)
  border 1px solid rgba(14,165,233,0.18)
  display flex
  align-items center
  justify-content center
  color var(--good)

.addAccountItemDeviceTitle
  font-size 12px
  color rgba(186,230,253,0.7)
  margin-top 4px

.addAccountItemDevices
  display flex
  flex-direction column
  gap 6px
  padding 0 20px

.addAccountItemMock
  height 50px
  border-radius 12px
  background rgb(10,14,35)
  border 1px solid rgba(14,165,233,0.18)

.addAccountItemOptionIntro
  font-size 12px
  color rgba(186,230,253,0.7)
  text-align center

.addAccountItemOptionSetup, .addAccountItemOptionSetupLightPay, .addAccountItemOptionSetupLightPays
  display flex
  flex-direction column
  gap 8px

.addAccountItemOptionInput
  background rgba(14,165,233,0.04)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 12px
  padding 11px 14px
  font-size 14px
  color rgb(224,242,254)
  outline none
  width 100%
  box-sizing border-box
  -webkit-app-region no-drag

.addAccountItemOptionInput:focus
  border-color rgba(14,165,233,0.4)

.addAccountItemOptionError
  font-size 11px
  color var(--bad)
  padding 2px 2px 0
