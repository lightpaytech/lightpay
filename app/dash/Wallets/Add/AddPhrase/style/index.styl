// LightPay VAULT — Add by Mnemonic Phrase

.addPhrase
  padding 20px
  display flex
  flex-direction column
  gap 14px

.addPhraseTitle
  font-size 18px
  font-weight 500
  color rgb(15, 23, 42)

.addPhraseTextarea
  background rgb(255, 255, 255)
  border 1px solid rgba(14, 165, 233, 0.30)
  border-radius 14px
  padding 18px 18px
  font-family 'CodeFont'
  font-size 16px
  font-weight 400
  color rgb(15, 23, 42)
  width 100%
  min-height 140px
  outline none
  resize none
  box-sizing border-box
  -webkit-app-region no-drag
  line-height 1.8
  letter-spacing 0.04em

.addPhraseTextarea:focus
  border-color rgba(14, 165, 233, 0.40)

.addPhraseTextarea::placeholder
  color rgba(15, 23, 42, 0.55)
  font-size 15px
  letter-spacing 0.02em

.addPhraseWordCount
  font-size 13px
  font-family 'CodeFont'
  color rgba(15, 23, 42, 0.4)
  text-align right

.addPhraseWordCountValid
  color rgb(14,165,233)

.addPhraseWarning
  background rgba(251, 146, 60, 0.08)
  border 1px solid rgba(251, 146, 60, 0.25)
  border-radius 10px
  padding 12px 16px
  font-size 13px
  color var(--warning)
  line-height 1.55

.addPhrasePassword
  background rgba(255, 255, 255, 0.04)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 12px
  padding 14px 16px
  font-size 16px
  font-weight 300
  color rgb(15, 23, 42)
  width 100%
  outline none
  box-sizing border-box
  -webkit-app-region no-drag
  letter-spacing 0.08em

.addPhrasePassword:focus
  border-color rgba(14, 165, 233, 0.40)

.addPhraseStrength
  height 3px
  border-radius 2px
  background var(--ghostD)
  overflow hidden

.addPhraseStrengthBar
  height 100%
  border-radius 2px

.addPhraseStrengthWeak
  background var(--bad)
  width 25%

.addPhraseStrengthFair
  background var(--warning)
  width 55%

.addPhraseStrengthStrong
  background rgb(14,165,233)
  width 100%
