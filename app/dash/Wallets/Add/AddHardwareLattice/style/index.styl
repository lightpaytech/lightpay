// LightPay VAULT — Add Lattice (GridPlus)

.addLattice
  padding 20px
  display flex
  flex-direction column
  gap 14px

.addLatticeTitle
  font-size 18px
  font-weight 500
  color rgb(15, 23, 42)

.addLatticeInput
  background rgb(255, 255, 255)
  border 1px solid rgba(14, 165, 233, 0.30)
  border-radius 12px
  padding 14px 16px
  font-family 'CodeFont'
  font-size 14px
  font-weight 400
  color rgb(15, 23, 42)
  width 100%
  outline none
  box-sizing border-box
  -webkit-app-region no-drag

.addLatticeInput:focus
  border-color rgba(14, 165, 233, 0.40)

.addLatticeNote
  font-size 11px
  color rgba(15, 23, 42, 0.4)
  line-height 1.55
  padding 8px 12px
  background rgba(255, 255, 255, 0.06)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 10px

.addLatticePairing
  font-family 'CodeFont'
  font-size 20px
  font-weight 400
  color rgb(14,165,233)
  letter-spacing 0.12em
  text-align center
  padding 20px
  background rgba(255, 255, 255, 0.04)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 14px
  user-select all
