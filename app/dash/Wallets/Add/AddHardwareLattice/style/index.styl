// LightPay VAULT — Add Lattice (GridPlus)

.addLattice
  padding 20px
  display flex
  flex-direction column
  gap 14px

.addLatticeTitle
  font-size 18px
  font-weight 500
  color rgb(224,242,254)

.addLatticeInput
  background rgba(14,165,233,0.04)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 12px
  padding 11px 14px
  font-family 'CodeFont'
  font-size 12px
  font-weight 400
  color rgb(224,242,254)
  width 100%
  outline none
  box-sizing border-box
  -webkit-app-region no-drag

.addLatticeInput:focus
  border-color rgba(14,165,233,0.4)

.addLatticeNote
  font-size 11px
  color rgba(186,230,253,0.4)
  line-height 1.55
  padding 8px 12px
  background rgba(14,165,233,0.06)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 10px

.addLatticePairing
  font-family 'CodeFont'
  font-size 20px
  font-weight 400
  color rgb(14,165,233)
  letter-spacing 0.12em
  text-align center
  padding 20px
  background rgba(14,165,233,0.04)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 14px
  user-select all
