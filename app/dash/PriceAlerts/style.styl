// LightPay — Price Alerts

.priceAlerts
  padding 16px
  background rgb(3,5,15)

.priceAlertsHeader
  display flex
  justify-content space-between
  align-items center
  margin-bottom 14px

.priceAlertsTitle
  font-size 13px
  font-weight 600
  color rgb(14,165,233)

.priceAlertsCount
  font-size 11px
  color rgba(186,230,253,0.4)
  background rgba(14,165,233,0.08)
  border 1px solid rgba(14,165,233,0.18)
  padding 2px 8px
  border-radius 10px

.alertForm
  background rgba(14,165,233,0.05)
  border 1px solid rgba(14,165,233,0.15)
  border-radius 8px
  padding 12px
  margin-bottom 12px

.alertFormTitle
  font-size 11px
  font-weight 600
  color rgba(14,165,233,0.7)
  text-transform uppercase
  letter-spacing 0.06em
  margin-bottom 8px

.alertInput
  width 100%
  background rgb(10,14,35)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 6px
  padding 7px 10px
  color rgba(186,230,253,0.7)
  font-size 12px
  margin-bottom 8px
  box-sizing border-box
  outline none
  transition all 0.15s ease
  &:focus
    outline none
    border-color rgba(14,165,233,0.4)
    background rgb(10,14,35)

.alertInputSmall
  width calc(50% - 4px)
  margin-bottom 0

.alertThresholds
  display flex
  gap 8px
  margin-bottom 10px

.alertThresholdGroup
  display flex
  flex-direction column
  gap 4px
  flex 1

.alertThresholdLabel
  font-size 10px
  color rgba(186,230,253,0.4)

.alertSubmit
  width 100%
  background rgb(14,165,233)
  color rgb(3,5,15)
  border none
  border-radius 6px
  padding 8px
  font-size 12px
  font-weight 600
  cursor pointer
  transition background 0.15s ease
  &:hover
    background rgb(56,189,248)

.alertItem
  display flex
  align-items center
  gap 8px
  padding 8px 10px
  background rgba(14,165,233,0.03)
  border 1px solid rgba(14,165,233,0.18)
  border-radius 6px
  margin-bottom 6px

.alertTriggered
  border-color rgba(34,197,94,0.4)
  background rgba(34,197,94,0.04)

.alertItemToken
  font-size 13px
  font-weight 700
  color rgba(186,230,253,0.7)
  min-width 40px

.alertAbove
  font-size 11px
  color rgb(34,197,94)

.alertBelow
  font-size 11px
  color rgb(239,68,68)

.alertTriggeredBadge
  font-size 10px
  font-weight 600
  color rgb(34,197,94)
  background rgba(34,197,94,0.1)
  border 1px solid rgba(34,197,94,0.25)
  padding 2px 8px
  border-radius 10px
  margin-left auto

.alertRemove
  background none
  border none
  cursor pointer
  color rgba(186,230,253,0.3)
  font-size 12px
  padding 2px 4px
  margin-left auto
  border-radius 3px
  transition color 0.1s ease
  &:hover
    color rgba(239,68,68,0.8)

.alertEmpty
  font-size 12px
  color rgba(186,230,253,0.3)
  text-align center
  padding 16px 0
