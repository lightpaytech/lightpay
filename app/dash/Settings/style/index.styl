// LightPay VAULT — Settings Screen

.prefSetting
  background var(--ghostB)
  border 1px solid rgba(14, 165, 233, 0.09)
  border-radius 14px
  overflow hidden
  margin-bottom 8px
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

.prefSetting:hover
  border-color rgba(14, 165, 233, 0.18)

.localSettings
  padding 14px
  display flex
  flex-direction column
  gap 0

.localSettingsWrap
  display flex
  flex-direction column
  gap 8px

// Setting row
.signerPermissionControls
  padding 13px 16px
  display flex
  align-items center
  gap 12px

.signerPermissionSetting
  flex 1
  font-size 13px
  font-weight 400
  color var(--outerspace08)
  position relative

.signerPermissionControls + .signerPermissionControls
  border-top 1px solid rgba(14, 165, 233, 0.06)

// Toggle switch
.signerPermissionToggle
  width 40px
  height 22px
  border-radius 11px
  flex-shrink 0
  position relative
  cursor pointer
  transition 0.22s cubic-bezier(0.4, 0, 0.2, 1) all

.signerPermissionToggle:after
  content ''
  position absolute
  top 3px
  width 16px
  height 16px
  border-radius 50%
  background white
  transition 0.22s cubic-bezier(0.4, 0, 0.2, 1) all

.signerPermissionToggleOff
  background var(--ghostD)

.signerPermissionToggleOff:after
  left 3px

.signerPermissionToggleOn
  background var(--good)
  border 1px solid rgba(14, 165, 233, 0.4)

.signerPermissionToggleOn:after
  left calc(100% - 19px)

// Shortcut configurator
.shortcutCmd
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.12)
  border-radius 10px
  padding 10px 14px
  font-family 'CodeFont'
  font-size 12px
  color var(--outerspace08)
  display flex
  align-items center
  gap 6px
  width fit-content

// Section headers
.settingsSectionTitle
  font-size 10px
  font-weight 500
  letter-spacing 0.1em
  text-transform uppercase
  color var(--outerspace04)
  padding 14px 16px 8px
  display block

// Dropdown in settings
.settingsDropdown
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.14)
  border-radius 10px
  padding 8px 12px
  font-size 13px
  color var(--outerspace08)
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  width 100%
  appearance none
  -webkit-appearance none
  outline none

.settingsDropdown:focus
  border-color rgba(14, 165, 233, 0.5)
  background rgba(14, 165, 233, 0.06)

// Input in settings
.settingsInput
  background rgba(14, 165, 233, 0.04)
  border 1px solid rgba(14, 165, 233, 0.15)
  border-radius 10px
  padding 9px 12px
  font-family 'CodeFont'
  font-size 12px
  color var(--outerspace)
  width 100%
  outline none
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  box-sizing border-box
  -webkit-app-region no-drag

.settingsInput:focus
  border-color rgba(14, 165, 233, 0.5)
  background rgba(14, 165, 233, 0.06)

// Reset button (dangerous)
.settingsResetBtn
  width 100%
  height 44px
  border-radius 12px
  border 1px solid rgba(255, 75, 100, 0.25)
  background transparent
  color var(--bad)
  font-size 13px
  font-weight 400
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  display flex
  align-items center
  justify-content center
  gap 8px
  margin-top 8px

.settingsResetBtn:hover
  background rgba(255, 75, 100, 0.07)
  border-color rgba(255, 75, 100, 0.5)

// Confirm reset state
.settingsResetConfirm
  display flex
  gap 8px
  margin-top 8px

.settingsResetConfirmYes
  flex 1
  height 40px
  background rgba(255, 75, 100, 0.12)
  border 1px solid rgba(255, 75, 100, 0.4)
  border-radius 10px
  color var(--bad)
  font-size 13px
  font-weight 500
  cursor pointer
  display flex
  align-items center
  justify-content center
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

.settingsResetConfirmNo
  flex 1
  height 40px
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.1)
  border-radius 10px
  color var(--outerspace07)
  font-size 13px
  cursor pointer
  display flex
  align-items center
  justify-content center
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
