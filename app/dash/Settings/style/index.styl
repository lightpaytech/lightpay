// LightPay VAULT — Settings Screen

.localSettings
  padding 18px 16px 80px 16px
  display flex
  flex-direction column
  gap 0
  position relative
  z-index 10

.localSettings .localSettingsWrap
  display flex
  flex-direction column
  gap 0

.localSettings .prefSetting
  background rgb(255, 255, 255)
  border 1px solid rgba(14, 165, 233, 0.22)
  border-radius 14px
  overflow visible
  margin-bottom 10px
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  padding 14px 16px

.localSettings .prefSetting:hover
  border-color rgba(14, 165, 233, 0.40)

.localSettings .prefSetting .signerPermissionControls
  padding 0 0 4px 0
  display flex
  align-items center
  gap 12px
  min-height 28px
  justify-content space-between

.localSettings .prefSetting .signerPermissionSetting
  flex 1
  font-size 14px
  font-weight 500
  color rgb(15, 23, 42)
  position relative

.localSettings .prefSetting .signerPermissionDetails
  font-size 12px
  font-weight 300
  color rgba(15, 23, 42, 0.65)
  line-height 1.5
  padding-top 6px
  display block

// Toggle switch
.signerPermissionToggle
  width 44px
  height 24px
  border-radius 12px
  flex-shrink 0
  position relative
  cursor pointer
  transition 0.22s cubic-bezier(0.4, 0, 0.2, 1) all
  border 1px solid rgba(14, 165, 233, 0.22)
  box-sizing border-box
  padding 0

.signerPermissionToggle:after
  content ''
  position absolute
  top 50%
  width 18px
  height 18px
  border-radius 50%
  background rgb(255, 255, 255)
  box-shadow 0 1px 3px rgba(15, 23, 42, 0.20), 0 0 0 1px rgba(15, 23, 42, 0.05)
  transition 0.22s cubic-bezier(0.4, 0, 0.2, 1) all
  transform translateY(-50%)

.signerPermissionToggleOff
  background rgb(224, 235, 252)

.signerPermissionToggleOff:after
  left 2px

.signerPermissionToggleOn
  background rgb(14, 165, 233)
  border-color rgb(14, 165, 233)

.signerPermissionToggleOn:after
  left calc(100% - 20px)
  box-shadow 0 1px 4px rgba(15, 23, 42, 0.28), 0 0 0 1px rgba(15, 23, 42, 0.05)

.signerPermissionToggle:hover
  border-color rgba(14, 165, 233, 0.50)

.signerPermissionToggleOn:hover
  background rgb(2, 132, 199)
  border-color rgb(2, 132, 199)

// Shortcut configurator
.shortcutCmd
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.12)
  border-radius 10px
  padding 10px 14px
  font-family 'CodeFont'
  font-size 12px
  color var(--outerspace08)
  display flex
  align-items center
  gap 6px
  width fit-content

// Section headers
.settingsSectionTitle
  font-size 10px
  font-weight 500
  letter-spacing 0.1em
  text-transform uppercase
  color var(--outerspace04)
  padding 14px 16px 8px
  display block

// Dropdown in settings
.settingsDropdown
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.14)
  border-radius 10px
  padding 8px 12px
  font-size 13px
  color var(--outerspace08)
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  width 100%
  appearance none
  -webkit-appearance none
  outline none

.settingsDropdown:focus
  border-color rgba(14, 165, 233, 0.50)
  background rgba(255, 255, 255, 0.06)

// Input in settings
.settingsInput
  background rgb(255, 255, 255)
  border 1px solid rgba(14, 165, 233, 0.30)
  border-radius 10px
  padding 13px 14px
  font-family 'CodeFont'
  font-size 14px
  color var(--outerspace)
  width 100%
  outline none
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  box-sizing border-box
  -webkit-app-region no-drag

.settingsInput:focus
  border-color rgba(14, 165, 233, 0.50)
  background rgb(255, 255, 255)

// Reset button (dangerous)
.settingsResetBtn
  width 100%
  height 44px
  border-radius 12px
  border 1px solid rgba(255, 75, 100, 0.25)
  background transparent
  color var(--bad)
  font-size 13px
  font-weight 400
  cursor pointer
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  display flex
  align-items center
  justify-content center
  gap 8px
  margin-top 8px

.settingsResetBtn:hover
  background rgba(255, 75, 100, 0.07)
  border-color rgba(255, 75, 100, 0.5)

// Confirm reset state
.settingsResetConfirm
  display flex
  gap 8px
  margin-top 8px

.settingsResetConfirmYes
  flex 1
  height 40px
  background rgba(255, 75, 100, 0.12)
  border 1px solid rgba(255, 75, 100, 0.4)
  border-radius 10px
  color var(--bad)
  font-size 13px
  font-weight 500
  cursor pointer
  display flex
  align-items center
  justify-content center
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all

.settingsResetConfirmNo
  flex 1
  height 40px
  background var(--ghostC)
  border 1px solid rgba(14, 165, 233, 0.10)
  border-radius 10px
  color var(--outerspace07)
  font-size 13px
  cursor pointer
  display flex
  align-items center
  justify-content center
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
