// ─── Token List Container ─────────────────────────────────────────────────────

.tokenList
  padding 14px
  display flex
  flex-direction column
  gap 8px

// ─── Individual Token Row ─────────────────────────────────────────────────────

.tokenRow
  background rgb(240, 245, 255)
  border-bottom 1px solid rgba(14, 165, 233, 0.18)
  border-radius 14px
  padding 12px 14px
  display flex
  align-items center
  gap 12px
  transition 0.25s cubic-bezier(0.4, 0, 0.2, 1) all

.tokenRow:hover
  border-color rgba(14, 165, 233, 0.40)
  background rgba(255, 255, 255, 0.05)

// ─── Token Icon ───────────────────────────────────────────────────────────────

.tokenIcon
  width 36px
  height 36px
  border-radius 50%
  overflow hidden
  background rgb(224, 235, 252)
  border 1px solid rgba(14, 165, 233, 0.18)
  flex-shrink 0

  img
    width 100%
    height 100%
    object-fit cover

// ─── Token Info ───────────────────────────────────────────────────────────────

.tokenInfo
  flex 1
  min-width 0

.tokenName
  font-size 13px
  font-weight 400
  color rgb(15, 23, 42)
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.tokenSymbol
  font-family 'CodeFont'
  font-size 11px
  color rgba(15, 23, 42, 0.7)
  letter-spacing 0.06em
  text-transform uppercase

.tokenChain
  font-size 11px
  color rgba(15, 23, 42, 0.7)
  margin-top 2px

// ─── Token Price ──────────────────────────────────────────────────────────────

.tokenPricePositive
  color rgb(0, 230, 180)

.tokenPriceNegative
  color rgb(255, 75, 100)

// ─── Remove Button ────────────────────────────────────────────────────────────

.tokenRemove
  width 28px
  height 28px
  border-radius 8px
  border 1px solid rgba(244, 63, 94, 0.2)
  background transparent
  color var(--bad)
  display flex
  align-items center
  justify-content center
  cursor pointer
  flex-shrink 0
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  *
    pointer-events none

.tokenRemove:hover
  background rgba(244, 63, 94, 0.08)
  border-color rgba(244, 63, 94, 0.5)

@import '../AddToken/style'
@import '../CustomTokens/style'
