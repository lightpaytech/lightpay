.displayValue
  display inline-flex
  justify-content center
  align-items center
  font-family 'CodeFont'
  color rgb(15, 23, 42)

  span
    padding 0
    margin 0

  .displayValueApprox
    font-weight 600
    font-size 0.9em

  .displayValueFiat
    font-weight 600
    font-size 0.8em
    padding 0em 0.2em

  .displayValueSymbol
    padding 0em 0.2em 0em 0.2em

  .displayValueUnit
    font-weight 600
    padding 0em 0em 0em 0.2em

// Positive value: electric green
.displayValuePositive
  color rgb(0, 230, 180)

// Negative value: electric red
.displayValueNegative
  color rgb(255, 75, 100)

// Zero / muted value
.displayValueZero
  color rgba(15, 23, 42, 0.4)
