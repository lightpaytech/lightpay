@keyframes lit
  0%
    opacity 1
  80%
    opacity 1
  100%
    opacity 0.5

@keyframes wave
  0%
    transform translateX(0)
  100%
    transform translateX(16px)

.actionItem
  cursor pointer
  position relative
  width 100%
  z-index 1
  overflow hidden
  font-family 'MainFont'
  font-weight 300
  margin-top 3px
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) all
  background rgb(6,9,22)
  border-bottom 1px solid rgba(14,165,233,0.08)
  border-radius 12px

.actionItem::after
  position absolute
  content ''
  top 0
  bottom 0
  left 0
  right 0
  z-index 20
  border-radius 12px
  opacity 1
  pointer-events none

.actionItem:hover
  transform translateY(-1px)
  position relative
  z-index 300000
  background rgba(14,165,233,0.04)
  border-color rgba(14,165,233,0.18)

  .clusterValue
    background rgb(6,9,22) !important

.actionItem:active
  transform translateY(0px)
  position relative
  z-index 300000
  background rgba(14,165,233,0.04)

.actionItem:first-child
  border-radius 16px
  border-bottom-left-radius 8px
  border-bottom-right-radius 8px

.actionItem:last-child
  border-radius 16px
  border-top-left-radius 8px
  border-top-right-radius 8px

.actionItem:first-child:last-child
  border-radius 16px

.requestItemBackground
  position absolute
  top 0px
  left 0px
  right 0px
  bottom 0
  border-radius 1.5px
  background linear-gradient(90deg, transparent 0%, transparent 100%)
  opacity 0.05
  z-index 200
  border-radius 18px
  display none

.requestItemCorner
  position absolute
  top -420px
  left -120px
  width 460px
  height 460px
  transform rotate(65deg)
  border-radius 6px
  opacity 0

.requestItemNotice
  position relative
  display flex
  align-items center
  justify-content center
  text-transform uppercase
  font-weight 400
  font-size 11px
  margin 14px
  letter-spacing 1px
  border-top 1px solid rgba(14,165,233,0.1)
  padding 12px 12px 0px 12px

.requestItemNoticeGood
  color rgb(0, 230, 180)

.requestItemNoticeBad
  color rgb(255, 75, 100)

.requestItemDetails
  position relative
  display flex
  align-items center
  justify-content space-between
  font-weight 400
  font-size 11px
  letter-spacing 1px
  width 100px
  height 30px

  span
    letter-spacing 1px
    padding-left 8px
    top -1px
    position relative

.requestItemDetailsIndicatorStill
  .requestItemDetailsIndicatorMarker
    animation none

.requestItemDetailsView
  display flex
  justify-content center
  align-items center
  margin-right 2px

  .requestItemDetailsViewText
    font-weight 400
    margin-right 0px
  .requestItemDetailsViewArrow
    display flex
    justify-content center
    align-items center
    div
      width 8px
    svg
      transform rotate(90deg)

.requestItemDetailsGood
  .requestItemLine
    color rgb(0, 230, 180)
  .requestItemLineShadow
    color rgba(14,165,233,0.1)
  .requestItemDetailsIndicator
    .requestItemDetailsIndicatorMarker
      background rgb(0, 230, 180)

.requestItemDetailsBad
  .requestItemLine
    color rgb(255, 75, 100)
  .requestItemLineShadow
    color rgba(255, 75, 100, 0.1)
  .requestItemDetailsIndicator
    .requestItemDetailsIndicatorMarker
      background rgb(255, 75, 100)

.requestItemRow
  position relative
  z-index 3
  width 100%
  display flex
  align-items center
  margin-bottom 10px
  box-sizing border-box

  .requestItemRowIcon
    width 40px
    height 20px
    display flex
    justify-content center
    align-items center
    position relative

  .requestItemRowIconLarge
    width 40px
    height 20px
    display flex
    justify-content center
    align-items center

  .requestItemRowChainIcon
    position absolute
    top 0px
    right 20px
    bottom 0px
    display flex
    justify-content center
    align-items center
    width 20px
    border-radius 10px

  .requestItemRowTitle
    position relative
    margin-left 9px
    font-size 12px
    font-weight 400

  .requestItemRowTitleLarge
    position relative
    font-weight 300
    display flex
    justify-content center
    align-items center

.requestItemLine
  position absolute
  top 0px
  right 0px
  bottom 0px
  left 0px
  margin 0px
  box-sizing border-box
  display flex
  overflow hidden
  opacity 1
  padding 10.5px 0px
  border-radius 20px
  background rgba(14,165,233,0.05)
  color rgb(56,189,248)
  display none

  svg
    width 200%
    position relative
    left -100%
    stroke-width 20px
    animation wave 1.4s linear infinite
    will-change transform

.requestItemLineShadow
  background none
  color rgba(14,165,233,0.1)
  display none

  svg
    bottom -2px

.requestItemIcon
  width 32px
  height 32px
  overflow hidden
  display flex
  justify-content center
  align-items center
  border-radius 12px
  border 1px solid rgba(14,165,233,0.14)
  z-index 2
  -webkit-app-region no-drag
  transition none
  pointer-events auto
  transform translate3d(0, 0, 0)

.requestItemTitle
  position relative
  font-family 'MainFont'
  font-weight 400
  display flex
  justify-content space-between
  align-items center
  font-size 16px
  font-weight 300
  padding 15px 12px 6px 12px
  overflow hidden

  .requestItemTitleTime
    position absolute
    top 12px
    right 18px
    bottom 3px
    display flex
    justify-content center
    align-items center
    z-index 3000

    .requestItemTitleTimeItem
      height 26px
      display flex
      justify-content center
      align-items center
      font-size 13px
      font-weight 400
      color rgb(14,165,233)

  .requestItemMain
    margin-top 1px
    display flex
    justify-content flex-start
    flex-direction column
    box-sizing border-box

    .requestItemTitleMain
      white-space nowrap
      overflow hidden
      text-overflow ellipsis

  .requestItemTitleLeft
    display flex
    justify-content flex-start
    align-items center
    box-sizing border-box
    margin-left 0px

  .requestItemTitleMain
    font-weight 400
    margin-left 8px

.requestItemTitleSub
  display flex
  justify-content flex-start
  align-items center
  font-size 11px
  font-weight 300

  .requestItemTitleSubIcon
    margin 1px 9px 0px -5px
    color rgb(224,242,254)

  .requestItemTitleSubText
    font-weight 400
    margin 0px 0px 0px 0px

.requestItemSource
  position absolute
  top 0px
  right 20px
  bottom 0px
  font-size 12px
  font-weight 400
  display flex
  justify-content center
  align-items center
  margin-top -2px

  div
    margin-right 5px
  svg
    position relative
    top 1px

.requestItemOrigin
  top 16px
  right 16px
  position absolute
  font-weight 300
  margin-left 2px
  display flex
  align-items center
  font-size 10px
  margin-top 3px

  .requestItemOriginIcon
    position relative
    top -1px
    display flex
    justify-content center
    align-items center

.requestItemStatus
  font-size 10px
  bottom 16px
  left 64px
  position absolute
  font-weight 300
  margin-left 2px

.requestItemRight
  width 64px
  display flex
  justify-content center
  align-items center
  transform scaleX(-1)
  position relative
  left 1px

.requestItemDetailsSlide
  display flex
  align-items center
  text-transform uppercase
  font-size 10px
  font-weight 500
  padding-left 6px
  letter-spacing 1px
  padding-top 4px

.requestItemWave
  display absolute
  top 0
  left 0
  bottom 0
  left 0

.requestItemWaveDisabled
  .requestItemLine
    svg
      animation-play-state paused

.requestItemDetailsIndicator
  height 12px
  width 12px
  display flex
  justify-content center
  align-items center
  border-radius 6px
  margin-right 4px

  .requestItemDetailsIndicatorMarker
    height 6px
    width 6px
    border-radius 3px
    background rgb(14,165,233)
    z-index 4
    position relative
    top 0px
    animation lit infinite ease-in-out alternate 1s
    will-change opacity

.requestItemSummary
  display flex
  justify-content center
  align-items center
  padding 8px 16px 18px 16px
  font-size 12px
  font-weight 500

.requestItemHeader, .requestItemHeader:hover, .requestItemHeader:active
  background none
  border-bottom none
  transform none
  margin-top 0px
  margin-bottom 0px
  pointer-events none
