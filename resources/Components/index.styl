// ─── VAULT Component System ─────────────────────────────────────

// Global border-box sizing
*, *::before, *::after
  box-sizing border-box

// Vault card style (reusable)
.vaultCard
  background rgb(240, 245, 255)
  border 1px solid rgba(14, 165, 233, 0.18)
  border-radius 16px
  transition var(--standard)

.vaultCard:hover
  border-color rgba(14, 165, 233, 0.40)

// Vault button style (reusable)
.vaultBtn
  border-radius 10px
  padding 10px 18px
  font-family 'MainFont'
  font-weight 400
  font-size 14px
  letter-spacing 0.01em
  transition var(--standardFast)
  cursor pointer

// Vault pill statusIndicator
.vaultPill
  display inline-flex
  align-items center
  padding 3px 10px
  border-radius 20px
  font-size 11px
  font-weight 400
  letter-spacing 0.03em

// Vault input style
.vaultInput
  background rgb(255, 255, 255)
  border 1px solid rgba(14, 165, 233, 0.30)
  border-radius 10px
  color rgb(15, 23, 42)
  font-family 'MainFont'
  font-weight 300
  transition var(--standardFast)
  outline none

.vaultInput:focus
  border-color rgba(14, 165, 233, 0.40)

// Electric blue separator
.vaultSeparator
  height 1px
  background linear-gradient(90deg, transparent, rgba(14,165,233,0.2), transparent)
  margin 8px 0

@import './Dropdown/'
@import './Confirm/'
@import './RingIcon/'
@import './RequestItem/style'
@import './FooterAux/style'
@import './Monitor/style'
@import './Cluster/style'
@import './DisplayValue/style'
