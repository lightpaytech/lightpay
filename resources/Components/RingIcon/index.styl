.ringIcon
  height 33px
  width 33px
  border-radius 50%
  position relative
  -webkit-app-region no-drag
  transition 0.2s cubic-bezier(0.4, 0, 0.2, 1) border-color
  pointer-events auto
  transform translate3d(0, 0, 0)
  border 2px solid rgba(14, 165, 233, 0.25)
  background rgb(240, 245, 255)

  *
    pointer-events none

  .ringIconInner
    position absolute
    top 3px
    right 3px
    bottom 3px
    left 3px
    border-radius 50%
    display flex
    justify-content center
    align-items center
    background rgb(248, 250, 255)
    overflow hidden
    color rgb(15, 23, 42)

    img
      object-fit cover
      max-height 31px
      min-height 31px
      max-width 31px
      min-width 31px
      border-radius 50%

// Active / selected state: electric blue ring
.ringIconActive
  border-color rgba(14, 165, 233, 0.15)

.ringIconSmall
  height 23px
  width 23px
  border-radius 50%
  border 2px solid rgba(14, 165, 233, 0.25)

  .ringIconInner
    position absolute
    top 2px
    right 2px
    bottom 2px
    left 2px
    border-radius 50%

    img
      object-fit cover
      max-height 19px
      min-height 19px
      max-width 19px
      min-width 19px
      border-radius 50%

.ringIconNoRing
  border 0px solid transparent
  background transparent
  border-radius 0px

  .ringIconInner
    background transparent
    border-radius 0px
