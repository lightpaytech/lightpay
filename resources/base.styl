.dark
  --v #0e2040
  --outerspace01 rgba(14, 165, 233, 0.1)
  --outerspace02 rgba(14, 165, 233, 0.2)
  --outerspace03 rgba(14, 165, 233, 0.3)
  --outerspace04 rgba(14, 165, 233, 0.4)
  --outerspace05 rgba(14, 165, 233, 0.5)
  --outerspace06 rgba(14, 165, 233, 0.6)
  --outerspace07 rgba(14, 165, 233, 0.7)
  --outerspace08 rgba(14, 165, 233, 0.8)
  --outerspace09 rgba(14, 165, 233, 0.9)
  --outerspace rgb(224, 242, 254)
  --nebula #04080f

  --outerspaceLight #080c1a
  --outerspacePulse #060a15
  --outerspacePhase rgba(3, 5, 15, 1)
  --outerspaceShader rgb(1, 2, 8)
  --outerspaceDark #010208
  --spacewhite rgba(6, 9, 22, 1)

  // Dark ghost scale (deep dark tone steps)
  --ghostX09 rgba(2, 3, 10, 0.9)
  --ghostX04 rgba(2, 3, 10, 0.4)
  --ghostX rgba(2, 3, 10, 1)
  --ghostY rgba(3, 5, 15, 1)
  --ghostZ0 rgba(6, 9, 22, 0)
  --ghostZ05 rgba(6, 9, 22, 0.5)
  --ghostZ08 rgba(6, 9, 22, 0.8)
  --ghostZ rgba(6, 9, 22, 1)
  --ghostAZ rgba(8, 12, 28, 1)
  --ghostA05 rgba(8, 12, 28, 0.5)
  --ghostA rgba(8, 12, 28, 1)
  --ghostB0 rgba(10, 14, 35, 0)
  --ghostB05 rgba(10, 14, 35, 0.2)
  --ghostB rgba(10, 14, 35, 1)
  --ghostC0 rgba(15, 20, 48, 0)
  --ghostC rgba(15, 20, 48, 1)
  --ghostD rgba(20, 28, 60, 1)

  --moon rgba(248, 113, 113, 1)
  --moonOver rgba(80, 10, 10, 1)

  ::selection
    background-color rgba(14, 165, 233, 0.3)
    color var(--text0)

  --overlayA rgba(3, 5, 15, 0.05)
  --overlayB rgba(14, 165, 233, 0.04)

  --thinner rgba(0, 0, 8, .1)
  --thin rgba(0, 0, 8, .2)
  --thick rgba(0, 0, 8, .3)
