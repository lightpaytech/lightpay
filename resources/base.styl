  // Light accent overrides
  --accent1 rgb(2, 132, 199)
  --accent2 rgb(202, 138, 4)
  --accent3 rgb(14, 165, 233)
  --accent4 rgb(185, 28, 28)
  --accent5 rgb(22, 163, 74)
  --accent6 rgb(7, 89, 133)
  --accent7 rgb(14, 165, 233)
  --accent8 rgb(2, 132, 199)
  --mint rgb(22, 163, 74)
