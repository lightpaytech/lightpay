// ─── LightPay accent palette ─────────────────────────────────

.light, .dark
  /* LightPay accent palette */
  --accentPrimary var(--electric)
  --accentLight var(--electricBright)
  --accentDark var(--electricDark)
  --accentGlow var(--electricGlow)
  --surfacePrimary var(--bg0)
  --surfaceSecondary var(--bg2)

// ─── Card animation ──────────────────────────────────────────

@keyframes vaultCardShow
  0%
    opacity 0
    transform translateY(10px) scale(0.98)
  55%
    opacity 1
    transform translateY(-1px) scale(1.001)
  100%
    opacity 1
    transform translateY(0) scale(1)

.vaultCardShow
  z-index 3000001
  animation vaultCardShow 320ms cubic-bezier(0.4, 0, 0.2, 1) both
  animation-delay 0s

.vaultCardHide
  opacity 0
  pointer-events none

// ─── Glitch effects ──────────────────────────────────────────

.distort
  position absolute
  top 0
  right 0
  bottom 0
  left 0
  display flex
  justify-content center
  align-items center
  color var(--outerspace)

.line
  display none

.lastLine
  display block
  opacity 1

.distortOn
  .line
    display block
    will-change clip-path
  .line:not(:first-child)
    position absolute
  .line:nth-child(1)
    animation clip 3000ms -300ms linear infinite, glitch1 1000ms -228ms linear infinite
  .line:nth-child(2)
    animation clip 3000ms -600ms linear infinite, glitch2 1000ms -927ms linear infinite

// ─── Utility ─────────────────────────────────────────────────

.suspend
  *
    animation-play-state paused !important

.clip
  *
    transition none !important

@import './Native/style'
@import './Components'

// ─── LightPay card / badge / divider utilities ────────────────

.lightpayCard
  background var(--bg2)
  border 1px solid var(--electricBorder)
  border-radius 10px
  padding 14px

.lightpayBadge
  display inline-flex
  align-items center
  gap 4px
  padding 2px 8px
  border-radius 10px
  font-size 10px
  font-weight 600
  text-transform uppercase
  letter-spacing 0.05em

.lightpayBadgePrimary
  background rgba(14, 165, 233, 0.1)
  color var(--electric)
  border 1px solid rgba(14, 165, 233, 0.2)

.lightpayBadgeSuccess
  background var(--good01)
  color var(--good)
  border 1px solid rgba(34, 197, 94, 0.3)

.lightpayBadgeWarn
  background var(--warnFaint)
  color var(--warn)

.lightpayDivider
  width 100%
  height 1px
  background linear-gradient(90deg, transparent 0%, rgba(14, 165, 233, 0.25) 50%, transparent 100%)
  margin 8px 0

// ─── LP utility classes ───────────────────────────────────────

.lpCard
  background var(--bg2)
  border 1px solid var(--electricBorder)
  border-radius 8px

.lpCardActive
  border-color rgba(56, 189, 248, 0.55)
  background var(--bg3)

.lpNeonText
  color var(--electric)
  font-weight 600

.lpLightningBorder
  border 1px solid rgba(14, 165, 233, 0.3)
  animation lightningPulse 3s ease-in-out infinite

.lpGlowBorder
  border 1px solid rgba(56, 189, 248, 0.55)

.lpDivider
  width 100%
  height 1px
  background linear-gradient(90deg, transparent 0%, var(--electric) 50%, transparent 100%)
  opacity 0.25
  margin 6px 0

.lpBadge
  display inline-flex
  align-items center
  padding 2px 8px
  border-radius 10px
  font-size 10px
  font-weight 600
  letter-spacing 0.05em

.lpBadgePrimary
  background rgba(14, 165, 233, 0.1)
  color var(--electric)
  border 1px solid rgba(14, 165, 233, 0.2)

.lpBadgeSuccess
  background var(--good01)
  color var(--good)
  border 1px solid rgba(34, 197, 94, 0.3)

.lpBadgeWarn
  background var(--warnFaint)
  color var(--warn)

.lpBadgeDanger
  background var(--badFaint)
  color var(--bad)
  border 1px solid rgba(239, 68, 68, 0.3)

// ─── Keyframes ───────────────────────────────────────────────

@keyframes lightningPulse
  0%, 100%
    border-color rgba(14, 165, 233, 0.2)
  50%
    border-color rgba(56, 189, 248, 0.6)

@keyframes electricFlicker
  0%, 95%, 100%
    opacity 1
  96%
    opacity 0.85
  97%
    opacity 1
  98%
    opacity 0.9

@keyframes boltStrike
  0%
    transform scaleX(0)
    opacity 0
  50%
    opacity 1
  100%
    transform scaleX(1)
    opacity 0.6

@keyframes electricGlow
  0%, 100%
    filter brightness(1)
  50%
    filter brightness(1.2)

@keyframes lightpayFadeIn
  from
    opacity 0
    transform translateY(-4px)
  to
    opacity 1
    transform translateY(0)

@keyframes lightpaySlideIn
  from
    opacity 0
    transform translateX(-8px)
  to
    opacity 1
    transform translateX(0)

@keyframes spin
  from
    transform rotate(0deg)
  to
    transform rotate(360deg)

@keyframes networkPulse
  0%, 100%
    opacity 1
  50%
    opacity 0.4

@keyframes lightningStrike
  0%
    opacity 0
  10%
    opacity 1
  20%
    opacity 0.3
  30%
    opacity 1
  100%
    opacity 0

@keyframes vaultPulse
  0%, 100%
    opacity 0.6
  50%
    opacity 1

@keyframes vaultSlide
  0%
    opacity 0
    transform translateY(12px) scale(0.97)
  60%
    opacity 1
    transform translateY(-2px) scale(1.002)
  100%
    opacity 1
    transform translateY(0) scale(1)

@keyframes vaultFadeIn
  0%
    opacity 0
  100%
    opacity 1

@keyframes spinnerRing
  0%
    transform rotate(0deg)
  100%
    transform rotate(360deg)

@keyframes shake
  0%
    transform translate3d(0px, 0px, 0)
  25%
    transform translate3d(-2px, -1px, 0)
  50%
    transform translate3d(2px, 1px, 0)
  75%
    transform translate3d(-1px, 0px, 0) rotate(0.5deg)
  100%
    transform translate3d(1px, -1px, 0) rotate(-0.5deg)

@keyframes glitch1
  0%
    transform translateX(0)
  80%
    transform translateX(0)
    color var(--outerspace)
  85%
    transform translateX(-3px)
    color var(--good)
  90%
    transform translateX(0px)
    color var(--bad)
  95%
    transform translateX(3px)
    color var(--outerspace)
  100%
    transform translateX(0)

@keyframes glitch2
  0%
    transform translateX(0)
  80%
    transform translateX(0)
    color var(--outerspace)
  85%
    transform translateX(5px)
    color var(--good)
  90%
    transform translateX(5px)
    color var(--bad)
  95%
    transform translateX(3px)
    color var(--outerspace)
  100%
    transform translateX(0)

@keyframes clip
  0%
    clip-path polygon(0 100%, 100% 100%, 100% 120%, 0 120%)
  100%
    clip-path polygon(0 -20%, 100% -20%, 100% 0%, 0 0)
