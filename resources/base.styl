// ============================================================
// LightPay Electric Blue Lightning Theme
// Deep Space × Electric Blue × Lightning Strike
// ============================================================

// ─── SpaceMono (accent/decorative mono) ──────────────────────
@font-face
  font-family 'AccentFont'
  font-weight 400 700
  src url('/resources/fonts/SpaceMono/SpaceMono-Regular.woff2') format('woff2')

// ─── JetBrains Mono (code/addresses) ─────────────────────────
@font-face
  font-family 'CodeFont'
  font-weight 300
  src url('/resources/fonts/JetBrainsMono/JetBrainsMono-Light.woff2') format('woff2')

@font-face
  font-family 'CodeFont'
  font-weight 400
  src url('/resources/fonts/JetBrainsMono/JetBrainsMono-Regular.woff2') format('woff2')

@font-face
  font-family 'CodeFont'
  font-weight 500
  src url('/resources/fonts/JetBrainsMono/JetBrainsMono-Medium.woff2') format('woff2')

@font-face
  font-family 'CodeFont'
  font-weight 700
  src url('/resources/fonts/JetBrainsMono/JetBrainsMono-Bold.woff2') format('woff2')

// ─── Inter (UI text) ─────────────────────────────────────────
@font-face
  font-family 'MainFont'
  font-weight 300
  src url('/resources/fonts/Inter/Inter-Light.woff2') format('woff2')

@font-face
  font-family 'MainFont'
  font-weight 400
  src url('/resources/fonts/Inter/Inter-Regular.woff2') format('woff2')

@font-face
  font-family 'MainFont'
  font-weight 500
  src url('/resources/fonts/Inter/Inter-Medium.woff2') format('woff2')

@font-face
  font-family 'MainFont'
  font-weight 700
  src url('/resources/fonts/Inter/Inter-Bold.woff2') format('woff2')

// ─── CSS Design Tokens ───────────────────────────────────────

:root
  /* ── LightPay Electric Blue Lightning Theme ── */
  --bg0            rgb(3, 5, 15)
  --bg1            rgb(6, 9, 22)
  --bg2            rgb(10, 14, 35)
  --bg3            rgb(15, 20, 48)
  --bg4            rgb(20, 28, 60)

  --electric       rgb(14, 165, 233)
  --electricBright rgb(56, 189, 248)
  --electricDark   rgb(2, 132, 199)
  --electricFaint  rgba(14, 165, 233, 0.08)
  --electricGlow   rgba(14, 165, 233, 0.18)
  --electricBorder rgba(14, 165, 233, 0.2)
  --electricFocus  rgba(14, 165, 233, 0.45)

  --bolt           rgb(250, 204, 21)
  --boltFaint      rgba(250, 204, 21, 0.12)

  --lightning      rgb(125, 211, 252)
  --lightningFaint rgba(125, 211, 252, 0.08)

  --text0          rgb(224, 242, 254)
  --text1          rgba(186, 230, 253, 0.75)
  --text2          rgba(186, 230, 253, 0.45)
  --text3          rgba(186, 230, 253, 0.22)

  --good           rgb(34, 197, 94)
  --goodFaint      rgba(34, 197, 94, 0.12)
  --good0          rgba(34, 197, 94, 0)
  --good01         rgba(34, 197, 94, 0.1)
  --good02         rgba(34, 197, 94, 0.2)
  --good04         rgba(34, 197, 94, 0.4)
  --goodUp         rgb(74, 222, 128)
  --goodDark       rgb(22, 163, 74)
  --goodShade      rgb(21, 128, 61)
  --goodHighlight  rgba(74, 222, 128, 0.15)
  --goodOver       rgba(0, 60, 30, 1)

  --bad            rgb(239, 68, 68)
  --badFaint       rgba(239, 68, 68, 0.12)
  --badUp          rgb(248, 113, 113)
  --badDark        rgb(185, 28, 28)

  --warn           rgb(251, 191, 36)
  --warnFaint      rgba(251, 191, 36, 0.12)

  --hardware       rgba(125, 211, 252, 1)
  --hardware2      rgba(186, 230, 253, 1)
  --smart          rgba(56, 189, 248, 1)
  --smart04        rgba(56, 189, 248, 0.4)
  --smart02        rgba(56, 189, 248, 0.2)
  --smartShade     rgba(14, 165, 233, 1)
  --hot            rgba(248, 113, 113, 1)

  /* legacy names mapped to new palette */
  --phase          var(--bg0)
  --phaseLight     var(--bg1)
  --phaseShade     rgb(2, 3, 10)
  --outerspace     var(--text0)
  --shader         rgba(3, 5, 15, 0.85)

  --accent1        var(--electric)
  --accent2        rgb(148, 163, 184)
  --accent3        rgb(139, 92, 246)
  --accent4        rgb(239, 68, 68)
  --accent5        rgb(34, 197, 94)
  --accent6        rgb(168, 85, 247)
  --accent7        rgb(14, 165, 233)
  --accent8        rgb(56, 189, 248)
  --accent9        rgb(99, 102, 241)
  --accent10       rgb(6, 182, 212)

  /* NO shadows — electric glow borders replace them */
  --cardDrop       none
  --cardGlow       none
  --hoverGlow      none

  /* LightPay unique */
  --accentPrimary  var(--electric)
  --accentLight    var(--electricBright)
  --accentDark     var(--electricDark)
  --accentGlow     var(--electricGlow)
  --surfacePrimary var(--bg1)
  --surfaceSecondary var(--bg2)

  /* lp-* prefix variants (backward compat) */
  --lp-bg-deep      var(--bg0)
  --lp-bg-base      var(--bg1)
  --lp-bg-card      var(--bg2)
  --lp-bg-raised    var(--bg3)
  --lp-bg-hover     rgba(14, 165, 233, 0.06)
  --lp-bg-active    rgba(14, 165, 233, 0.12)

  --lp-neon         var(--electric)
  --lp-neon-bright  var(--electricBright)
  --lp-blue         var(--electricDark)
  --lp-blue-deep    rgb(2, 100, 170)
  --lp-blue-ultra   rgb(1, 50, 100)

  --lp-neon-01      rgba(14, 165, 233, 0.1)
  --lp-neon-02      rgba(14, 165, 233, 0.2)
  --lp-neon-03      rgba(14, 165, 233, 0.3)
  --lp-neon-05      rgba(14, 165, 233, 0.5)
  --lp-neon-08      rgba(14, 165, 233, 0.8)
  --lp-blue-01      rgba(2, 132, 199, 0.1)
  --lp-blue-02      rgba(2, 132, 199, 0.2)

  --lp-border       var(--electricBorder)
  --lp-border-mid   rgba(14, 165, 233, 0.3)
  --lp-border-bright rgba(56, 189, 248, 0.55)
  --lp-border-glow  rgba(56, 189, 248, 0.7)

  --lp-text         var(--text0)
  --lp-text-sec     var(--text1)
  --lp-text-dim     var(--text2)
  --lp-text-neon    var(--electric)

  --lp-good         var(--good)
  --lp-good-01      var(--good01)
  --lp-good-03      rgba(34, 197, 94, 0.3)
  --lp-warn         var(--warn)
  --lp-warn-01      var(--warnFaint)
  --lp-bad          var(--bad)
  --lp-bad-01       var(--badFaint)
  --lp-bad-03       rgba(239, 68, 68, 0.3)

  --overlayA        rgba(3, 5, 15, 0.97)
  --overlayB        rgba(6, 9, 22, 0.95)

// ─── Body-level design tokens ────────────────────────────────

body
  // Elevation — NO shadows, use borders
  --cardDrop none
  --cardGlow none
  --hoverGlow none

  // Transitions — Material ease
  --standardFaster .08s cubic-bezier(0.4, 0, 0.2, 1) all
  --standardFast .18s cubic-bezier(0.4, 0, 0.2, 1) all
  --standard .28s cubic-bezier(0.4, 0, 0.2, 1) all
  --standardVibe .42s cubic-bezier(0.4, 0, 0.2, 1) all
  --standardSlow .56s cubic-bezier(0.4, 0, 0.2, 1) all
  --standardSlower .84s cubic-bezier(0.4, 0, 0.2, 1) all
  --standardSlowest 1.4s cubic-bezier(0.4, 0, 0.2, 1) all
  --slowRocket 2.2s cubic-bezier(0.34, 1.56, 0.64, 1) all

  --cubic cubic-bezier(0.4, 0, 0.2, 1)

  font-feature-settings 'ss04', 'zero'

// ─── Global base ─────────────────────────────────────────────

html, body
  background var(--bg0)
  color var(--text0)

::selection
  background-color rgba(14, 165, 233, 0.3)
  color var(--text0)

::-webkit-scrollbar
  width 4px
  height 4px

::-webkit-scrollbar-track
  background transparent

::-webkit-scrollbar-thumb
  background rgba(14, 165, 233, 0.35)
  border-radius 2px

::-webkit-scrollbar-thumb:hover
  background rgba(14, 165, 233, 0.6)

// ─── Card base ───────────────────────────────────────────────

.card
  background var(--bg2)
  border 1px solid var(--electricBorder)
  border-radius 10px

// ─── Button primary ──────────────────────────────────────────

.btn-primary, .button-primary
  background var(--electric)
  color var(--bg0)
  border 1px solid transparent

  &:hover
    background var(--electricBright)

// ─── Overlay gradient ────────────────────────────────────────

.lightpayOverlay
  position absolute
  top 0
  right 0
  bottom 0
  left 0
  pointer-events none
  z-index 9999999999999998

.vaultOverlay
  position absolute
  top 0
  right 0
  bottom 0
  left 0
  background linear-gradient(155deg, var(--overlayA) 0%, var(--overlayB) 100%)
  z-index 9999999999999999
  pointer-events none

body::before
  content ''
  position fixed
  top 0
  right 0
  bottom 0
  left 0
  pointer-events none
  z-index 0
  background:
    radial-gradient(ellipse 80% 50% at 15% 0%, rgba(14, 165, 233, 0.04), transparent 70%),
    radial-gradient(ellipse 70% 45% at 90% 8%, rgba(56, 189, 248, 0.03), transparent 70%),
    radial-gradient(ellipse 90% 60% at 85% 95%, rgba(14, 165, 233, 0.04), transparent 75%),
    radial-gradient(ellipse 80% 50% at 8% 92%, rgba(56, 189, 248, 0.03), transparent 70%),
    radial-gradient(ellipse 120% 45% at 50% 50%, rgba(14, 165, 233, 0.02), transparent 60%)
  animation vaultPulse 8s ease-in-out infinite

// ─── Shared light/dark palette ────────────────────────────────

.light, .dark
  --hardware var(--lightning)
  --hardware2 var(--text0)
  --smart var(--electricBright)
  --smart04 rgba(56, 189, 248, 0.4)
  --smart02 rgba(56, 189, 248, 0.2)
  --smartShade var(--electric)
  --hot rgba(248, 113, 113, 1)
  --shader rgba(3, 5, 15, 0.75)
  --phase var(--bg0)
  --phaseLight var(--bg2)
  --phaseShade rgb(2, 3, 10)

  // ─── Green good ──────────────────────────────────────────────
  --goodHighlighter rgb(74, 222, 128)
  --goodHighlight rgba(74, 222, 128, 0.15)
  --goodLight rgb(74, 222, 128)
  --goodOver rgba(0, 60, 30, 1)
  --good rgb(34, 197, 94)
  --goodUp rgb(74, 222, 128)
  --goodShade rgb(21, 128, 61)
  --good0 rgba(34, 197, 94, 0)
  --good01 rgba(34, 197, 94, 0.1)
  --good02 rgba(34, 197, 94, 0.2)
  --good03 rgba(34, 197, 94, 0.3)
  --good04 rgba(34, 197, 94, 0.4)
  --good06 rgba(34, 197, 94, 0.6)
  --goodDark rgba(22, 163, 74, 1)

  // ─── Red error ───────────────────────────────────────────────
  --badOver rgb(60, 0, 10)
  --bad rgb(239, 68, 68)
  --bad0 rgba(239, 68, 68, 0)
  --bad01 rgba(239, 68, 68, 0.1)
  --bad04 rgba(239, 68, 68, 0.4)
  --bad06 rgba(239, 68, 68, 0.6)

  // ─── Electric pending ────────────────────────────────────────
  --pendingOver rgb(0, 15, 45)
  --pending var(--electricBright)
  --pending04 rgba(56, 189, 248, 0.4)
  --pendingShade var(--electric)
  --pendingShade2 var(--electricDark)

  // ─── Amber warning ───────────────────────────────────────────
  --warning var(--warn)

  --foreverwhite rgba(224, 242, 254, 1)
  --moonHighlight rgba(248, 113, 113, 0.3)
  --moonOver rgba(80, 0, 10, 1)
  --moon rgba(248, 113, 113, 1)
  --moonDark rgba(185, 28, 28, 1)
  --moon06 rgba(248, 113, 113, 0.6)
  --moonLight rgba(252, 165, 165, 1)
  --mint rgba(34, 197, 94, 1)
  --mintOver rgba(0, 60, 30, 1)

  // ─── Accent palette — electric blue variants ─────────────────
  --accent1 rgb(14, 165, 233)    // Mainnet — Electric blue
  --accent2 rgb(250, 204, 21)    // Testnets — Lightning yellow
  --accent3 rgb(125, 211, 252)   // Default — Lightning sky
  --accent4 rgb(239, 68, 68)     // Optimism — Red
  --accent5 rgb(34, 197, 94)     // Gnosis — Green
  --accent6 rgb(14, 165, 233)    // Polygon — Electric
  --accent7 rgb(56, 189, 248)    // Arbitrum — Sky
  --accent8 rgb(14, 165, 233)    // Other — Electric blue

// ─── Light mode ──────────────────────────────────────────────

.light
  --v #0a2a4a
  --outerspace01 rgba(14, 165, 233, 0.1)
  --outerspace02 rgba(14, 165, 233, 0.2)
  --outerspace03 rgba(14, 165, 233, 0.3)
  --outerspace05 rgba(14, 165, 233, 0.5)
  --outerspace06 rgba(14, 165, 233, 0.6)
  --outerspace07 rgba(14, 165, 233, 0.7)
  --outerspace08 rgba(14, 165, 233, 0.8)
  --outerspace09 rgba(14, 165, 233, 0.9)
  --outerspace rgba(2, 132, 199, 1)

  --nebula #083050
  --outerspaceLight #0e4a72
  --outerspacePulse #093860
  --outerspacePhase rgba(1, 30, 70, 1)
  --outerspaceDark #020810
  --spacewhite rgba(224, 242, 254, 1)

  --ghostX02 rgba(14, 165, 233, 0.2)
  --ghostX04 rgba(14, 165, 233, 0.4)
  --ghostX09 rgba(14, 165, 233, 0.9)
  --ghostX rgba(14, 165, 233, 1)
  --ghostY rgba(56, 189, 248, 1)
  --ghostZ0 rgba(56, 189, 248, 0)
  --ghostZ05 rgba(56, 189, 248, 0.5)
  --ghostZ08 rgba(56, 189, 248, 0.8)
  --ghostZ rgba(56, 189, 248, 1)
  --ghostAZ rgba(125, 211, 252, 1)
  --ghostA05 rgba(125, 211, 252, 0.5)
  --ghostA rgba(125, 211, 252, 1)
  --ghostB0 rgba(186, 230, 253, 0)
  --ghostB05 rgba(186, 230, 253, 0.5)
  --ghostB rgba(186, 230, 253, 1)
  --ghostC0 rgba(224, 242, 254, 0)
  --ghostC rgba(224, 242, 254, 1)
  --ghostD rgba(240, 249, 255, 1)

  --moon rgb(239, 68, 68)
  --moonDark rgba(185, 28, 28, 1)
  --moonLight rgba(248, 113, 113, 1)
  --moonOver rgba(254, 226, 226, 1)

  --goodHighlighter rgb(74, 222, 128)
  --goodHighlight rgba(74, 222, 128, 0.15)
  --good rgb(34, 197, 94)
  --goodOver rgba(220, 252, 231, 1)
  --goodUp rgb(74, 222, 128)
  --goodDark rgb(22, 163, 74)
  --good0 rgba(34, 197, 94, 0)
  --good01 rgba(34, 197, 94, 0.1)
  --good02 rgba(34, 197, 94, 0.18)
  --good03 rgba(34, 197, 94, 0.28)
  --good04 rgba(34, 197, 94, 0.4)
  --good06 rgba(34, 197, 94, 0.6)
